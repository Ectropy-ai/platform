  "version": "0.1.0",
  "type": "module",
  "description": "Ectropy - Enterprise Federated Construction Platform with BIM Collaboration and DAO Governance",
  "private": true,
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "postinstall": "pnpm nx run-many --target=postinstall --all --parallel=1 || true",
    "build": "pnpm nx run-many --target=build --all",
    "build:web": "pnpm nx run web-dashboard:build",
    "build:api": "pnpm nx run api-gateway:build",
    "build:mcp": "pnpm nx run mcp-server:build",
    "test:build": "pnpm build:web && pnpm build:api && pnpm build:mcp",
    "truth": "./scripts/truth-baseline.sh",
    "clean": "rm -rf dist node_modules apps/*/node_modules libs/*/node_modules",
    "reset": "pnpm clean && pnpm install && pnpm nx reset"
  },
