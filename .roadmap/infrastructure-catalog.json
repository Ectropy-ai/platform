{
  "$schema": "https://luhtech.dev/schemas/infrastructure-catalog-v1.json",
  "version": "2.0.0",
  "ventureId": "ectropy",
  "lastUpdated": "2026-02-20T00:00:00Z",
  "catalog": {
    "environments": [
      {
        "id": "env-dev",
        "name": "Development",
        "type": "development",
        "url": "http://localhost:4000",
        "notes": "Local Docker Compose with 13+ services on ectropy_ectropy-network"
      },
      {
        "id": "env-staging",
        "name": "Staging",
        "type": "staging",
        "url": "https://staging.ectropy.ai",
        "notes": "DigitalOcean droplet, 11 services operational, demo-ready validated"
      },
      {
        "id": "env-prod",
        "name": "Production",
        "type": "production",
        "url": "https://ectropy.ai",
        "servers": [
          {
            "id": "server-do-primary",
            "name": "ectropy-production",
            "provider": "digitalocean",
            "region": "sfo3",
            "specs": {
              "cpu": "4 vCPU",
              "memory": "8GB",
              "storage": "160GB SSD",
              "os": "Ubuntu 24.04 LTS"
            },
            "services": [
              "service-web-dashboard",
              "service-api-gateway",
              "service-mcp-server",
              "service-mcp-express",
              "service-speckle",
              "service-postgresql",
              "service-redis",
              "service-minio",
              "service-n8n",
              "service-nginx",
              "service-qdrant"
            ]
          }
        ],
        "notes": "Single-server deployment with Docker Compose"
      },
      {
        "id": "env-pilot",
        "name": "Canadian Plant Pilot",
        "type": "preview",
        "url": "https://pilot.jsc.ai",
        "notes": "March 2026 pilot deployment with JSC edge servers",
        "features": {
          "decision-lifecycle": true,
          "voxel-decision-surface": true
        },
        "servers": [
          {
            "id": "server-edge-karbon521",
            "name": "Karbon 521 Edge Server",
            "provider": "digitalocean",
            "region": "canadian-plant-facility",
            "specs": {
              "model": "OnLogic Karbon 521",
              "cpu": "Intel Core Ultra 5 125H (14 cores / 18 threads)",
              "memory": "16GB DDR5-5600",
              "storage": "512GB NVMe Gen4",
              "os": "Ubuntu 24.04 LTS",
              "hardware": {
                "network": "4x 2.5GbE Intel I226-IT",
                "power": "12-48 VDC (no inverter required)",
                "temperature": "-40C to +70C (MIL-STD-810H)",
                "formFactor": "Fanless rugged low-profile"
              },
              "connectivity": {
                "primary": "Starlink Gen 3 Performance Kit",
                "failover": "Peplink BR1 Pro 5G",
                "secondary": "Peplink BR2 4G LTE",
                "wifi": "UniFi U7 Pro Outdoor (WiFi 7, 300+ users)"
              },
              "compose": "docker-compose.edge.yml",
              "resourceBudget": {
                "cpuLimits": "4.0 cores",
                "memoryLimits": "3.5GB",
                "cpuReserved": "1.9 cores",
                "memoryReserved": "1.7GB",
                "headroomCpu": "10+ cores",
                "headroomMemory": "12.5+ GB"
              }
            },
            "services": [
              "service-web-dashboard",
              "service-api-gateway",
              "service-mcp-server",
              "service-edge-server",
              "service-mqtt-broker",
              "service-postgresql-local",
              "service-redis",
              "service-nginx"
            ]
          }
        ]
      }
    ],
    "services": [
      {
        "id": "service-web-dashboard",
        "name": "Web Dashboard",
        "type": "web",
        "description": "Next.js 14 application with BIM viewer and role-based dashboards",
        "repository": "luhtech/Ectropy/apps/web-dashboard",
        "ports": {
          "internal": 3000,
          "external": 443
        },
        "healthCheck": {
          "endpoint": "/",
          "interval": "30s",
          "timeout": "10s",
          "retries": 3
        },
        "status": "operational"
      },
      {
        "id": "service-mcp-server",
        "name": "MCP Server (Native Protocol)",
        "type": "api",
        "description": "Model Context Protocol server for AI agent integration. Includes 17 Decision Lifecycle tools.",
        "repository": "luhtech/Ectropy/apps/mcp-server",
        "ports": {
          "internal": 3001,
          "external": 3001
        },
        "healthCheck": {
          "endpoint": "/health",
          "interval": "30s",
          "timeout": "10s",
          "retries": 3,
          "lastScore": 64
        },
        "dependencies": ["service-postgresql", "service-redis"],
        "status": "operational"
      },
      {
        "id": "service-api-gateway",
        "name": "API Gateway",
        "type": "api",
        "description": "Express REST API with OAuth, Prisma ORM, and Passport.js authentication",
        "repository": "luhtech/Ectropy/apps/api-gateway",
        "ports": {
          "internal": 3002,
          "external": 3002
        },
        "healthCheck": {
          "endpoint": "/api/health",
          "interval": "30s",
          "timeout": "10s",
          "retries": 3,
          "lastScore": 80
        },
        "dependencies": ["service-postgresql", "service-redis"],
        "status": "operational"
      },
      {
        "id": "service-mcp-express",
        "name": "MCP Express API",
        "type": "api",
        "description": "HTTP wrapper for MCP server REST access",
        "repository": "luhtech/Ectropy/apps/mcp-server",
        "ports": {
          "internal": 3003,
          "external": 3003
        },
        "dependencies": ["service-mcp-server"],
        "status": "operational"
      },
      {
        "id": "service-decision-lifecycle",
        "name": "Decision Lifecycle Service",
        "type": "api",
        "description": "Flagship feature: Proactive decision navigation with 7-tier authority cascade. Transforms 28-hour escalations into 10-second acknowledgments.",
        "repository": "luhtech/Ectropy/apps/api-gateway",
        "dependencies": ["service-postgresql", "service-voxel-service"],
        "status": "planned"
      },
      {
        "id": "service-voxel-service",
        "name": "Voxel Decision Surface Service",
        "type": "api",
        "description": "Spatial decision attachment - every decision lives in physical space. Workers entering voxel zones automatically see pre-approved decisions.",
        "repository": "luhtech/Ectropy/apps/api-gateway",
        "dependencies": ["service-postgresql", "service-speckle"],
        "status": "planned"
      }
    ],
    "ports": {
      "service-web-dashboard": {
        "development": 3000,
        "staging": 3000,
        "production": 3000,
        "description": "Next.js web application"
      },
      "service-mcp-server": {
        "development": 3001,
        "staging": 3001,
        "production": 3001,
        "description": "MCP Native Protocol"
      },
      "service-api-gateway": {
        "development": 3002,
        "staging": 3002,
        "production": 3002,
        "description": "Express API Gateway"
      },
      "service-mcp-express": {
        "development": 3003,
        "staging": 3003,
        "production": 3003,
        "description": "MCP Express HTTP API"
      },
      "service-speckle": {
        "development": 3101,
        "staging": 3101,
        "production": 3101,
        "description": "Speckle BIM Server"
      },
      "service-nginx": {
        "development": 4000,
        "staging": 443,
        "production": 443,
        "description": "Nginx reverse proxy (external)"
      },
      "service-postgresql": {
        "development": 5432,
        "staging": 5432,
        "production": 5432,
        "description": "PostgreSQL database"
      },
      "service-n8n": {
        "development": 5678,
        "staging": 5678,
        "production": 5678,
        "description": "n8n workflow automation"
      },
      "service-redis": {
        "development": 6379,
        "staging": 6379,
        "production": 6379,
        "description": "Redis cache"
      },
      "service-qdrant": {
        "development": 6333,
        "staging": 6333,
        "production": 6333,
        "description": "Qdrant vector database"
      },
      "service-minio": {
        "development": 9000,
        "staging": 9000,
        "production": 9000,
        "description": "MinIO object storage"
      }
    },
    "databases": [
      {
        "id": "db-ectropy-staging",
        "name": "ectropy",
        "type": "postgresql",
        "version": "16",
        "hosted": true,
        "provider": "DigitalOcean Managed PostgreSQL",
        "connectionStringRef": "DATABASE_URL",
        "backupPolicy": {
          "frequency": "daily (automated by DigitalOcean)",
          "retention": "7 days",
          "location": "DigitalOcean managed storage (encrypted)"
        },
        "extensions": ["uuid-ossp", "pg_stat_statements"]
      },
      {
        "id": "db-speckle",
        "name": "speckle",
        "type": "postgresql",
        "version": "15.15",
        "hosted": false,
        "provider": "Self-hosted (Docker)",
        "connectionStringRef": "SPECKLE_POSTGRES_URL"
      },
      {
        "id": "db-redis-cache",
        "name": "ectropy-redis",
        "type": "redis",
        "version": "7",
        "hosted": false,
        "provider": "Self-hosted (Docker)",
        "connectionStringRef": "REDIS_URL"
      },
      {
        "id": "db-qdrant",
        "name": "ectropy-qdrant",
        "type": "elasticsearch",
        "version": "latest",
        "hosted": false,
        "provider": "Self-hosted (Docker)",
        "connectionStringRef": "QDRANT_URL"
      }
    ],
    "workflows": [
      {
        "name": "Deploy Staging",
        "file": ".github/workflows/deploy-staging.yml",
        "triggers": ["push"],
        "branches": ["develop"],
        "maturity": 4,
        "description": "Build, test, and deploy to staging environment"
      },
      {
        "name": "Deploy Production Enterprise",
        "file": ".github/workflows/deploy-production-enterprise.yml",
        "triggers": ["workflow_dispatch", "push"],
        "branches": ["main"],
        "maturity": 4,
        "description": "Production deployment with 5-layer immutable architecture"
      },
      {
        "name": "Foundation (CI)",
        "file": ".github/workflows/foundation.yml",
        "triggers": ["push", "pull_request"],
        "maturity": 4,
        "description": "Type-check, lint, unit tests, E2E tests"
      },
      {
        "name": "Roadmap Validation",
        "file": ".github/workflows/roadmap-ci.yml",
        "triggers": ["push", "pull_request"],
        "maturity": 3,
        "description": "Validate .roadmap/ files against V3 schemas"
      },
      {
        "name": "n8n Feature Pipeline",
        "file": "infrastructure/n8n/workflows/feature-pipeline.json",
        "triggers": ["push", "workflow_dispatch"],
        "paths": [".roadmap/schemas/**"],
        "maturity": 1,
        "description": "AI-driven code generation: Schema to Prisma to GraphQL to React to Playwright"
      }
    ]
  },
