  "architecturePatterns": [
    {
      "name": "modular-monolith",
      "description": "Nx-managed monorepo with discrete apps and shared libs",
      "implementation": "apps/ for deployable applications, libs/ for shared code",
      "rationale": "Enables code sharing while maintaining clear boundaries and independent deployability",
      "scope": "full-system"
    },
    {
      "name": "api-first",
      "description": "Single entry point for all API requests with OAuth and session management",
      "implementation": "Express server at port 3002 with Passport.js strategies",
      "rationale": "Centralized authentication, rate limiting, and request routing",
      "scope": "api"
    },
    {
      "name": "mcp-server",
      "description": "Model Context Protocol for AI agent integration with platform data",
      "implementation": "Node.js MCP server serving JSON governance files",
      "rationale": "Enables structured AI interactions with enterprise construction data",
      "scope": "backend"
    },
    {
      "name": "domain-driven",
      "description": "BIM collaboration via self-hosted Speckle server",
      "implementation": "5-service Speckle stack with @speckle/viewer React component",
      "rationale": "Open-source BIM collaboration with 3D viewer and version control",
