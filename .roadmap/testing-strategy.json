        "patterns": [
          "AIA G702/G703 format",
          "Retainage calculations",
          "Invoice generation"
        ]
      }
    ]
  },

  "testDataManagement": {
    "fixtures": {
      "location": "**/__fixtures__/",
      "patterns": [
        "{domain}-fixtures.json - Domain-specific test data",
        "mock-{entity}.ts - TypeScript factory functions"
      ],
      "guidelines": [
        "Use factory functions for dynamic test data",
        "Store static fixtures in JSON files",
        "Never use production data in tests",
        "Fixtures should match schema exactly"
      ]
    },
    "mocking": {
      "tools": ["vitest mock", "msw"],
      "patterns": [
        "Mock external services at network boundary",
        "Use dependency injection for service mocks",
        "Prefer real implementations over mocks when fast"
      ]
    }
  },

  "ciIntegration": {
    "workflow": ".github/workflows/test.yml",
    "stages": [
      {
        "name": "lint",
        "blocking": true,
        "command": "pnpm lint"
      },
      {
        "name": "typecheck",
        "blocking": true,
        "command": "pnpm typecheck"
      },
      {
        "name": "schema-validation",
        "blocking": true,
        "command": "pnpm validate:schemas"
      },
      {
        "name": "unit-tests",
        "blocking": true,
        "command": "pnpm test:unit"
      },
      {
        "name": "integration-tests",
        "blocking": true,
        "command": "pnpm test:integration"
      },
      {
        "name": "e2e-tests",
        "blocking": false,
        "command": "pnpm test:e2e",
        "conditions": ["staging deploy", "release branch"]
      }
    ],
    "parallelization": {
      "enabled": true,
      "shards": 4,
      "strategy": "Test file distribution"
    }
  },

  "performanceBaselines": {
    "targets": {
      "unitTest": {
        "maxDuration": "200ms per test",
        "totalSuite": "60 seconds"
      },
      "integrationTest": {
        "maxDuration": "2 seconds per test",
        "totalSuite": "5 minutes"
      },
      "e2eTest": {
        "maxDuration": "30 seconds per test",
        "totalSuite": "15 minutes"
      },
      "apiResponse": {
        "p50": "50ms",
        "p95": "200ms",
        "p99": "500ms"
      }
    }
  },

  "evidenceTracking": {
    "testResults": {
      "format": "JSON",
      "retention": "90 days",
      "location": "CI artifacts",
      "fields": ["timestamp", "commit", "branch", "passed", "failed", "duration"]
    },
    "coverageReports": {
      "format": "lcov, json",
      "retention": "30 days",
      "thresholds": {
        "global": 80,
        "perFile": 70
      }
    }
  },

  "testTemplates": {
    "unitTest": "import { describe, it, expect, beforeEach } from 'vitest';\nimport { {FunctionUnderTest} } from '../{module}';\n\ndescribe('{FunctionUnderTest}', () => {\n  beforeEach(() => {\n    // Setup\n  });\n\n  it('should {expected behavior} when {condition}', () => {\n    // Arrange\n    const input = {};\n    \n    // Act\n    const result = {FunctionUnderTest}(input);\n    \n    // Assert\n    expect(result).toEqual({});\n  });\n\n  it('should throw error when {invalid condition}', () => {\n    expect(() => {FunctionUnderTest}(null)).toThrow();\n  });\n});",

    "integrationTest": "import { describe, it, expect, beforeAll, afterAll } from 'vitest';\nimport { setupTestServer, teardownTestServer } from '../test-utils';\n\ndescribe('{Feature} Integration', () => {\n  let server;\n\n  beforeAll(async () => {\n    server = await setupTestServer();\n  });\n\n  afterAll(async () => {\n    await teardownTestServer(server);\n  });\n\n  it('should {expected behavior} across services', async () => {\n    // Arrange: Setup initial state\n    \n    // Act: Trigger cross-service operation\n    \n    // Assert: Verify end state\n  });\n});",

    "schemaValidation": "import Ajv from 'ajv';\nimport addFormats from 'ajv-formats';\nimport schema from '../schemas/{domain}/{schema}.schema.json';\n\nconst ajv = new Ajv({ allErrors: true });\naddFormats(ajv);\nconst validate = ajv.compile(schema);\n\ndescribe('{Schema} Validation', () => {\n  it('should validate correct document', () => {\n    const validDoc = { /* valid data */ };\n    expect(validate(validDoc)).toBe(true);\n  });\n\n  it('should reject document missing required fields', () => {\n    const invalidDoc = {};\n    expect(validate(invalidDoc)).toBe(false);\n  });\n});"
  },

  "roadmap": {
    "current": {
      "phase": "5b",
      "testCoverage": "68%",
      "passingTests": 691,
      "totalTests": 735
    },
    "milestones": [
