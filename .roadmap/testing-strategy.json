        "status": "partial"
      },
      {
        "milestone": "M3",
        "name": "Integration Test Suite",
        "target": "Cross-service contract tests",
        "status": "planned"
      },
      {
        "milestone": "M4",
        "name": "E2E Coverage",
        "target": "Key user journeys automated",
        "status": "planned"
      }
    ]
  }
}
