{
  "$schema": "https://luhtech.dev/schemas/testing-strategy.schema.json",
  "$id": "urn:luhtech:ectropy:file:testing-strategy",
  "schemaVersion": "1.0.0",
  "ventureId": "ectropy",
  "lastUpdated": "2026-01-22T22:00:00Z",

  "meta": {
    "sourceOfTruth": ".roadmap/testing-strategy.json",
    "description": "Schema-first testing strategy for Ectropy platform - defines test patterns, coverage requirements, and validation approaches aligned with industry best practices"
  },

  "philosophy": {
    "approach": "Schema-First Test-Driven Development",
    "principles": [
      "Schema defines structure, tests validate behavior",
      "Every schema domain has corresponding test suite",
      "Integration tests validate cross-service contracts",
      "Evidence chain maintains test result immutability"
    ],
    "coverage": {
      "unit": "80% minimum for services",
      "integration": "Critical paths 100%",
      "e2e": "Key user journeys"
    }
  },

  "testingLayers": {
    "layer1_schema": {
      "name": "Schema Validation",
      "description": "Validate JSON documents against JSON Schema definitions",
      "tools": ["ajv-cli", "ajv-formats"],
      "location": "CI/CD workflow",
      "frequency": "Every PR",
      "blocking": true,
      "patterns": [
        {
          "name": "Roadmap File Validation",
          "target": ".roadmap/*.json",
          "schemas": "luh-tech/luh-tech-roadmap-template/schemas/",
          "examples": [
            "ajv validate -s roadmap.schema.v2.json -d .roadmap/roadmap.json"
          ]
        },
        {
          "name": "Domain Schema Meta-Validation",
          "target": ".roadmap/schemas/**/*.json",
          "schemas": "JSON Schema Draft 7",
          "examples": [
            "ajv compile -s schema.json --spec=draft7"
          ]
        }
      ]
    },

    "layer2_unit": {
      "name": "Unit Tests",
      "description": "Test individual functions and service methods in isolation",
      "tools": ["vitest", "jest"],
      "location": "**/__tests__/*.spec.ts, **/*.test.ts",
      "frequency": "Every PR",
      "blocking": true,
      "patterns": [
        {
          "name": "Service Function Tests",
          "description": "Test pure functions with mock data",
          "template": {
            "file": "{service}.spec.ts",
            "structure": [
              "describe('{ServiceName}', () => {",
              "  describe('{functionName}', () => {",
              "    it('should {expected behavior}', () => {",
              "      // Arrange: Set up test data",
              "      // Act: Call function",
              "      // Assert: Verify results",
              "    });",
              "  });",
              "});"
            ]
          },
          "examples": [
            "apps/mcp-server/src/services/__tests__/usf-decision-lifecycle.spec.ts"
          ]
        },
        {
          "name": "MCP Tool Tests",
          "description": "Test MCP tool handlers with mock context",
          "template": {
            "file": "{tool-category}-tools.spec.ts",
            "structure": [
              "describe('MCP Tools - {Category}', () => {",
              "  describe('{tool_name}', () => {",
              "    it('should validate input schema', () => {});",
              "    it('should return expected output format', () => {});",
              "    it('should handle error cases gracefully', () => {});",
              "  });",
              "});"
            ]
          }
        }
      ],
      "coverageRequirements": {
        "statements": 80,
        "branches": 75,
        "functions": 80,
        "lines": 80
      }
    },

    "layer3_integration": {
      "name": "Integration Tests",
      "description": "Test service interactions and API contracts",
      "tools": ["vitest", "supertest"],
      "location": "**/__tests__/*.integration.spec.ts",
      "frequency": "Every PR",
      "blocking": true,
      "patterns": [
        {
          "name": "Service Integration",
          "description": "Test cross-service data flow",
          "template": {
            "file": "{feature}-integration.spec.ts",
            "structure": [
              "describe('{Feature} Integration', () => {",
              "  describe('Service A → Service B', () => {",
              "    it('should propagate data correctly', () => {});",
              "    it('should handle service B failures gracefully', () => {});",
              "  });",
              "});"
            ]
          },
          "examples": [
            "apps/mcp-server/src/services/__tests__/usf-voxel-integration.spec.ts"
          ]
        },
        {
          "name": "API Contract Tests",
          "description": "Validate REST/GraphQL API responses match schema",
          "template": {
            "file": "{api}-contract.spec.ts",
            "structure": [
              "describe('API Contract - {Endpoint}', () => {",
              "  it('should return schema-compliant response', async () => {",
              "    const response = await request(app).get('/api/v1/{endpoint}');",
              "    expect(ajv.validate(schema, response.body)).toBe(true);",
              "  });",
              "});"
            ]
          }
        }
      ]
    },

    "layer4_e2e": {
      "name": "End-to-End Tests",
      "description": "Test complete user journeys through the system",
      "tools": ["playwright"],
      "location": "apps/web-dashboard-e2e/",
      "frequency": "Pre-release, nightly",
      "blocking": false,
      "patterns": [
        {
          "name": "User Journey Tests",
          "description": "Test complete workflows from UI to database",
          "template": {
            "file": "{journey}.spec.ts",
            "structure": [
              "test.describe('{User Journey}', () => {",
              "  test('should complete {action} successfully', async ({ page }) => {",
              "    // Navigate to feature",
              "    // Perform user actions",
              "    // Verify outcomes",
              "  });",
              "});"
            ]
          }
        }
      ]
    }
  },

  "domainTestPatterns": {
