{
  "$schema": "https://luhtech.dev/schemas/architecture-v1.json",
  "$id": "urn:luhtech:ectropy:architecture:mcp-seppa-backend",
  "schemaVersion": "1.0.0",
  "meta": {
    "title": "MCP + SEPPA Backend Architecture",
    "description": "Backend service architecture for Seppä construction intelligence assistant including Claude orchestration, RAG, and phone agent services",
    "lastUpdated": "2026-01-14T00:00:00Z",
    "author": "Technical Architecture Team",
    "references": [
      "SEPPA_Claude_Integration_Handoff.md",
      "SEPPA_Technical_Specification_v1",
      "ectropy-claude-assistant-plan.md"
    ]
  },
  "architecture": {
    "overview": "Three-service architecture within the Ectropy Intelligence Layer (EIL) providing AI-powered construction decision support across web, SMS, and voice channels",
    "pattern": "Microservices with shared database and event-driven communication",
    "designPrinciples": [
      "Channel-agnostic intelligence layer",
      "Authority-aware tool execution",
      "Conversation context preservation",
      "Multi-tenant data isolation",
      "Graceful degradation under load"
    ],
    "dualMeaning": {
      "finnish": "Seppä - Master builder, journeyman craftsman",
      "technical": "SEPPA - Spatial Element Processing Prediction Aggregation"
    }
  },
  "components": [
    {
      "id": "assistant-service",
      "name": "Assistant Service",
      "port": 4005,
      "description": "Claude API orchestration with 24 PM decision tools and conversation management",
      "responsibilities": [
        "Claude API communication",
        "Tool registration and execution",
        "Conversation state management",
        "System prompt generation",
        "Authority-aware response filtering"
      ],
      "modules": [
        {
          "name": "claude-client",
          "file": "apps/mcp-server/src/services/assistant/claude-client.ts",
          "description": "Anthropic SDK wrapper with model selection and streaming support"
        },
        {
          "name": "tool-registry",
          "file": "apps/mcp-server/src/services/assistant/tool-registry.ts",
          "description": "24 tools registered: 21 PM + 3 core tools"
        },
        {
          "name": "tool-executor",
          "file": "apps/mcp-server/src/services/assistant/tool-executor.ts",
          "description": "Bridges Claude tool_use blocks to MCP tool handlers"
        },
        {
          "name": "system-prompt",
          "file": "apps/mcp-server/src/services/assistant/system-prompt.ts",
          "description": "Dynamic prompt generation with authority injection"
        },
        {
          "name": "conversation-store",
          "file": "apps/mcp-server/src/services/assistant/conversation-store.ts",
          "description": "In-memory conversation storage (Redis in production)"
        },
        {
          "name": "context-builder",
          "file": "apps/mcp-server/src/services/assistant/context-builder.ts",
          "description": "Message history and project context enrichment"
        },
        {
          "name": "assistant.service",
          "file": "apps/mcp-server/src/services/assistant/assistant.service.ts",
          "description": "Main orchestration with agentic tool loop"
        }
      ],
      "endpoints": [
        {
          "method": "POST",
          "path": "/api/assistant/chat",
          "description": "Send message, receive Claude response with tool execution"
        },
        {
          "method": "GET",
          "path": "/api/assistant/conversations/:id",
          "description": "Retrieve conversation history"
        },
        {
          "method": "DELETE",
          "path": "/api/assistant/conversations/:id",
          "description": "Delete conversation"
        },
        {
          "method": "POST",
          "path": "/api/assistant/conversations/:id/context",
          "description": "Update conversation context (project, voxels, authority)"
        },
        {
          "method": "GET",
          "path": "/api/assistant/health",
          "description": "Health check including Claude API connectivity"
        }
      ],
      "tools": {
        "decisionManagement": [
          {
            "name": "capture_decision",
            "description": "Create PM decision attached to voxel",
            "authorityRequired": "Level 0+"
          },
          {
            "name": "route_decision",
            "description": "Route decision to appropriate authority",
            "authorityRequired": "Level 1+"
          },
          {
            "name": "approve_decision",
            "description": "Approve decision within authority limits",
            "authorityRequired": "Varies by impact"
          },
          {
            "name": "reject_decision",
            "description": "Reject decision with documented reason",
            "authorityRequired": "Level 1+"
          },
          {
            "name": "escalate_decision",
            "description": "Escalate to higher authority level",
            "authorityRequired": "Any"
          },
          {
            "name": "query_decision_history",
            "description": "Query decisions by voxel/status/authority",
            "authorityRequired": "Level 0+"
          }
        ],
        "authorityGraph": [
          {
            "name": "get_authority_graph",
            "description": "Retrieve 7-tier authority cascade for project"
          },
          {
            "name": "find_decision_authority",
            "description": "Calculate required level for decision impacts"
          },
          {
            "name": "validate_authority_level",
            "description": "Check if participant can approve decision"
          }
        ],
        "voxelOperations": [
          {
            "name": "attach_decision_to_voxel",
            "description": "Link decision to 3D spatial location"
          },
          {
            "name": "get_voxel_decisions",
            "description": "Get all decisions for a voxel"
          },
          {
            "name": "navigate_decision_surface",
            "description": "BFS traversal of decision graph"
          }
        ],
        "toleranceManagement": [
          {
            "name": "apply_tolerance_override",
            "description": "Create pre-approved variance"
          },
          {
            "name": "query_tolerance_overrides",
            "description": "Query overrides by type/voxel"
          }
        ],
        "consequenceInspection": [
          {
            "name": "track_consequence",
            "description": "Create consequence linked to decision"
          },
          {
            "name": "request_inspection",
            "description": "Schedule inspection for voxel"
          },
          {
            "name": "complete_inspection",
            "description": "Record results, validate/fail decisions"
          }
        ],
        "core": [
          {
            "name": "get_project_info",
            "description": "Get project metadata"
          },
          {
            "name": "get_user_context",
            "description": "Get current user's authority and role"
          },
          {
            "name": "list_available_tools",
            "description": "List tools available to user"
          }
        ]
      }
    },
    {
      "id": "rag-service",
      "name": "RAG Service",
      "port": 4006,
      "description": "Vector search and context assembly for document-grounded responses",
      "status": "Phase 5 - Planned",
      "responsibilities": [
        "Document embedding generation",
        "Vector similarity search",
        "Context assembly with token budgets",
        "Citation tracking and source attribution"
      ],
      "integrations": {
        "vectorDb": {
          "provider": "Qdrant",
          "protocol": "gRPC/HTTP",
          "port": 6333
        },
        "embeddings": {
          "provider": "Jina AI",
          "model": "jina-embeddings-v3",
          "dimensions": 1024
        }
      },
      "collections": [
        {
          "name": "project_documents",
          "description": "Project-specific documents (specs, RFIs, submittals)",
          "isolation": "per-tenant collection for Enterprise"
        },
        {
          "name": "decision_history",
          "description": "Historical decisions for precedent search",
          "isolation": "shared with tenant filtering"
        },
        {
          "name": "regulatory_codes",
          "description": "Building codes, safety standards",
          "isolation": "shared read-only"
        }
      ],
      "chunkingStrategy": {
        "size": 512,
        "overlap": 64,
        "splitter": "recursive-character",
        "preserveStructure": true
      },
      "tokenBudgets": {
        "demo": 2000,
        "standard": 4000,
        "enterprise": 8000
      },
      "endpoints": [
        {
          "method": "POST",
          "path": "/api/rag/search",
          "description": "Semantic search across document collections"
        },
        {
          "method": "POST",
          "path": "/api/rag/embed",
          "description": "Generate embeddings for new documents"
        },
        {
          "method": "POST",
          "path": "/api/rag/index",
          "description": "Index document into vector store"
        },
        {
          "method": "GET",
          "path": "/api/rag/health",
          "description": "Health check including Qdrant connectivity"
        }
      ]
    },
    {
      "id": "phone-agent-service",
      "name": "Phone Agent Service",
      "port": 4007,
      "description": "SMS and voice channel handling with Twilio integration",
      "status": "Phase 6 - Planned",
      "responsibilities": [
        "Twilio webhook processing",
        "User identity resolution from phone number",
        "SMS intent classification",
        "Multi-turn SMS state machine",
        "160-character response formatting",
        "Voice transcription and synthesis"
      ],
      "integrations": {
        "telephony": {
          "provider": "Twilio",
          "features": ["SMS", "Voice", "WhatsApp-future"]
        },
        "assistantService": {
          "protocol": "REST",
          "port": 4005
        }
      },
      "smsStateMachine": {
        "states": [
          "IDLE",
          "AWAITING_PROJECT",
          "AWAITING_VOXEL",
          "AWAITING_DECISION_TYPE",
          "AWAITING_DESCRIPTION",
          "AWAITING_CONFIRMATION",
          "PROCESSING"
        ],
        "transitions": {
          "IDLE_to_AWAITING_PROJECT": "User sends first message without project context",
          "AWAITING_PROJECT_to_AWAITING_VOXEL": "User provides project name/code",
          "AWAITING_VOXEL_to_AWAITING_DECISION_TYPE": "User provides voxel/zone reference",
          "AWAITING_CONFIRMATION_to_IDLE": "User confirms or cancels"
        },
        "timeout": 300,
        "timeoutAction": "Return to IDLE with timeout message"
      },
      "intentClassification": {
        "intents": [
          "CAPTURE_DECISION",
          "QUERY_DECISIONS",
          "CHECK_AUTHORITY",
          "REQUEST_INSPECTION",
          "REPORT_ISSUE",
          "HELP"
        ],
        "model": "rule-based-with-claude-fallback"
      },
      "responseFormatting": {
        "maxLength": 160,
        "multipart": true,
        "maxParts": 3,
        "truncationStrategy": "priority-based"
      },
      "endpoints": [
        {
          "method": "POST",
          "path": "/api/phone/sms/webhook",
          "description": "Twilio SMS webhook handler"
        },
        {
          "method": "POST",
          "path": "/api/phone/voice/webhook",
          "description": "Twilio voice webhook handler"
        },
        {
          "method": "GET",
          "path": "/api/phone/user/:phoneNumber",
          "description": "Resolve phone number to user identity"
        },
        {
          "method": "GET",
          "path": "/api/phone/health",
          "description": "Health check including Twilio connectivity"
        }
      ]
    }
  ],
  "interfaces": [
    {
      "id": "assistant-chat-request",
      "name": "AssistantChatRequest",
      "type": "typescript",
      "definition": {
        "conversationId": "string | undefined",
        "message": "string",
        "context": {
          "projectId": "string",
          "activeVoxels": "string[]",
          "userRole": "string",
          "authorityLevel": "0 | 1 | 2 | 3 | 4 | 5 | 6",
          "viewerState": "object | undefined"
        },
        "options": {
          "stream": "boolean",
          "maxTokens": "number | undefined",
          "temperature": "number | undefined"
        }
      }
    },
    {
      "id": "assistant-chat-response",
      "name": "AssistantChatResponse",
      "type": "typescript",
      "definition": {
        "conversationId": "string",
        "messageId": "string",
        "content": "string",
        "toolCalls": [
          {
            "tool": "string",
            "input": "object",
            "output": "object",
            "duration": "number"
          }
        ],
        "citations": [
          {
            "source": "string",
            "chunk": "string",
            "relevance": "number"
          }
        ],
        "suggestions": "string[]",
        "usage": {
          "inputTokens": "number",
          "outputTokens": "number"
        }
      }
    },
    {
      "id": "sms-message",
      "name": "SMSMessage",
      "type": "typescript",
      "definition": {
        "from": "string",
        "to": "string",
        "body": "string",
        "timestamp": "ISO8601",
        "twilioSid": "string",
        "resolvedUser": {
          "userId": "string",
          "tenantId": "string",
          "authorityLevel": "number"
        }
      }
    }
  ],
  "dataFlows": [
    {
      "id": "web-chat-flow",
      "name": "Web Chat Flow",
      "description": "User interaction via admin dashboard chat panel",
      "steps": [
        {
          "step": 1,
          "action": "User types message in MCPChatPanel",
          "component": "admin-dashboard"
        },
        {
          "step": 2,
          "action": "Frontend POSTs to /api/assistant/chat with context",
          "component": "mcp-client.service"
        },
        {
          "step": 3,
          "action": "API Gateway validates auth, routes to assistant-service",
          "component": "api-gateway:4000"
        },
        {
          "step": 4,
          "action": "Context builder enriches message with project/user data",
          "component": "assistant-service:4005"
        },
        {
          "step": 5,
          "action": "RAG service retrieves relevant document chunks",
          "component": "rag-service:4006"
        },
        {
          "step": 6,
          "action": "System prompt generated with authority context",
          "component": "assistant-service"
        },
        {
          "step": 7,
          "action": "Claude API called with tools and context",
          "component": "claude-client"
        },
        {
          "step": 8,
          "action": "Tool executor processes any tool_use blocks",
          "component": "tool-executor"
        },
        {
          "step": 9,
          "action": "Response streamed back to frontend",
          "component": "assistant-service → admin-dashboard"
        }
      ]
    },
    {
      "id": "sms-decision-capture-flow",
      "name": "SMS Decision Capture Flow",
      "description": "Field worker capturing decision via SMS",
      "steps": [
        {
          "step": 1,
          "action": "Field worker texts: 'RFI needed for pipe routing in zone B3'",
          "component": "Mobile phone"
        },
        {
          "step": 2,
          "action": "Twilio receives SMS, posts to webhook",
          "component": "Twilio"
        },
        {
          "step": 3,
          "action": "Phone agent resolves phone → user identity",
          "component": "phone-agent-service:4007"
        },
        {
          "step": 4,
          "action": "Intent classified as CAPTURE_DECISION",
          "component": "phone-agent-service"
        },
        {
          "step": 5,
          "action": "State machine checks for missing context",
          "component": "phone-agent-service"
        },
        {
          "step": 6,
          "action": "Request forwarded to assistant-service",
          "component": "phone-agent-service → assistant-service"
        },
        {
          "step": 7,
          "action": "Claude processes with capture_decision tool",
          "component": "assistant-service"
        },
        {
          "step": 8,
          "action": "Decision created, attached to voxel",
          "component": "MCP Server PM tools"
        },
        {
          "step": 9,
          "action": "Confirmation formatted to 160 chars, sent via Twilio",
          "component": "phone-agent-service → Twilio"
        }
      ]
    }
  ],
  "contextManagement": {
    "conversationHistory": {
      "storage": "Redis (production) / In-memory (development)",
      "retention": "7 days",
      "maxTurns": 50,
      "tokenBudget": "8000 tokens for history"
    },
    "projectContext": {
      "injection": "System prompt + first message",
      "includes": [
        "Project name and ID",
        "Active voxels",
        "User role and authority level",
        "Budget and schedule authority limits"
      ]
    },
    "ragContext": {
      "injection": "Appended to user message",
      "format": "Numbered citations with source URNs",
      "maxChunks": "Tier-dependent (5/15/30)"
    }
  },
  "streaming": {
    "protocol": "Server-Sent Events (SSE)",
    "events": [
      {
        "type": "start",
        "description": "Stream started"
      },
      {
        "type": "content",
        "description": "Text content chunk"
      },
      {
        "type": "tool_start",
        "description": "Tool execution beginning"
      },
      {
        "type": "tool_end",
        "description": "Tool execution complete with result"
      },
      {
        "type": "done",
        "description": "Stream complete"
      },
      {
        "type": "error",
        "description": "Error occurred"
      }
    ]
  },
  "errorHandling": {
    "strategies": [
      {
        "error": "Claude API timeout",
        "action": "Retry with exponential backoff (max 3)",
        "fallback": "Return partial response with retry suggestion"
      },
      {
        "error": "Tool execution failure",
        "action": "Return error in tool result, let Claude handle gracefully",
        "fallback": "Suggest alternative approach to user"
      },
      {
        "error": "Authority validation failure",
        "action": "Block tool execution, explain authority requirements",
        "fallback": "Suggest escalation path"
      },
      {
        "error": "RAG service unavailable",
        "action": "Continue without document context",
        "fallback": "Note that response may be less context-aware"
      },
      {
        "error": "Rate limit exceeded",
        "action": "Return 429 with retry-after header",
        "fallback": "Suggest upgrade path for higher limits"
      }
    ],
    "logging": {
      "level": "info (production) / debug (development)",
      "includes": [
        "Request/response metadata",
        "Tool calls and durations",
        "Token usage",
        "Error details"
      ],
      "excludes": [
        "Full message content (PII)",
        "API keys",
        "Raw tool outputs with sensitive data"
      ]
    }
  },
  "environment": {
    "required": [
      {
        "name": "ANTHROPIC_API_KEY",
        "description": "Claude API key",
        "source": "secrets"
      },
      {
        "name": "CLAUDE_MODEL",
        "description": "Default Claude model",
        "default": "claude-sonnet-4-20250514"
      },
      {
        "name": "ASSISTANT_SERVICE_PORT",
        "default": "4005"
      },
      {
        "name": "RAG_SERVICE_PORT",
        "default": "4006"
      },
      {
        "name": "PHONE_AGENT_SERVICE_PORT",
        "default": "4007"
      },
      {
        "name": "QDRANT_HOST",
        "default": "localhost"
      },
      {
        "name": "QDRANT_PORT",
        "default": "6333"
      },
      {
        "name": "JINA_API_KEY",
        "description": "Jina embeddings API key",
        "source": "secrets"
      },
      {
        "name": "TWILIO_ACCOUNT_SID",
        "source": "secrets"
      },
      {
        "name": "TWILIO_AUTH_TOKEN",
        "source": "secrets"
      },
      {
        "name": "TWILIO_PHONE_NUMBER",
        "description": "Dedicated phone number for SMS"
      },
      {
        "name": "REDIS_URL",
        "default": "redis://localhost:6379"
      }
    ]
  },
  "graphMetadata": {
    "inEdges": ["urn:luhtech:ectropy:architecture:ai-service-tiers"],
    "outEdges": ["urn:luhtech:ectropy:architecture:voxel-ml-architecture"]
  }
}
