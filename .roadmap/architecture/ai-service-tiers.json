{
  "$schema": "https://luhtech.dev/schemas/architecture-v1.json",
  "$id": "urn:luhtech:ectropy:architecture:ai-service-tiers",
  "schemaVersion": "1.0.0",
  "meta": {
    "title": "AI Service Tiers Architecture",
    "description": "Defines Demo/Standard/Enterprise AI service tier architecture for Ectropy's Seppä assistant",
    "lastUpdated": "2026-01-14T00:00:00Z",
    "author": "Technical Architecture Team",
    "references": [
      ".roadmap/roadmap-business.json#serviceTiers",
      "SEPPA_Claude_Integration_Handoff.md",
      "SEPPA_Technical_Specification_v1"
    ]
  },
  "architecture": {
    "overview": "Three-tier AI service model providing differentiated Claude model access, query limits, and feature capabilities based on subscription level",
    "designPrinciples": [
      "Cost-effective model selection based on task complexity",
      "Graceful degradation when limits exceeded",
      "Clear upgrade path between tiers",
      "Multi-tenant isolation at every tier"
    ],
    "modelStrategy": {
      "haiku": "High-volume, simple queries - Demo tier default",
      "sonnet": "Complex reasoning, tool orchestration - Standard/Enterprise default",
      "opus": "Multi-step analysis, report generation - Enterprise option"
    }
  },
  "components": [
    {
      "id": "model-router",
      "name": "AI Model Router",
      "description": "Selects appropriate Claude model based on tier, query complexity, and cost optimization",
      "responsibilities": [
        "Tier-based model selection",
        "Query complexity analysis",
        "Fallback to lower-cost models when appropriate",
        "Token budget management"
      ],
      "implementation": {
        "location": "apps/mcp-server/src/services/assistant/claude-client.ts",
        "pattern": "Strategy pattern with tier-based model selection"
      }
    },
    {
      "id": "rate-limiter",
      "name": "Rate Limiter",
      "description": "Enforces query limits per tier with Redis-backed counters",
      "responsibilities": [
        "Per-user query counting",
        "Monthly reset cycles",
        "Overage tracking for billing",
        "Graceful limit enforcement"
      ],
      "implementation": {
        "location": "apps/api-gateway/src/middleware/rate-limiter.ts",
        "storage": "Redis",
        "pattern": "Sliding window counter"
      }
    },
    {
      "id": "tool-access-controller",
      "name": "Tool Access Controller",
      "description": "Controls which PM decision tools are available based on tier",
      "responsibilities": [
        "Tool whitelist per tier",
        "Authority level enforcement",
        "Audit logging of tool execution",
        "Feature flag integration"
      ],
      "implementation": {
        "location": "apps/mcp-server/src/services/assistant/tool-registry.ts",
        "pattern": "Decorator pattern with tier checks"
      }
    },
    {
      "id": "prompt-customizer",
      "name": "Prompt Customizer",
      "description": "Enables custom system prompts for Enterprise tier",
      "responsibilities": [
        "Base prompt generation",
        "Custom prompt injection (Enterprise only)",
        "Prompt versioning and A/B testing",
        "Safety guardrail enforcement"
      ],
      "implementation": {
        "location": "apps/mcp-server/src/services/assistant/system-prompt.ts",
        "pattern": "Template method with tier-based customization"
      }
    }
  ],
  "interfaces": [
    {
      "id": "tier-config-interface",
      "name": "TierConfiguration",
      "type": "typescript",
      "definition": {
        "tierLevel": "demo | standard | enterprise",
        "models": {
          "primary": "string",
          "fallback": "string | null",
          "premium": "string | null"
        },
        "limits": {
          "queriesPerMonth": "number | 'unlimited'",
          "maxTokensPerQuery": "number",
          "concurrentRequests": "number"
        },
        "features": {
          "toolExecution": "boolean",
          "customPrompts": "boolean",
          "ragAccess": "boolean",
          "phoneAgent": "boolean | 'sms-only' | 'full'"
        }
      }
    },
    {
      "id": "usage-metrics-interface",
      "name": "UsageMetrics",
      "type": "typescript",
      "definition": {
        "userId": "string",
        "tenantId": "string",
        "tier": "string",
        "period": {
          "start": "ISO8601",
          "end": "ISO8601"
        },
        "queries": {
          "total": "number",
          "byModel": {
            "haiku": "number",
            "sonnet": "number",
            "opus": "number"
          }
        },
        "tokens": {
          "input": "number",
          "output": "number",
          "estimatedCost": "number"
        },
        "toolCalls": {
          "total": "number",
          "byTool": "Record<string, number>"
        }
      }
    }
  ],
  "dataFlows": [
    {
      "id": "query-routing-flow",
      "name": "Query Routing Flow",
      "description": "How queries are routed to appropriate Claude model based on tier",
      "steps": [
        {
          "step": 1,
          "action": "User sends query via chat interface",
          "component": "Frontend MCPChatPanel"
        },
        {
          "step": 2,
          "action": "API Gateway validates auth and extracts tenant/tier info",
          "component": "api-gateway"
        },
        {
          "step": 3,
          "action": "Rate limiter checks query count against tier limits",
          "component": "rate-limiter"
        },
        {
          "step": 4,
          "action": "Model router selects appropriate Claude model",
          "component": "model-router"
        },
        {
          "step": 5,
          "action": "Tool access controller filters available tools",
          "component": "tool-access-controller"
        },
        {
          "step": 6,
          "action": "Claude API called with tier-appropriate configuration",
          "component": "claude-client"
        },
        {
          "step": 7,
          "action": "Usage metrics recorded for billing",
          "component": "usage-metrics-service"
        }
      ]
    }
  ],
  "tiers": {
    "demo": {
      "name": "Demo/Free",
      "target": "Evaluation users",
      "claude": {
        "primaryModel": "claude-haiku-4-5-20251001",
        "fallbackModel": null,
        "premiumModel": null,
        "maxTokensPerQuery": 2048,
        "systemPromptCustomization": false
      },
      "queryLimits": {
        "perMonth": 100,
        "perDay": 10,
        "concurrent": 1,
        "overagePolicy": "hard-block"
      },
      "rateLimiting": {
        "requestsPerMinute": 5,
        "tokensPerMinute": 10000,
        "burstAllowance": 2
      },
      "toolExecution": {
        "enabled": false,
        "allowedTools": [],
        "maxToolCallsPerQuery": 0,
        "reason": "Demo tier is view-only, no state modifications"
      },
      "ragAccess": {
        "enabled": true,
        "maxDocuments": 10,
        "customCorpus": false,
        "maxChunksPerQuery": 5
      },
      "phoneAgent": {
        "smsInbound": false,
        "smsOutbound": false,
        "voice": false
      },
      "decisionLifecycle": {
        "viewDecisions": true,
        "createDecisions": false,
        "approveReject": false,
        "bulkOperations": false,
        "apiAccess": false
      }
    },
    "standard": {
      "name": "Standard",
      "target": "SMB contractors",
      "claude": {
        "primaryModel": "claude-sonnet-4-20250514",
        "fallbackModel": "claude-haiku-4-5-20251001",
        "premiumModel": null,
        "maxTokensPerQuery": 4096,
        "systemPromptCustomization": false
      },
      "queryLimits": {
        "perMonth": "unlimited",
        "perDay": "unlimited",
        "concurrent": 5,
        "overagePolicy": "not-applicable"
      },
      "rateLimiting": {
        "requestsPerMinute": 30,
        "tokensPerMinute": 100000,
        "burstAllowance": 10
      },
      "toolExecution": {
        "enabled": true,
        "allowedTools": [
          "capture_decision",
          "route_decision",
          "approve_decision",
          "reject_decision",
          "escalate_decision",
          "query_decision_history",
          "get_authority_graph",
          "find_decision_authority",
          "validate_authority_level",
          "attach_decision_to_voxel",
          "get_voxel_decisions",
          "navigate_decision_surface",
          "apply_tolerance_override",
          "query_tolerance_overrides",
          "track_consequence",
          "request_inspection",
          "complete_inspection",
          "query_voxels_by_status",
          "link_consequence_to_decision",
          "query_consequences_by_voxel",
          "propose_schedule_change",
          "get_project_info",
          "get_user_context",
          "list_available_tools"
        ],
        "maxToolCallsPerQuery": 10,
        "bulkOperations": false
      },
      "ragAccess": {
        "enabled": true,
        "maxDocuments": "unlimited",
        "customCorpus": false,
        "maxChunksPerQuery": 15
      },
      "phoneAgent": {
        "smsInbound": true,
        "smsOutbound": true,
        "voice": false
      },
      "decisionLifecycle": {
        "viewDecisions": true,
        "createDecisions": true,
        "approveReject": true,
        "bulkOperations": false,
        "apiAccess": false
      }
    },
    "enterprise": {
      "name": "Enterprise",
      "target": "GCs, Owners",
      "claude": {
        "primaryModel": "claude-sonnet-4-20250514",
        "fallbackModel": "claude-haiku-4-5-20251001",
        "premiumModel": "claude-opus-4-5-20251101",
        "maxTokensPerQuery": 8192,
        "systemPromptCustomization": true,
        "customPromptStorage": "tenant-isolated-s3-bucket"
      },
      "queryLimits": {
        "perMonth": "unlimited",
        "perDay": "unlimited",
        "concurrent": 20,
        "overagePolicy": "not-applicable"
      },
      "rateLimiting": {
        "requestsPerMinute": 100,
        "tokensPerMinute": 500000,
        "burstAllowance": 30
      },
      "toolExecution": {
        "enabled": true,
        "allowedTools": "all",
        "maxToolCallsPerQuery": 25,
        "bulkOperations": true,
        "customTools": true,
        "apiAccess": true
      },
      "ragAccess": {
        "enabled": true,
        "maxDocuments": "unlimited",
        "customCorpus": true,
        "maxChunksPerQuery": 30,
        "privateVectorCollection": true
      },
      "phoneAgent": {
        "smsInbound": true,
        "smsOutbound": true,
        "voice": true,
        "customGreetings": true,
        "dedicatedNumbers": true
      },
      "decisionLifecycle": {
        "viewDecisions": true,
        "createDecisions": true,
        "approveReject": true,
        "bulkOperations": true,
        "apiAccess": true,
        "webhooks": true
      }
    }
  },
  "costModel": {
    "claudeApi": {
      "haiku": {
        "inputPer1MTokens": 0.25,
        "outputPer1MTokens": 1.25,
        "note": "Cost-optimized for high-volume simple queries"
      },
      "sonnet": {
        "inputPer1MTokens": 3.0,
        "outputPer1MTokens": 15.0,
        "note": "Primary model for tool orchestration"
      },
      "opus": {
        "inputPer1MTokens": 15.0,
        "outputPer1MTokens": 75.0,
        "note": "Enterprise-only for complex analysis"
      }
    },
    "estimatedCostPerQuery": {
      "demo": {
        "avgTokens": 1500,
        "model": "haiku",
        "estimatedCost": 0.002
      },
      "standard": {
        "avgTokens": 3000,
        "model": "sonnet",
        "estimatedCost": 0.054
      },
      "enterprise": {
        "avgTokens": 5000,
        "model": "sonnet",
        "estimatedCost": 0.09,
        "opusQueries": {
          "avgTokens": 8000,
          "estimatedCost": 0.72
        }
      }
    }
  },
  "multiTenantIsolation": {
    "strategy": "namespace-prefixed-isolation",
    "components": {
      "conversations": "tenant_id prefix on all conversation records",
      "vectorDb": "per-tenant Qdrant collections for Enterprise",
      "customPrompts": "S3 bucket with tenant-scoped prefixes",
      "usageMetrics": "partitioned by tenant_id with row-level security"
    },
    "dataResidency": {
      "default": "us-east-1",
      "enterpriseOptions": ["us-west-2", "eu-west-1", "ca-central-1"]
    }
  },
  "graphMetadata": {
    "inEdges": ["urn:luhtech:ectropy:file:roadmap-business"],
    "outEdges": [
      "urn:luhtech:ectropy:architecture:mcp-seppa-backend",
      "urn:luhtech:ectropy:architecture:voxel-ml-architecture"
    ]
  }
}
