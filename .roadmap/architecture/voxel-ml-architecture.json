{
  "$schema": "https://luhtech.dev/schemas/architecture-v1.json",
  "$id": "urn:luhtech:ectropy:architecture:voxel-ml-architecture",
  "schemaVersion": "1.0.0",
  "meta": {
    "title": "Voxel Decision Surface + ML Forecasting Architecture",
    "description": "Architecture for voxel-based spatial decision containers, 7-tier authority cascade, and XGBoost cost forecasting integration",
    "lastUpdated": "2026-01-14T00:00:00Z",
    "author": "Technical Architecture Team",
    "references": [
      "ECTROPY_PM_SCHEMA_DESIGN_V3.md",
      "Ectropy_Voxel_SEPPA_Technical_Guide",
      "LUHTECH_VENTURE_SCHEMA_SYSTEM_TECHNICAL_SUMMARY.md"
    ]
  },
  "architecture": {
    "overview": "Voxels serve as 3D spatial containers that attach PM decisions to specific physical locations in the construction model, enabling spatial decision tracking and ML-powered cost forecasting",
    "designPrinciples": [
      "Every decision has a spatial anchor (voxel)",
      "Authority flows automatically based on impact thresholds",
      "ML predictions improve with project data (network effects)",
      "Consequence chains are spatially traceable"
    ],
    "coreInnovation": "Proactive decision attachment via voxel decision surfaces - NO competitor has this capability"
  },
  "components": [
    {
      "id": "voxel-container",
      "name": "Voxel Container",
      "description": "3D spatial container for decisions using octree-based spatial indexing",
      "concept": {
        "definition": "A voxel is a discrete 3D grid cell (typically 10-40mm resolution) that serves as a spatial anchor for construction decisions, consequences, and inspections",
        "properties": [
          "Unique spatial identifier (VOX-{level}-{system}-{index})",
          "Coordinates (x, y, z) in project coordinate system",
          "Building/level/zone hierarchy",
          "System classification (MECH, ELEC, PLUMB, STRUCT, etc.)",
          "Material classification from IFC entity"
        ]
      },
      "spatialIndexing": {
        "algorithm": "Octree",
        "resolution": {
          "coarse": "100mm (overview/aggregation)",
          "standard": "40mm (decision attachment)",
          "fine": "10mm (precision inspection)"
        },
        "benefits": [
          "O(log n) spatial queries",
          "Hierarchical aggregation",
          "Efficient neighbor lookup",
          "GPU-accelerated operations"
        ]
      },
      "schema": {
        "$id": "urn:luhtech:{project}:voxel:{voxelId}",
        "pattern": "VOX-[A-Z0-9-]+",
        "example": "VOX-L2-MECH-047"
      }
    },
    {
      "id": "decision-surface",
      "name": "Decision Surface",
      "description": "The graph of decisions attached to voxels, enabling spatial navigation and impact analysis",
      "concept": {
        "definition": "A queryable surface of decisions overlaid on the BIM model, allowing users to see decision density, consequence chains, and authority routing at any spatial location"
      },
      "capabilities": [
        "Heat map visualization of decision density",
        "Consequence chain traversal",
        "Authority flow visualization",
        "Temporal decision evolution",
        "Impact radius calculation"
      ],
      "navigation": {
        "algorithm": "BFS (Breadth-First Search)",
        "tool": "navigate_decision_surface",
        "traversalTypes": [
          "spatial (adjacent voxels)",
          "causal (consequence chains)",
          "temporal (decision timeline)",
          "authority (escalation path)"
        ]
      }
    },
    {
      "id": "authority-cascade",
      "name": "Authority Cascade",
      "description": "7-tier escalation system that automatically routes decisions based on budget and schedule impact",
      "levels": [
        {
          "level": 0,
          "name": "FIELD",
          "title": "Field Worker",
          "budgetLimit": 0,
          "budgetLimitCAD": 0,
          "varianceTolerance": "0\"",
          "scheduleAuthority": "0 days",
          "autoApprove": true,
          "description": "Observation and reporting only, no approval authority"
        },
        {
          "level": 1,
          "name": "FOREMAN",
          "title": "Foreman",
          "budgetLimit": 500,
          "budgetLimitCAD": 750,
          "varianceTolerance": "1/8\"",
          "scheduleAuthority": "4 hours",
          "autoApprove": false,
          "description": "Minor field decisions within tolerance"
        },
        {
          "level": 2,
          "name": "SUPERINTENDENT",
          "title": "Superintendent",
          "budgetLimit": 5000,
          "budgetLimitCAD": 7500,
          "varianceTolerance": "1/4\"",
          "scheduleAuthority": "1 day",
          "autoApprove": false,
          "description": "Day-to-day construction decisions"
        },
        {
          "level": 3,
          "name": "PM",
          "title": "Project Manager",
          "budgetLimit": 50000,
          "budgetLimitCAD": 37500,
          "varianceTolerance": "1/2\"",
          "scheduleAuthority": "1 week",
          "autoApprove": false,
          "description": "Project-level decisions affecting schedule/budget"
        },
        {
          "level": 4,
          "name": "ARCHITECT",
          "title": "Architect/Engineer",
          "budgetLimit": "design",
          "budgetLimitCAD": "design",
          "varianceTolerance": "visible",
          "scheduleAuthority": "2 weeks",
          "autoApprove": false,
          "description": "Design decisions, structural changes, visible elements"
        },
        {
          "level": 5,
          "name": "OWNER",
          "title": "Owner/Executive",
          "budgetLimit": "project",
          "budgetLimitCAD": 150000,
          "varianceTolerance": "major",
          "scheduleAuthority": "1 month",
          "autoApprove": false,
          "description": "Major project decisions, scope changes"
        },
        {
          "level": 6,
          "name": "REGULATORY",
          "title": "Regulatory/Code",
          "budgetLimit": "code",
          "budgetLimitCAD": "unlimited",
          "varianceTolerance": "safety",
          "scheduleAuthority": "any",
          "autoApprove": false,
          "description": "Permit requirements, code compliance, safety issues"
        }
      ],
      "routing": {
        "algorithm": "Impact-based threshold matching",
        "factors": [
          {
            "name": "budgetImpact",
            "weight": 0.4,
            "description": "Estimated cost of decision"
          },
          {
            "name": "scheduleImpact",
            "weight": 0.3,
            "description": "Days of delay caused"
          },
          {
            "name": "varianceAmount",
            "weight": 0.15,
            "description": "Physical deviation from spec"
          },
          {
            "name": "safetyFlag",
            "weight": 0.15,
            "description": "Safety-related automatically escalates to Level 6"
          }
        ],
        "escalationTriggers": [
          "Budget exceeds authority limit",
          "Schedule exceeds authority limit",
          "Variance exceeds tolerance",
          "Safety concern flagged",
          "Multiple affected systems",
          "Previous similar decision rejected"
        ]
      }
    },
    {
      "id": "ml-forecaster",
      "name": "ML Cost Forecaster",
      "description": "XGBoost-based cost prediction using voxel features and historical data",
      "model": {
        "algorithm": "XGBoost with LightGBM ensemble",
        "features": {
          "voxelFeatures": [
            "material_type",
            "ifc_entity",
            "volume_m3",
            "surface_area_m2",
            "complexity_score",
            "trade_code",
            "assembly_type"
          ],
          "spatialFeatures": [
            "floor_level",
            "zone_type",
            "accessibility_score",
            "adjacent_systems_count",
            "distance_to_core"
          ],
          "temporalFeatures": [
            "installation_sequence",
            "predecessor_completion",
            "weather_risk_window"
          ],
          "historicalFeatures": [
            "similar_project_costs",
            "regional_labor_rates",
            "material_price_index"
          ]
        },
        "outputs": [
          {
            "name": "estimated_cost",
            "type": "regression",
            "confidence": "95% CI"
          },
          {
            "name": "cost_drivers",
            "type": "SHAP values",
            "description": "Explainable contribution of each feature"
          },
          {
            "name": "risk_score",
            "type": "classification",
            "classes": ["low", "medium", "high"]
          }
        ]
      },
      "accuracy": {
        "phase1_mvp": "±30% (AACE Class 3)",
        "phase2_production": "90%+ (AACE Class 2)",
        "phase3_advanced": "95%+ (AACE Class 1)"
      },
      "training": {
        "dataRequirements": "100+ completed projects",
        "features": "50+ per voxel",
        "updateFrequency": "Weekly retraining with new project data"
      }
    },
    {
      "id": "consequence-tracker",
      "name": "Consequence Tracker",
      "description": "Tracks downstream effects of decisions with spatial attribution",
      "categories": [
        "SCHEDULE_DELAY",
        "COST_INCREASE",
        "SAFETY_RISK",
        "QUALITY_IMPACT",
        "SCOPE_CHANGE",
        "REWORK_REQUIRED",
        "RESOURCE_CONFLICT",
        "PERMIT_REQUIRED",
        "DESIGN_CHANGE",
        "WARRANTY_IMPACT"
      ],
      "tracking": {
        "sourceDecision": "URN of originating decision",
        "affectedVoxels": "Array of voxel URNs impacted",
        "impactMagnitude": "Quantified effect (cost, days, etc.)",
        "probability": "Likelihood of occurrence (0-1)",
        "timeframe": "When consequence expected to manifest"
      },
      "forecasting": {
        "algorithm": "Monte Carlo simulation",
        "iterations": 1000,
        "outputs": [
          "P50/P80/P95 cost scenarios",
          "Schedule risk profile",
          "Critical path impact probability"
        ]
      }
    },
    {
      "id": "inspection-validator",
      "name": "Inspection Validator",
      "description": "Links inspections to voxels and validates decisions",
      "types": [
        "ROUGH_IN",
        "COVER_UP",
        "FINAL",
        "SAFETY",
        "QUALITY",
        "SPECIAL",
        "REGULATORY"
      ],
      "workflow": [
        "Schedule inspection for voxel(s)",
        "Inspector arrives, captures evidence (photos, measurements)",
        "Result recorded (PASSED, FAILED, CONDITIONAL)",
        "Linked decisions validated or flagged",
        "Consequence created if failed"
      ],
      "evidence": {
        "types": ["photo", "document", "voice-note", "video", "measurement"],
        "storage": "S3 with tenant-prefixed paths",
        "linking": "URN reference to decision and voxel"
      }
    }
  ],
  "interfaces": [
    {
      "id": "voxel-interface",
      "name": "Voxel",
      "type": "typescript",
      "definition": {
        "$id": "string (URN)",
        "voxelId": "string (VOX-{level}-{system}-{index})",
        "projectId": "string",
        "coordinates": {
          "x": "number",
          "y": "number",
          "z": "number"
        },
        "hierarchy": {
          "building": "string",
          "level": "string",
          "zone": "string",
          "system": "string"
        },
        "properties": {
          "materialType": "string",
          "ifcEntity": "string",
          "volume": "number",
          "surfaceArea": "number",
          "complexityScore": "number"
        },
        "status": "PLANNED | IN_PROGRESS | COMPLETE | BLOCKED | INSPECTION_REQUIRED",
        "decisions": "string[] (URN references)",
        "consequences": "string[] (URN references)",
        "graphMetadata": {
          "inEdges": "string[]",
          "outEdges": "string[]"
        }
      }
    },
    {
      "id": "pm-decision-interface",
      "name": "PMDecision",
      "type": "typescript",
      "definition": {
        "$id": "string (URN)",
        "$schema": "string",
        "schemaVersion": "string",
        "type": "APPROVAL | REJECTION | DEFERRAL | ESCALATION | PROPOSAL | CONSEQUENCE",
        "status": "PENDING | APPROVED | REJECTED | SUPERSEDED | EXPIRED",
        "title": "string",
        "description": "string",
        "voxelRef": "string (URN)",
        "voxelContext": {
          "voxelId": "string",
          "coordinates": "object",
          "building": "string",
          "level": "string",
          "zone": "string"
        },
        "authority": {
          "requiredLevel": "number (0-6)",
          "requiredName": "string",
          "approvedByLevel": "number | null",
          "approvedByRef": "string | null"
        },
        "budgetImpact": {
          "estimated": "number",
          "actual": "number | null",
          "currency": "string",
          "variance": "number | null"
        },
        "scheduleImpact": {
          "delayDays": "number",
          "affectedMilestones": "string[]",
          "criticalPath": "boolean"
        },
        "participants": {
          "requestedBy": "string (URN)",
          "approvedBy": "string | null",
          "rejectedBy": "string | null",
          "escalatedTo": "string | null"
        },
        "evidence": "array",
        "consequences": "string[] (URN references)",
        "relatedDecisions": "string[] (URN references)",
        "timestamps": {
          "created": "ISO8601",
          "updated": "ISO8601",
          "resolved": "ISO8601 | null"
        },
        "graphMetadata": {
          "inEdges": "string[]",
          "outEdges": "string[]"
        }
      }
    },
    {
      "id": "authority-thresholds-interface",
      "name": "AuthorityThresholds",
      "type": "typescript",
      "definition": {
        "level": "number (0-6)",
        "name": "FIELD | FOREMAN | SUPERINTENDENT | PM | ARCHITECT | OWNER | REGULATORY",
        "title": "string",
        "budgetLimit": "number | 'design' | 'project' | 'code'",
        "budgetLimitCAD": "number | 'design' | 'project' | 'unlimited'",
        "varianceTolerance": "string",
        "scheduleAuthority": "string",
        "autoApprove": "boolean",
        "graphMetadata": {
          "inEdges": "string[]",
          "outEdges": "string[]"
        }
      }
    },
    {
      "id": "cost-forecast-interface",
      "name": "CostForecast",
      "type": "typescript",
      "definition": {
        "voxelId": "string",
        "estimatedCost": {
          "value": "number",
          "currency": "string",
          "confidence": "number (0-1)",
          "range": {
            "low": "number",
            "high": "number"
          }
        },
        "costDrivers": [
          {
            "feature": "string",
            "contribution": "number",
            "direction": "positive | negative"
          }
        ],
        "riskScore": "low | medium | high",
        "modelVersion": "string",
        "generatedAt": "ISO8601"
      }
    }
  ],
  "dataFlows": [
    {
      "id": "decision-capture-flow",
      "name": "Decision Capture Flow",
      "description": "How a decision is captured, validated, and routed through authority cascade",
      "steps": [
        {
          "step": 1,
          "action": "User identifies location in BIM viewer",
          "component": "BIM Viewer"
        },
        {
          "step": 2,
          "action": "Voxel selected (single or group)",
          "component": "Voxel Selector"
        },
        {
          "step": 3,
          "action": "Decision captured via Seppä (web/SMS/voice)",
          "component": "assistant-service"
        },
        {
          "step": 4,
          "action": "capture_decision tool creates decision record",
          "component": "PM Decision Tools"
        },
        {
          "step": 5,
          "action": "find_decision_authority calculates required level",
          "component": "Authority Service"
        },
        {
          "step": 6,
          "action": "Decision attached to voxel(s)",
          "component": "Voxel Service"
        },
        {
          "step": 7,
          "action": "route_decision sends to appropriate authority",
          "component": "Routing Service"
        },
        {
          "step": 8,
          "action": "Notification sent to approver",
          "component": "Notification Service"
        },
        {
          "step": 9,
          "action": "Decision surface updated",
          "component": "Decision Surface"
        }
      ]
    },
    {
      "id": "ml-forecast-flow",
      "name": "ML Cost Forecast Flow",
      "description": "How cost estimates are generated using ML",
      "steps": [
        {
          "step": 1,
          "action": "IFC model uploaded",
          "component": "Upload Service"
        },
        {
          "step": 2,
          "action": "WebAssembly IFC parser extracts geometry",
          "component": "IFC Parser"
        },
        {
          "step": 3,
          "action": "GPU-accelerated voxelization (10-40mm)",
          "component": "Voxelizer"
        },
        {
          "step": 4,
          "action": "Material classification from IFC entities",
          "component": "Classifier"
        },
        {
          "step": 5,
          "action": "Feature extraction (50+ features per voxel)",
          "component": "Feature Extractor"
        },
        {
          "step": 6,
          "action": "XGBoost prediction with historical data",
          "component": "ML Predictor"
        },
        {
          "step": 7,
          "action": "SHAP explainability for cost drivers",
          "component": "SHAP Explainer"
        },
        {
          "step": 8,
          "action": "Hierarchical aggregation (Voxel → Assembly → System → Project)",
          "component": "Aggregator"
        },
        {
          "step": 9,
          "action": "Results displayed in dashboard",
          "component": "Admin Dashboard"
        }
      ]
    },
    {
      "id": "consequence-tracking-flow",
      "name": "Consequence Tracking Flow",
      "description": "How consequences are tracked and traced to source decisions",
      "steps": [
        {
          "step": 1,
          "action": "Issue identified in field",
          "component": "Field observation"
        },
        {
          "step": 2,
          "action": "track_consequence tool creates record",
          "component": "Consequence Tracker"
        },
        {
          "step": 3,
          "action": "Consequence linked to source decision(s)",
          "component": "Decision Graph"
        },
        {
          "step": 4,
          "action": "Affected voxels identified and tagged",
          "component": "Voxel Service"
        },
        {
          "step": 5,
          "action": "Impact magnitude quantified",
          "component": "Impact Calculator"
        },
        {
          "step": 6,
          "action": "Monte Carlo simulation forecasts scenarios",
          "component": "Forecaster"
        },
        {
          "step": 7,
          "action": "Decision surface updated with consequence overlay",
          "component": "Decision Surface"
        },
        {
          "step": 8,
          "action": "Stakeholders notified of impact",
          "component": "Notification Service"
        }
      ]
    }
  ],
  "seppaPipeline": {
    "description": "SEPPA: Spatial Element Processing Prediction Aggregation - the five-stage voxel intelligence pipeline",
    "stages": [
      {
        "letter": "S",
        "name": "Spatial",
        "function": "GPU-accelerated voxelization of BIM geometry",
        "resolution": "10-40mm",
        "implementation": "apps/voxel-service/src/voxelizer/conservative-rasterizer.ts"
      },
      {
        "letter": "E",
        "name": "Element",
        "function": "Material classification, IFC entity mapping, component identification",
        "implementation": "apps/voxel-service/src/classifiers/"
      },
      {
        "letter": "P",
        "name": "Processing",
        "function": "Enrichment with cost data, complexity scoring, trade assignment",
        "implementation": "apps/voxel-service/src/enrichment/"
      },
      {
        "letter": "P",
        "name": "Prediction",
        "function": "ML-powered cost estimation using XGBoost/LightGBM ensemble",
        "implementation": "apps/voxel-service/src/ml/xgboost-cost-predictor.ts"
      },
      {
        "letter": "A",
        "name": "Aggregation",
        "function": "Hierarchical rollup: Voxel → Assembly → System → Project totals",
        "implementation": "apps/voxel-service/src/aggregation/"
      }
    ]
  },
  "edgeTypes": {
    "description": "PM-specific graph edge types for decision relationships",
    "types": [
      {
        "type": "contains",
        "from": "Voxel",
        "to": "PM-Decision",
        "description": "Decision attached to spatial location"
      },
      {
        "type": "triggers",
        "from": "PM-Decision",
        "to": "Consequence",
        "description": "Decision causes outcome"
      },
      {
        "type": "proposes",
        "from": "PM-Decision",
        "to": "Schedule-Proposal",
        "description": "Decision requests schedule change"
      },
      {
        "type": "escalates-to",
        "from": "PM-Decision",
        "to": "PM-Decision",
        "description": "Authority cascade escalation"
      },
      {
        "type": "validates",
        "from": "Inspection",
        "to": "PM-Decision",
        "description": "Inspection confirms decision"
      },
      {
        "type": "authored-by",
        "from": "PM-Decision",
        "to": "Participant",
        "description": "Decision maker"
      },
      {
        "type": "approved-by",
        "from": "PM-Decision",
        "to": "Participant",
        "description": "Approval authority"
      },
      {
        "type": "affects",
        "from": "Consequence",
        "to": "Voxel",
        "description": "Consequence impacts spatial area"
      }
    ]
  },
  "graphMetadata": {
    "inEdges": [
      "urn:luhtech:ectropy:architecture:ai-service-tiers",
      "urn:luhtech:ectropy:architecture:mcp-seppa-backend"
    ],
    "outEdges": []
  }
}
