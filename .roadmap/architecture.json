        "project_documents",
        "decision_history",
        "voxel_metadata",
        "conversation_logs",
        "safety_protocols"
      ]
    },
    {
      "serviceId": "phone-agent-service",
      "$id": "urn:luhtech:ectropy:service:phone-agent-service",
      "name": "Phone Agent Service",
      "description": "Zero-friction data collection via SMS/voice using Twilio + Claude",
      "port": 4007,
      "technology": "Node.js + Express + TypeScript + Twilio SDK",
      "deliverableId": "p5b-d24",
      "priority": "critical",
      "status": "planned",
      "targetDate": "2026-03-15",
      "feature": "seppa-agent",
      "dependencies": ["assistant-service", "rag-service", "postgresql"],
      "interfaces": {
        "smsWebhook": "POST /api/phone/v1/webhooks/twilio/sms",
        "voiceWebhook": "POST /api/phone/v1/webhooks/twilio/voice",
        "sendSms": "POST /api/phone/v1/send",
        "conversationStatus": "GET /api/phone/v1/conversations/:sessionId"
      },
      "stateMachine": {
        "states": [
          "IDLE",
          "IDENTIFY_USER",
          "CLASSIFY_INTENT",
          "EXTRACT_ENTITIES",
          "COLLECT_DATA",
          "VALIDATE",
          "CONFIRM",
          "EXECUTE",
          "RESPOND",
          "ERROR",
          "ESCALATE"
        ]
      }
    },
    {
      "serviceId": "subdomain-provisioner",
      "name": "job.site Subdomain System",
      "description": "Multi-tenant subdomain provisioning with DNS automation and SSL",
      "port": 4003,
      "technology": "Node.js + Terraform + Cloudflare API",
      "deliverableId": "p5b-d11",
      "priority": "high",
      "status": "planned",
      "dependencies": ["api-gateway", "postgresql", "nginx"]
    },
    {
      "serviceId": "contract-parser-service",
