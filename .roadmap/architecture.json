      "supportedContractTypes": [
        "AIA C191",
        "AIA A133",
        "AIA A101",
        "CCDC 2",
        "CCDC 5B",
        "ConsensusDOCS 300"
      ]
    },
    {
      "serviceId": "closeout-service",
      "$id": "urn:luhtech:ectropy:service:closeout-service",
      "name": "Closeout Service",
      "description": "Project closeout workflow management including G704 certificates and IPD final accounting",
      "port": 4009,
