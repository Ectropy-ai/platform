{
  "$schema": "https://luhtech.dev/schemas/agent-prompt.schema.json",
  "$id": "urn:luhtech:ectropy:agent-prompt:prisma-m3-completion",
  "schemaVersion": "1.0.0",
  "meta": {
    "createdAt": "2026-01-23T00:00:00Z",
    "createdBy": "claude",
    "purpose": "Complete Decision Lifecycle M3 Prisma validation and tests, then add Dual-Process Decision Prisma models",
    "targetBranch": "claude/prisma-m3-dp-completion-{SESSION_ID}",
    "estimatedDuration": "2-3 hours",
    "priority": "HIGH"
  },
  "repoSplitConfirmation": {
    "canProceed": true,
    "rationale": "Prisma work can and should proceed before repo split",
    "evidence": [
      {
        "source": ".roadmap/boundaries.json",
        "key": "repositorySplit.publicRepo.includes",
        "value": "prisma/schema.prisma is explicitly included in PUBLIC repo"
      },
      {
        "source": ".roadmap/venture-summary.json",
        "key": "repositorySplit.splitDate",
        "value": "2026-01-17 (already passed - today is 2026-01-23)"
      },
      {
        "source": ".roadmap/boundaries.json",
        "key": "repositorySplit.syncStrategy",
        "value": "public → private sync means Prisma changes flow to both repos"
      }
    ],
    "conclusion": "All Prisma work will automatically propagate to both public (ectropy-ai/ectropy) and private (luh-tech/Ectropy-Business) repos via the configured sync strategy"
  },
  "taskOverview": {
    "phase1": {
      "name": "Complete Decision Lifecycle M3",
      "milestone": "M3",
      "feature": "decision-lifecycle",
      "targetDate": "2026-01-31",
      "currentStatus": {
        "schemaComplete": true,
        "migrationComplete": true,
        "seedDataComplete": true,
        "validationPending": true,
        "testsPending": true
      },
      "remainingWork": [
        "Run prisma validate to ensure schema is valid",
        "Run prisma generate to generate Prisma client",
        "Create comprehensive test suite for M3 models",
        "Verify seed data runs successfully",
        "Update FEATURE.json with completion evidence"
      ]
    },
    "phase2": {
      "name": "Add Dual-Process Decision Prisma Models",
      "milestone": "DP-M1",
      "feature": "dual-process-decision",
      "targetDate": "2026-02-05",
      "dependsOn": "M3 completion",
      "newModels": [
        {
          "name": "DecisionEvent",
          "description": "Full decision event capture for dual-process architecture",
          "sourceSchema": ".roadmap/schemas/decision/decision-event.schema.json",
          "urnPattern": "urn:luhtech:{project}:decision-event:DEV-{YYYY}-{NNNN}"
        },
        {
          "name": "SuccessPattern",
          "description": "Compressed validated decision pattern for Success Stack",
          "sourceSchema": ".roadmap/schemas/decision/success-pattern.schema.json",
          "urnPattern": "urn:luhtech:{project}:success-pattern:PAT-{YYYY}-{NNNN}"
        },
        {
          "name": "SDISnapshot",
          "description": "Solution Density Index calculation snapshot",
          "sourceSchema": ".roadmap/schemas/decision/sdi-snapshot.schema.json",
          "urnPattern": "urn:luhtech:{project}:sdi-snapshot:SDI-{YYYY}-{NNNN}"
        }
      ],
      "newEnums": [
        "MediationStrategy",
        "SDIClassification",
        "EngineType",
        "PatternValidationStatus"
      ]
    }
  },
  "agentPrompt": {
    "title": "Prisma M3 Completion & Dual-Process Decision Foundation",
    "instructions": "Complete the Decision Lifecycle M3 milestone by validating and testing the existing Prisma schema, then add the Dual-Process Decision Prisma models for DP-M1.",
    "context": [
      "The Ectropy platform is a construction intelligence system with Decision Lifecycle and USF (Universal Service Factors) features",
      "M3 has schema and migrations complete but needs validation and tests",
      "DP-M1 extends the decision system with Success Stack pattern matching and SDI calculations",
      "All work follows the V3 schema pattern with URN identifiers and graphMetadata",
      "Repo uses JSON-only documentation pattern - no markdown files in .roadmap"
    ],
    "steps": [
      {
        "step": 1,
        "action": "Validate existing M3 Prisma schema",
        "commands": [
          "cd /home/user/Ectropy",
          "pnpm exec prisma validate",
          "pnpm exec prisma generate"
        ],
        "expectedOutput": "Schema validates successfully, Prisma client generated",
        "onFailure": "Fix any schema validation errors before proceeding"
      },
      {
        "step": 2,
        "action": "Review existing M3 models",
        "files": [
          "prisma/schema.prisma (lines 326-1079 for M3 models)",
          "prisma/migrations/20260108001000_m3_decision_lifecycle/migration.sql",
          "prisma/seed-decision-lifecycle.ts"
        ],
        "verify": [
          "12 M3 models exist: AuthorityLevel, Participant, Voxel, PMDecision, VoxelDecisionAttachment, ToleranceOverride, PreApproval, VoxelAlert, Acknowledgment, Consequence, ScheduleProposal, Inspection",
          "16 enums for decision lifecycle",
          "All relations correctly defined",
          "URN indexes on all entity tables"
        ]
      },
      {
        "step": 3,
        "action": "Create M3 Prisma test suite",
        "createFile": "prisma/__tests__/m3-decision-lifecycle.spec.ts",
        "testCases": [
          "Authority level CRUD operations",
          "Participant creation with authority level relation",
          "Voxel creation with spatial data",
          "PMDecision full lifecycle (create, escalate, approve)",
          "VoxelDecisionAttachment creation",
          "ToleranceOverride creation and validation",
          "Consequence tracking from decisions",
          "Inspection with decision validation",
          "Acknowledgment recording",
          "Graph traversal queries via URN references"
        ],
        "pattern": "Follow existing test patterns in apps/mcp-server/src/services/__tests__/"
      },
      {
        "step": 4,
        "action": "Run seed data",
        "command": "pnpm exec ts-node prisma/seed-decision-lifecycle.ts",
        "verify": [
          "7 authority levels seeded",
          "No errors during seed execution"
        ]
      },
      {
        "step": 5,
        "action": "Add Dual-Process Decision Prisma models",
        "editFile": "prisma/schema.prisma",
        "addModels": {
          "enums": [
            {
              "name": "MediationStrategy",
              "values": ["CRISIS_OVERRIDE", "HIGH_CONFIDENCE", "EXPLORATION_GUIDED", "NO_PATTERNS", "BLENDED"]
            },
            {
              "name": "SDIClassification",
              "values": ["CRITICAL", "WARNING", "HEALTHY", "ABUNDANT"]
            },
            {
              "name": "EngineType",
              "values": ["SUCCESS_STACK", "POSSIBILITY_SPACE"]
            },
            {
              "name": "PatternValidationStatus",
              "values": ["PENDING", "VALIDATED", "REJECTED", "MERGED"]
            }
          ],
          "models": [
            {
              "name": "DecisionEvent",
              "fields": [
                "id UUID @id @default(uuid())",
                "urn String @unique @db.VarChar(200)",
                "project_id UUID",
                "event_id String @db.VarChar(20)",
                "timestamp DateTime @default(now())",
                "actor_id UUID",
                "trigger Json @db.JsonB",
                "state Json @db.JsonB",
                "engine1_output Json @db.JsonB",
                "engine2_output Json? @db.JsonB",
                "mediation Json @db.JsonB",
                "outcome Json? @db.JsonB",
                "sdi_at_decision Decimal? @db.Decimal(10, 4)",
                "graph_metadata Json? @db.JsonB",
                "created_at DateTime @default(now())"
              ],
              "relations": [
                "Project (project_id)",
                "Participant (actor_id)"
              ],
              "indexes": [
                "urn",
                "project_id, timestamp",
                "actor_id"
              ]
            },
            {
              "name": "SuccessPattern",
              "fields": [
                "id UUID @id @default(uuid())",
                "urn String @unique @db.VarChar(200)",
                "pattern_id String @db.VarChar(20)",
                "context_signature Json @db.JsonB",
                "action_type String @db.VarChar(100)",
                "outcome_profile Json @db.JsonB",
                "confidence Decimal @db.Decimal(4, 3)",
                "frequency Int @default(1)",
                "validation_status PatternValidationStatus @default(PENDING)",
                "source_events String[] @default([])",
                "decay_factor Decimal @db.Decimal(4, 3) @default(1.0)",
                "last_success DateTime?",
                "merged_from String[] @default([])",
                "graph_metadata Json? @db.JsonB",
                "created_at DateTime @default(now())",
                "updated_at DateTime @default(now()) @updatedAt"
              ],
              "indexes": [
                "urn",
                "action_type",
                "confidence DESC",
                "validation_status"
              ]
            },
            {
              "name": "SDISnapshot",
              "fields": [
                "id UUID @id @default(uuid())",
                "urn String @unique @db.VarChar(200)",
                "snapshot_id String @db.VarChar(20)",
                "project_id UUID",
                "timestamp DateTime @default(now())",
                "sdi_value Decimal @db.Decimal(15, 4)",
                "classification SDIClassification",
                "components Json @db.JsonB",
                "thresholds Json @db.JsonB",
                "exploration_budget Decimal @db.Decimal(4, 3)",
                "context Json? @db.JsonB",
                "graph_metadata Json? @db.JsonB",
                "created_at DateTime @default(now())"
              ],
              "relations": [
                "Project (project_id)"
              ],
              "indexes": [
                "urn",
                "project_id, timestamp",
                "classification"
              ]
            }
          ]
        },
        "guidelines": [
          "Follow existing M3 model patterns exactly",
          "Use @@map for snake_case table names",
          "Add @map for snake_case column names",
          "Include graph_metadata JSONB field on all entities",
          "Add URN unique constraint and index",
          "Use @db.Timestamptz(6) for all timestamps"
        ]
      },
      {
        "step": 6,
        "action": "Create migration for Dual-Process Decision models",
        "command": "pnpm exec prisma migrate dev --name dp_m1_dual_process_foundation",
        "expectedOutput": "Migration created successfully",
        "migrationPath": "prisma/migrations/20260205_dp_m1_dual_process_foundation/migration.sql"
      },
      {
        "step": 7,
        "action": "Create DP-M1 test suite",
        "createFile": "prisma/__tests__/dp-m1-dual-process.spec.ts",
        "testCases": [
          "DecisionEvent capture with full context",
          "SuccessPattern creation and validation workflow",
          "SDISnapshot calculation storage",
          "Pattern confidence decay",
          "Pattern merging",
          "SDI classification thresholds"
        ]
      },
      {
        "step": 8,
        "action": "Update FEATURE.json files with completion evidence",
        "files": [
          ".roadmap/features/decision-lifecycle/FEATURE.json",
          ".roadmap/features/dual-process-decision/FEATURE.json"
        ],
        "updates": [
          "Set M3 status to COMPLETE with completedAt timestamp",
          "Add test evidence counts",
          "Set DP-M1 progress indicators"
        ]
      },
      {
        "step": 9,
        "action": "Commit and push",
        "commands": [
          "git add .",
          "git commit -m 'feat(prisma): Complete M3 validation + DP-M1 Dual-Process Decision models'",
          "git push -u origin claude/prisma-m3-dp-completion-{SESSION_ID}"
        ]
      }
    ],
    "successCriteria": [
      "prisma validate passes",
      "prisma generate succeeds",
      "M3 test suite passes (minimum 20 tests)",
      "DP-M1 models added to schema",
      "DP-M1 migration created",
      "DP-M1 test suite passes (minimum 10 tests)",
      "Both FEATURE.json files updated",
      "All changes committed and pushed"
    ],
    "rollbackPlan": {
      "onValidationFailure": "Fix schema errors, do not proceed until validate passes",
      "onMigrationFailure": "Delete failed migration, fix schema, regenerate",
      "onTestFailure": "Fix failing tests before committing"
    }
  },
  "referenceFiles": {
    "schemas": [
      ".roadmap/schemas/decision/pm-decision.schema.json",
      ".roadmap/schemas/decision/decision-event.schema.json",
      ".roadmap/schemas/decision/success-pattern.schema.json",
      ".roadmap/schemas/decision/sdi-snapshot.schema.json",
      ".roadmap/schemas/voxel/voxel-v3.schema.json",
      ".roadmap/schemas/consequence/consequence-v3.schema.json",
      ".roadmap/schemas/inspection/inspection.schema.json",
      ".roadmap/schemas/authority/authority-level.schema.json"
    ],
    "features": [
      ".roadmap/features/decision-lifecycle/FEATURE.json",
      ".roadmap/features/decision-lifecycle/graph-architecture.json",
      ".roadmap/features/decision-lifecycle/interfaces.json",
      ".roadmap/features/dual-process-decision/FEATURE.json",
      ".roadmap/features/dual-process-decision/graph-architecture.json",
      ".roadmap/features/dual-process-decision/implementation-plan.json"
    ],
    "prisma": [
      "prisma/schema.prisma",
      "prisma/migrations/20260108001000_m3_decision_lifecycle/migration.sql",
      "prisma/seed-decision-lifecycle.ts"
    ],
    "testPatterns": [
      "apps/mcp-server/src/services/__tests__/pm-decision-tools.spec.ts",
      "apps/mcp-server/src/services/__tests__/pm-decision-tools-m2.spec.ts",
      "apps/mcp-server/src/services/__tests__/usf-decision-lifecycle.spec.ts"
    ]
  },
  "environmentRequirements": {
    "node": ">=20",
    "pnpm": ">=9",
    "database": "PostgreSQL 15+",
    "env": {
      "DATABASE_URL": "Must be set for prisma commands"
    }
  }
}
