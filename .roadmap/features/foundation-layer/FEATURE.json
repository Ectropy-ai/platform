  "meta": {
    "sourceOfTruth": ".roadmap/features/foundation-layer/FEATURE.json",
    "lastUpdated": "2026-01-30T00:00:00Z"
  },
  "description": "Shared infrastructure providing IoT sensor integration, UWB positioning, and commissioning workflows used across all platform services. Single source of truth for common capabilities, preventing code duplication across microservices.",
  "coreInnovation": {
    "before": {
      "iotIntegration": "Fragmented sensor deployments per service",
      "positioning": "No real-time tracking capability",
      "commissioning": "Manual paper-based workflows"
    },
    "after": {
      "iotIntegration": "Unified TimescaleDB architecture with real-time alerting",
      "positioning": "Sub-meter UWB positioning for robot fleet and crew tracking",
      "commissioning": "Automated functional testing with spatial deficiency tagging"
    }
  },
  "value": {
    "sensorDataIngestion": "10,000+ readings per second",
    "positioningAccuracy": "+/-10 cm indoor UWB tracking",
    "turnoverDocumentation": "Automated O&M manual generation",
    "retentionCompliance": "7-year cold storage in S3"
  },
  "milestones": [
    {
      "id": "M1",
      "name": "IoT Sensor Foundation",
      "targetDate": "2026-06-01",
      "status": "NOT_STARTED",
      "description": "Sensor deployment plan schema, TimescaleDB integration, MQTT broker, alert thresholds, Grafana dashboards",
      "deliverables": [
        ".roadmap/schemas/foundation/sensor-plan.schema.json",
        "services/foundation/sensor-management/",
        "MCP tools registration (18 sensor tools)"
      ]
    },
    {
      "id": "M2",
      "name": "UWB Positioning",
      "targetDate": "2026-06-01",
      "status": "NOT_STARTED",
      "description": "UWB anchor grid schema, real-time positioning at 10 Hz, collision detection, geo-fencing",
      "deliverables": [
        "services/foundation/positioning/",
        "MCP tools registration (12 positioning tools)"
      ]
    },
    {
      "id": "M3",
      "name": "Commissioning Workflows",
      "targetDate": "2026-09-01",
      "status": "NOT_STARTED",
      "description": "Commissioning test schema, deficiency tracking with voxel attribution, O&M manual generation, turnover packages",
      "deliverables": [
        "services/foundation/commissioning/",
        "MCP tools registration (18 commissioning tools)"
      ]
    },
    {
      "id": "M4",
      "name": "Shared Package Ecosystem",
      "targetDate": "2026-12-01",
      "status": "NOT_STARTED",
      "description": "@ectropy/types, @ectropy/schemas, @ectropy/validation, @ectropy/spatial packages"
    }
  ],
  "dependencies": {
