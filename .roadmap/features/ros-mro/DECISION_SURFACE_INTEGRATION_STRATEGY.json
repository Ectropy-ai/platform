  "integrationPoints": {
    "dataFlow": {
      "description": "Decision Surface data flow through services",
      "flow": [
        "Decision Created (USF/RFI/CO)",
        "→ DecisionAuthorityCascadeService.calculateRequiredAuthority(impact)",
        "→ DecisionSurfaceService.routeAndAttachDecision()",
        "→ VoxelPersistenceService.persistDecisionSurface()",
        "→ MCP Tools expose to AI agents",
        "→ React Query hooks fetch for frontend",
        "→ ROSMROView displays in decision panel"
      ]
    },
    "serviceIntegration": {
      "VoxelCoordinationService": {
        "role": "Orchestration layer",
        "integrates": ["DecisionSurfaceService", "DecisionAuthorityCascadeService", "VoxelPersistenceService"]
      },
      "DecisionSurfaceService": {
        "role": "Decision management",
        "methods": ["attachDecision", "createToleranceOverride", "createPreApproval", "createAlert", "recordAcknowledgment"]
      },
      "DecisionAuthorityCascadeService": {
        "role": "Authority routing",
        "methods": ["calculateRequiredAuthority", "validateAuthority", "getTierByName"]
      }
    }
  },
  "prismaSchemaAdditions": {
    "description": "Required Prisma schema additions for Decision Surface persistence",
    "tables": [
      {
        "name": "VoxelDecision",
        "fields": [
          "id String @id @default(uuid()) @db.Uuid",
          "voxel_id String @map(\"voxel_id\") @db.Uuid",
          "decision_ref String @map(\"decision_ref\")",
          "attachment_type String @map(\"attachment_type\") @db.VarChar(50)",
          "attached_by String @map(\"attached_by\") @db.VarChar(20)",
          "requires_acknowledgment Boolean @default(false)",
          "acknowledged Boolean @default(false)",
          "affected_trades String[]",
          "summary String?",
          "created_at DateTime @default(now())"
        ],
        "indexes": ["@@index([voxel_id])", "@@index([decision_ref])", "@@index([acknowledged])"]
      },
      {
        "name": "VoxelToleranceOverride",
        "fields": [
          "id String @id @default(uuid()) @db.Uuid",
          "voxel_id String @map(\"voxel_id\") @db.Uuid",
          "tolerance_type String @map(\"tolerance_type\") @db.VarChar(50)",
          "standard_value Json @map(\"standard_value\") @db.JsonB",
          "approved_value Json @map(\"approved_value\") @db.JsonB",
          "source_decision_ref String @map(\"source_decision_ref\")",
          "approved_by String @map(\"approved_by\")",
          "approval_date DateTime @map(\"approval_date\")",
          "expires_at DateTime? @map(\"expires_at\")",
          "rationale String",
          "applicable_trades String[]",
          "created_at DateTime @default(now())"
        ],
        "indexes": ["@@index([voxel_id])", "@@index([tolerance_type])", "@@index([expires_at])"]
      },
      {
        "name": "VoxelPreApproval",
        "fields": [
          "id String @id @default(uuid()) @db.Uuid",
          "voxel_id String @map(\"voxel_id\") @db.Uuid",
          "scope String",
          "conditions String[]",
          "valid_from DateTime @map(\"valid_from\")",
          "valid_until DateTime? @map(\"valid_until\")",
          "source_decision_ref String @map(\"source_decision_ref\")",
          "authority_level String @map(\"authority_level\") @db.VarChar(30)",
          "applicable_trades String[]",
          "usage_count Int @default(0) @map(\"usage_count\")",
          "created_at DateTime @default(now())"
        ],
        "indexes": ["@@index([voxel_id])", "@@index([authority_level])", "@@index([valid_until])"]
      },
      {
        "name": "VoxelAlert",
        "fields": [
          "id String @id @default(uuid()) @db.Uuid",
          "voxel_id String @map(\"voxel_id\") @db.Uuid",
          "priority String @db.VarChar(20)",
          "title String @db.VarChar(255)",
          "message String",
          "source_decision_ref String? @map(\"source_decision_ref\")",
          "target_trades String[]",
          "requires_acknowledgment Boolean @default(false)",
          "expires_at DateTime? @map(\"expires_at\")",
          "acknowledged_by String[]",
          "created_at DateTime @default(now())"
        ],
        "indexes": ["@@index([voxel_id])", "@@index([priority])", "@@index([expires_at])"]
      },
      {
        "name": "VoxelAcknowledgment",
        "fields": [
          "id String @id @default(uuid()) @db.Uuid",
          "voxel_id String @map(\"voxel_id\") @db.Uuid",
          "decision_ref String @map(\"decision_ref\")",
          "worker_ref String @map(\"worker_ref\")",
          "worker_name String @map(\"worker_name\") @db.VarChar(255)",
          "worker_trade String @map(\"worker_trade\") @db.VarChar(50)",
          "timestamp DateTime",
          "method String @db.VarChar(30)",
          "location Json? @db.JsonB",
          "notes String?",
          "created_at DateTime @default(now())"
        ],
        "indexes": ["@@index([voxel_id])", "@@index([decision_ref])", "@@index([worker_ref])"]
      }
    ]
  },
  "mcpToolsSpecification": {
    "tools": [
      {
        "name": "get_voxel_decisions",
        "description": "Get all decisions attached to a voxel with optional filtering",
        "inputSchema": {
          "voxelId": "string (required)",
          "filters": {
            "attachmentType": "PRIMARY|AFFECTED|ADJACENT|DOWNSTREAM (optional)",
            "requiresAcknowledgment": "boolean (optional)",
            "acknowledged": "boolean (optional)",
            "trades": "string[] (optional)"
          }
        },
        "outputSchema": {
          "decisions": "AttachedDecision[]",
          "totalCount": "number",
          "unacknowledgedCount": "number"
        }
      },
      {
        "name": "acknowledge_decision",
        "description": "Record worker acknowledgment of a decision with location tracking",
        "inputSchema": {
          "voxelId": "string (required)",
          "decisionRef": "string (required)",
          "workerRef": "string (required)",
          "workerName": "string (required)",
          "workerTrade": "string (required)",
          "method": "APP_TAP|SMS_REPLY|VOICE|AR_GESTURE (required)",
          "location": {
            "gps": { "lat": "number", "lng": "number", "accuracy": "number" },
            "uwb": { "x": "number", "y": "number", "z": "number", "accuracy": "number" }
          },
          "notes": "string (optional)"
        },
        "outputSchema": {
          "acknowledgmentId": "string",
          "success": "boolean",
          "decisionSurfaceUpdated": "boolean"
        }
      },
      {
        "name": "apply_tolerance_override",
        "description": "Create an approved tolerance variance for a voxel",
        "inputSchema": {
          "voxelId": "string (required)",
          "toleranceType": "ToleranceType (required)",
          "standardValue": "ToleranceValue (required)",
          "approvedValue": "ToleranceValue (required)",
          "sourceDecisionRef": "string (required)",
          "approvedBy": "string (required)",
          "rationale": "string (required)",
          "applicableTrades": "string[] (required)",
          "expiresAt": "Date (optional)"
        },
        "outputSchema": {
          "overrideId": "string",
          "success": "boolean"
        }
      },
      {
        "name": "query_tolerance_overrides",
        "description": "Query tolerance overrides by criteria",
        "inputSchema": {
          "projectId": "string (required)",
          "voxelId": "string (optional)",
          "toleranceType": "ToleranceType (optional)",
          "trade": "string (optional)",
          "active": "boolean (optional - filters by expiration)"
        },
        "outputSchema": {
          "overrides": "ToleranceOverride[]",
          "totalCount": "number"
        }
      },
      {
        "name": "request_inspection",
        "description": "Schedule an inspection for a voxel",
        "inputSchema": {
          "voxelId": "string (required)",
          "inspectionType": "ROUGH|FINAL|SPECIAL (required)",
          "requestedBy": "string (required)",
          "priority": "NORMAL|EXPEDITED (optional)",
          "notes": "string (optional)",
          "targetDate": "Date (optional)"
        },
        "outputSchema": {
          "inspectionId": "string",
          "scheduledDate": "Date",
          "status": "SCHEDULED"
        }
      },
      {
        "name": "complete_inspection",
        "description": "Record inspection completion results",
        "inputSchema": {
          "inspectionId": "string (required)",
          "voxelId": "string (required)",
          "result": "PASSED|FAILED|CONDITIONAL (required)",
          "inspectorRef": "string (required)",
          "findings": "string (optional)",
          "conditions": "string[] (optional for CONDITIONAL)",
          "decisionsReviewed": "string[] (optional - URNs)"
        },
        "outputSchema": {
          "success": "boolean",
          "voxelStatusUpdated": "boolean",
          "nextSteps": "string[]"
        }
      }
    ]
  },
