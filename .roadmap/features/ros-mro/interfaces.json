{
  "$schema": "../../schemas/interfaces.schema.json",
  "$id": "urn:luhtech:ectropy:interfaces:ros-mro",
  "schemaVersion": "1.0.0",
  "meta": {
    "ventureId": "ectropy",
    "featureId": "ros-mro",
    "createdAt": "2026-01-24T18:00:00Z",
    "lastUpdated": "2026-01-24T20:00:00Z",
    "author": "claude",
    "sourceDoc": ".roadmap/features/ros-mro/interfaces.json"
  },
  "summary": "ROS MRO REST API endpoints, React Query hooks, and service definitions for voxel coordination dashboard",
  "restApi": {
    "basePath": "/api/v1",
    "endpoints": [
      {
        "method": "GET",
        "path": "/projects/:projectId/voxels",
        "description": "List all voxels for a project with optional filtering",
        "auth": "required",
        "authorityRequired": 0,
        "request": {
          "params": {
            "projectId": {"type": "string", "required": true, "description": "Project UUID"}
          },
          "query": {
            "system": {"type": "string", "description": "Filter by system (STRUCT, MECH, ELEC, PLUMB, HVAC, FIRE)"},
            "status": {"type": "string", "description": "Filter by status (PLANNED, IN_PROGRESS, COMPLETE, BLOCKED)"},
            "level": {"type": "string", "description": "Filter by level"},
            "limit": {"type": "integer", "description": "Max results (default 1000)"}
          }
        },
        "response": {
          "200": {
            "schema": {
              "voxels": "VoxelData[]",
              "total": "number",
              "aggregations": "VoxelAggregation[]"
            }
          }
        }
      },
      {
        "method": "GET",
        "path": "/projects/:projectId/voxels/aggregation",
        "description": "Get voxel aggregations by level and system",
        "auth": "required",
        "authorityRequired": 0,
        "response": {
          "200": {
            "schema": {
              "byLevel": "VoxelAggregation[]",
              "bySystem": "VoxelAggregation[]",
              "overall": {
                "totalVoxels": "number",
                "progressPercentage": "number",
                "healthScore": "number"
              }
            }
          }
        }
      },
      {
        "method": "GET",
        "path": "/projects/:projectId/voxels/:voxelId",
        "description": "Get single voxel with linked decisions and history",
        "auth": "required",
        "authorityRequired": 0,
        "response": {
          "200": {
            "schema": {
              "voxel": "VoxelData",
              "linkedDecisions": "Decision[]",
              "history": "VoxelStatusChange[]"
            }
          }
        }
      },
      {
        "method": "PATCH",
        "path": "/voxels/:voxelId/status",
        "description": "Update voxel status with optional note",
        "auth": "required",
        "authorityRequired": 2,
        "request": {
          "body": {
            "status": {"type": "enum", "values": ["PLANNED", "IN_PROGRESS", "COMPLETE", "BLOCKED", "ON_HOLD", "INSPECTION_REQUIRED"], "required": true},
            "percentComplete": {"type": "integer", "min": 0, "max": 100},
            "note": {"type": "string", "maxLength": 500}
          }
        },
        "response": {
          "200": {"schema": {"voxel": "VoxelData"}}
        }
      },
      {
        "method": "GET",
        "path": "/voxels/:voxelId/history",
        "description": "Get status change history for a voxel",
        "auth": "required",
        "authorityRequired": 0,
        "response": {
          "200": {
            "schema": {
              "history": "VoxelStatusHistory[]",
              "total": "number"
            }
          }
        }
      },
      {
        "method": "POST",
        "path": "/voxels/batch",
        "description": "Batch update multiple voxels",
        "auth": "required",
        "authorityRequired": 3,
        "request": {
          "body": {
            "updates": {
              "type": "array",
              "items": {
                "voxelId": "string",
                "status": "VoxelStatus",
                "percentComplete": "number"
              }
            }
          }
        },
        "response": {
          "200": {
            "schema": {
              "updated": "number",
              "failed": "number",
              "errors": "Error[]"
            }
          }
        }
      },
      {
        "method": "GET",
        "path": "/projects/:projectId/voxels/export",
        "description": "Export voxels to CSV or JSON",
        "auth": "required",
        "authorityRequired": 1,
        "request": {
          "query": {
            "format": {"type": "enum", "values": ["csv", "json"], "required": true}
          }
        },
        "response": {
          "200": {"schema": "Binary file download"}
        }
      },
      {
        "method": "GET",
        "path": "/projects/:projectId/activity",
        "description": "Get activity stream for project",
        "auth": "required",
        "authorityRequired": 0,
        "response": {
          "200": {
            "schema": {
              "activities": "ActivityItem[]",
              "unreadCount": "number"
            }
          }
        }
      }
    ]
  },
  "dataTypes": {
    "VoxelData": {
      "description": "Core voxel data structure",
      "schema": ".roadmap/schemas/ros-mro/coordination-view.schema.json#/definitions/VoxelData",
      "fields": {
        "id": {"type": "string", "description": "Unique voxel ID (UUID)"},
        "voxelId": {"type": "string", "description": "Human-readable voxel ID (VOX-L1-STRUCT-001)"},
        "center": {"type": "object", "description": "3D center coordinates {x, y, z}"},
        "resolution": {"type": "number", "description": "Voxel size in mm (default 180)"},
        "system": {"type": "string", "description": "Building system (STRUCT, MECH, ELEC, PLUMB, HVAC, FIRE)"},
        "status": {"type": "string", "description": "Current status"},
        "healthStatus": {"type": "string", "description": "Health indicator (HEALTHY, AT_RISK, CRITICAL)"},
        "percentComplete": {"type": "number", "description": "Completion percentage 0-100"},
        "decisionCount": {"type": "number", "description": "Attached decisions count"}
      }
    },
    "VoxelAggregation": {
      "description": "Aggregated voxel statistics",
      "fields": {
        "label": {"type": "string"},
        "count": {"type": "number"},
        "statusBreakdown": {"type": "object"},
        "avgProgress": {"type": "number"}
      }
    },
    "ActivityItem": {
      "description": "Activity feed item",
      "schema": ".roadmap/schemas/ros-mro/coordination-view.schema.json#/definitions/ActivityItem",
      "fields": {
        "id": {"type": "string"},
        "type": {"type": "string", "description": "status_change | decision_attached | inspection | issue"},
        "title": {"type": "string"},
        "description": {"type": "string"},
        "severity": {"type": "string", "description": "info | warning | error | success"},
        "timestamp": {"type": "string", "description": "ISO 8601 timestamp"}
      }
    },
    "GeneratedRecords": {
      "description": "Records generated by DemoScenarioService for persistence",
      "fields": {
        "users": {"type": "array", "description": "Generated user records"},
        "projects": {"type": "array", "description": "Generated project records"},
        "participants": {"type": "array", "description": "Project participant mappings"},
        "voxels": {"type": "array", "description": "Generated voxel records"},
        "decisions": {"type": "array", "description": "PM decision records"},
        "inspections": {"type": "array", "description": "Inspection records"},
        "consequences": {"type": "array", "description": "Decision consequences"},
        "decisionEvents": {"type": "array", "description": "Decision event history"},
        "alerts": {"type": "array", "description": "Voxel alert records"},
        "acknowledgments": {"type": "array", "description": "Alert acknowledgments"}
      }
    }
  },
  "services": {
    "DemoPersistenceService": {
      "location": "apps/api-gateway/src/services/demo-persistence.service.ts",
      "description": "Persists synthetic demo data from DemoScenarioService to PostgreSQL",
      "methods": [
        {
          "name": "persistGeneratedRecords",
          "description": "Persist all generated demo records to database",
          "params": {
            "records": {"type": "GeneratedRecords", "required": true},
            "options": {
              "cleanupPrevious": {"type": "boolean", "description": "Delete previous demo data"},
              "projectId": {"type": "string", "description": "Limit cleanup to specific project"}
            }
          },
          "returns": {
            "success": "boolean",
            "counts": {
              "users": "number",
              "projects": "number",
              "voxels": "number",
              "decisions": "number"
            }
          }
        },
        {
          "name": "persistVoxels",
          "description": "Persist voxel records with field mapping",
          "params": {
            "voxels": {"type": "array", "required": true}
          },
          "returns": {"inserted": "number"}
        },
        {
          "name": "persistDecisions",
          "description": "Persist PM decision records",
          "params": {
            "decisions": {"type": "array", "required": true}
          },
          "returns": {"inserted": "number"}
        }
      ]
    },
    "VoxelDataService": {
      "location": "apps/api-gateway/src/services/voxel-data.service.ts",
      "description": "Voxel data access layer for API routes",
      "methods": [
        {
          "name": "getProjectVoxels",
          "description": "Fetch voxels for a project with filtering",
          "params": {
            "projectId": {"type": "string", "required": true},
            "filters": {"type": "VoxelFilter"}
          },
          "returns": {"voxels": "VoxelData[]", "total": "number"}
        },
        {
          "name": "getVoxelAggregations",
          "description": "Get aggregated voxel statistics",
          "params": {
            "projectId": {"type": "string", "required": true}
          },
          "returns": {"byLevel": "VoxelAggregation[]", "bySystem": "VoxelAggregation[]"}
        },
        {
          "name": "updateVoxelStatus",
          "description": "Update voxel status with history tracking",
          "params": {
            "voxelId": {"type": "string", "required": true},
            "status": {"type": "VoxelStatus", "required": true},
            "userId": {"type": "string", "required": true},
            "note": {"type": "string"}
          },
          "returns": {"voxel": "VoxelData"}
        }
      ]
    }
  },
  "hooks": {
    "useVoxels": {
      "location": "apps/web-dashboard/src/hooks/queries/useVoxels.ts",
      "description": "React Query hook for fetching project voxels",
      "params": {
        "projectId": {"type": "string", "required": true}
      },
      "returns": {
        "data": "VoxelData[] | undefined",
        "isLoading": "boolean",
        "error": "Error | null"
      },
      "config": {
        "staleTime": "30_000",
        "refetchInterval": "30_000"
      }
    },
    "useVoxelAggregations": {
      "location": "apps/web-dashboard/src/hooks/queries/useVoxels.ts",
      "description": "React Query hook for voxel aggregations",
      "params": {
        "projectId": {"type": "string", "required": true}
      },
      "returns": {
        "data": "VoxelAggregation[] | undefined"
      },
      "config": {
        "staleTime": "60_000"
      }
    },
    "useVoxelStatusMutation": {
      "location": "apps/web-dashboard/src/hooks/queries/useVoxels.ts",
      "description": "React Query mutation for updating voxel status",
      "params": {
        "voxelId": {"type": "string"},
        "status": {"type": "VoxelStatus"},
        "percentComplete": {"type": "number"},
        "note": {"type": "string"}
      },
      "returns": {
        "mutate": "function",
        "isLoading": "boolean"
      }
    },
    "useActivityStream": {
      "location": "apps/web-dashboard/src/hooks/queries/useActivityStream.ts",
      "description": "React Query hook for activity feed",
      "params": {
        "projectId": {"type": "string", "required": true}
      },
      "returns": {
        "data": "ActivityItem[] | undefined"
      },
      "config": {
        "staleTime": "10_000",
        "refetchInterval": "10_000"
      }
    }
  },
  "events": [
    {
      "name": "VOXEL_STATUS_UPDATED",
      "description": "Emitted when a voxel status changes",
      "payload": {
        "voxelId": "string",
        "projectId": "string",
        "previousStatus": "VoxelStatus",
        "newStatus": "VoxelStatus",
        "updatedBy": "string",
        "timestamp": "string"
      },
      "emittedBy": ["VoxelDataService.updateVoxelStatus"]
    },
    {
      "name": "DEMO_DATA_PERSISTED",
      "description": "Emitted when demo scenario data is persisted to database",
      "payload": {
        "scenarioId": "string",
        "projectId": "string",
        "recordCounts": "object",
        "timestamp": "string"
      },
      "emittedBy": ["DemoPersistenceService.persistGeneratedRecords"]
    }
  ],
  "mcpTools": {
    "totalCount": 6,
    "categories": [
      {
        "name": "Voxel Operations",
        "description": "MCP tools for voxel management (planned Q2 2026)",
        "tools": [
          {
            "name": "voxel_get_list",
            "description": "Get list of voxels for a project with optional filtering",
            "authorityRequired": 0,
            "input": {
              "projectId": {"type": "string", "required": true},
              "system": {"type": "string"},
              "status": {"type": "string"}
            }
          },
          {
            "name": "voxel_update_status",
            "description": "Update the status of a voxel",
            "authorityRequired": 2,
            "input": {
              "voxelId": {"type": "string", "required": true},
              "status": {"type": "enum", "values": ["PLANNED", "IN_PROGRESS", "COMPLETE", "BLOCKED"], "required": true},
              "note": {"type": "string"}
            }
          },
          {
            "name": "voxel_attach_decision",
            "description": "Attach a PM decision to a voxel location",
            "authorityRequired": 3,
            "input": {
              "voxelId": {"type": "string", "required": true},
              "decisionId": {"type": "string", "required": true}
            }
          },
          {
            "name": "voxel_get_aggregations",
            "description": "Get aggregated voxel statistics by level and system",
            "authorityRequired": 0,
            "input": {
              "projectId": {"type": "string", "required": true}
            }
          },
          {
            "name": "voxel_batch_update",
            "description": "Batch update multiple voxels at once",
            "authorityRequired": 3,
            "input": {
              "updates": {"type": "array", "required": true}
            }
          },
          {
            "name": "voxel_export",
            "description": "Export voxels to CSV or JSON format",
            "authorityRequired": 1,
            "input": {
              "projectId": {"type": "string", "required": true},
              "format": {"type": "enum", "values": ["csv", "json"], "required": true}
            }
          }
        ]
      }
    ]
  }
}
