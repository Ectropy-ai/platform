{
  "$schema": "https://luhtech.dev/schemas/interfaces.schema.json",
  "$id": "urn:luhtech:ectropy:interfaces:contract-onboarding",
  "schemaVersion": "3.0.0",
  "meta": {
    "ventureId": "ectropy",
    "featureId": "contract-onboarding",
    "createdAt": "2026-01-15T10:00:00Z",
    "lastUpdated": "2026-01-15T10:00:00Z",
    "author": "erik",
    "sourceDoc": ".roadmap/features/contract-onboarding/interfaces.json"
  },
  "summary": "MCP tools for contract parsing and project configuration - 3 tools",
  "mcpTools": {
    "totalCount": 3,
    "categories": [
      {
        "name": "Contract Management",
        "tools": [
          {
            "name": "parse_contract_tool",
            "description": "Parse AIA/CCDC/ConsensusDOCS PDF or DOCX to extract structured data",
            "authorityRequired": 3,
            "input": {
              "documentUri": {
                "type": "string",
                "format": "uri",
                "required": true,
                "description": "Storage URI of uploaded contract document"
              },
              "contractFamily": {
                "type": "enum",
                "values": ["AIA", "ConsensusDOCS", "CCDC", "Custom"],
                "description": "Optional hint for contract family"
              },
              "expectedType": {
                "type": "string",
                "description": "Optional hint for expected contract type (e.g., C191, A133)"
              }
            },
            "output": {
              "contractAnalysis": {
                "detectedFamily": { "type": "string" },
                "detectedType": { "type": "string" },
                "deliveryMethod": { "type": "string" },
                "confidence": { "type": "number", "min": 0, "max": 1 },
                "parties": { "type": "array", "items": "PartyExtraction" },
                "financialTerms": { "type": "FinancialTerms" },
                "keyDates": { "type": "KeyDates" },
                "governanceStructure": { "type": "GovernanceStructure" },
                "humanReviewFlags": { "type": "array", "items": "ReviewFlag" }
              },
              "rawExtraction": { "type": "object" },
              "processingTime": {
                "type": "number",
                "description": "Milliseconds"
              }
            }
          },
          {
            "name": "extract_authority_cascade_tool",
            "description": "Map contract governance roles to Ectropy 7-tier authority cascade",
            "authorityRequired": 3,
            "input": {
              "contractAnalysis": {
                "type": "object",
                "required": true,
                "description": "Output from parse_contract_tool"
              },
              "projectId": {
                "type": "string",
                "description": "Optional: existing project to update"
              }
            },
            "output": {
              "authorityMapping": {
                "level0_FIELD": { "type": "array", "items": "RoleMapping" },
                "level1_FOREMAN": { "type": "array", "items": "RoleMapping" },
                "level2_SUPERINTENDENT": {
                  "type": "array",
                  "items": "RoleMapping"
                },
                "level3_PM": { "type": "array", "items": "RoleMapping" },
                "level4_ARCHITECT": { "type": "array", "items": "RoleMapping" },
                "level5_OWNER": { "type": "array", "items": "RoleMapping" },
                "level6_REGULATORY": {
                  "type": "array",
                  "items": "RoleMapping"
                },
                "pmtAuthority": { "type": "PMTAuthority" },
                "petAuthority": { "type": "PETAuthority" }
              },
              "thresholds": {
                "type": "array",
                "items": "ThresholdMapping"
              },
              "escalationRules": {
                "type": "array",
                "items": "EscalationRule"
              },
              "confidence": { "type": "number" },
              "reviewRequired": { "type": "boolean" }
            }
          },
          {
            "name": "configure_project_from_contract_tool",
            "description": "Auto-configure Ectropy project from parsed contract data",
            "authorityRequired": 5,
            "input": {
              "contractUrn": {
                "type": "urn",
                "description": "URN of stored contract (if already saved)"
              },
              "contractAnalysis": {
                "type": "object",
                "description": "Or provide analysis directly"
              },
              "authorityMapping": {
                "type": "object",
                "required": true
              },
              "projectName": {
                "type": "string",
                "description": "Override extracted project name"
              },
              "sendInvitations": {
                "type": "boolean",
                "default": false,
                "description": "Send team invitations after creation"
              }
            },
            "output": {
              "project": { "type": "Project" },
              "contract": { "type": "Contract" },
              "parties": { "type": "array", "items": "ContractParty" },
              "authorityLevels": { "type": "array", "items": "AuthorityLevel" },
              "participants": { "type": "array", "items": "Participant" },
              "invitationsSent": { "type": "array", "items": "string" },
              "setupComplete": { "type": "boolean" }
            }
          }
        ]
      }
    ]
  },
  "restApi": {
    "baseUrl": "/api/contracts",
    "endpoints": [
      {
        "method": "POST",
        "path": "/upload",
        "description": "Upload contract document",
        "authorityRequired": 3
      },
      {
        "method": "GET",
        "path": "/:id/analysis",
        "description": "Get contract analysis results",
        "authorityRequired": 0
      },
      {
        "method": "POST",
        "path": "/:id/configure",
        "description": "Configure project from contract",
        "authorityRequired": 5
      },
      {
        "method": "GET",
        "path": "/:id/authority-cascade",
        "description": "Get authority cascade mapping",
        "authorityRequired": 0
      },
      {
        "method": "PUT",
        "path": "/:id/review",
        "description": "Submit human review corrections",
        "authorityRequired": 3
      }
    ]
  },
  "graphMetadata": {
    "inEdges": ["urn:luhtech:ectropy:feature:contract-onboarding"],
    "outEdges": []
  }
}
