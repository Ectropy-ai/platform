  },
  "description": "Track building system commissioning with functional performance testing (FPT) results linked to PM decisions. Connect commissioning issues to root cause decisions for complete audit trail from design through operations.",
  "coreInnovation": {
    "before": {
      "fptTracking": "Paper checklists, manual spreadsheets",
      "issueResolution": "No traceability to original decisions",
      "documentation": "Scattered across multiple systems",
      "rootCauseAnalysis": "Manual investigation, often incomplete"
    },
    "after": {
      "fptTracking": "Digital records linked to voxels",
      "issueResolution": "Direct links to PM decisions that caused issues",
      "documentation": "Unified system with spatial context",
      "rootCauseAnalysis": "Automated traversal of decision graph"
    }
  },
  "value": {
    "fptTimeReduction": "40% faster test documentation",
    "issueResolutionTime": "60% faster with decision linkage",
    "documentationCompleteness": "100% vs industry average 70%",
    "differentiator": "Only platform linking Cx issues to construction decisions"
  },
  "milestones": [
    {
      "id": "M1",
      "name": "Commissioning System Database",
      "targetDate": "2026-07-01",
      "status": "NOT_STARTED",
      "description": "Prisma models and database for commissioning systems",
      "deliverables": [
        "Prisma models for CommissioningSystem, FunctionalTest, CxIssue",
        "Database migrations",
        "Seed data for system types"
      ]
    },
    {
      "id": "M2",
      "name": "FPT Recording Interface",
      "targetDate": "2026-07-15",
      "status": "NOT_STARTED",
      "description": "Interface for logging functional performance tests",
      "deliverables": [
        "FPT entry UI with checklist templates",
        "Mobile-friendly test recording",
        "Photo/video evidence attachment",
        "Pass/fail with conditions workflow"
      ]
    },
    {
      "id": "M3",
      "name": "Decision Linkage Engine",
      "targetDate": "2026-08-01",
      "status": "NOT_STARTED",
      "description": "Link commissioning issues to PM decisions",
      "deliverables": [
        "Root cause decision search",
        "Graph traversal for related decisions",
        "Issue-to-decision attachment workflow",
        "Resolution tracking with decision reference"
      ]
    },
    {
      "id": "M4",
      "name": "MCP Tools & Documentation Generation",
      "targetDate": "2026-09-01",
      "status": "NOT_STARTED",
      "description": "MCP tools and automated documentation",
      "deliverables": [
        "log_fpt_result_tool",
        "link_cx_issue_to_decision_tool",
        "generate_cx_documentation_tool",
        "Cx report PDF generation",
        "O&M manual integration"
      ]
    }
  ],
