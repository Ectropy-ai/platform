{
  "$schema": "https://luhtech.dev/schemas/interfaces.schema.json",
  "$id": "urn:luhtech:ectropy:interfaces:commissioning",
  "schemaVersion": "3.0.0",
  "meta": {
    "ventureId": "ectropy",
    "featureId": "commissioning-integration",
    "createdAt": "2026-01-15T23:55:00Z",
    "lastUpdated": "2026-01-15T23:55:00Z",
    "author": "erik",
    "sourceDoc": ".roadmap/features/commissioning/interfaces.json"
  },
  "summary": "MCP tools for commissioning integration - 3 tools for FPT logging, issue linkage, and documentation generation",
  "mcpTools": {
    "totalCount": 3,
    "categories": [
      {
        "name": "Commissioning Operations",
        "tools": [
          {
            "name": "log_fpt_result_tool",
            "description": "Record functional performance test result for a building system",
            "authorityRequired": 2,
            "input": {
              "systemUrn": {
                "type": "urn",
                "required": true,
                "description": "URN of commissioning system being tested"
              },
              "testType": {
                "type": "string",
                "required": true,
                "description": "Type of functional test (e.g., 'Air Balance', 'Load Test')"
              },
              "testDate": {
                "type": "datetime",
                "required": true,
                "description": "Date and time test was performed"
              },
              "performedBy": {
                "type": "urn",
                "required": true,
                "description": "Participant who performed the test"
              },
              "witnessedBy": {
                "type": "array",
                "items": "urn",
                "description": "Participants who witnessed the test"
              },
              "outcome": {
                "type": "enum",
                "values": ["PASSED", "FAILED", "CONDITIONAL", "DEFERRED"],
                "required": true,
                "description": "Test outcome"
              },
              "measurements": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "parameter": { "type": "string" },
                    "expected": { "type": "string" },
                    "actual": { "type": "string" },
                    "unit": { "type": "string" },
                    "withinTolerance": { "type": "boolean" }
                  }
                },
                "description": "Measured values vs expected"
              },
              "checklistItems": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "item": { "type": "string" },
                    "passed": { "type": "boolean" },
                    "notes": { "type": "string" }
                  }
                },
                "description": "Checklist verification items"
              },
              "conditions": {
                "type": "array",
                "items": "string",
                "description": "Conditions attached to CONDITIONAL pass"
              },
              "deficiencies": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "description": { "type": "string" },
                    "severity": {
                      "type": "enum",
                      "values": ["MINOR", "MAJOR", "CRITICAL"]
                    },
                    "responsibleParty": { "type": "urn" }
                  }
                },
                "description": "Deficiencies found during test"
              },
              "evidence": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "type": {
                      "type": "enum",
                      "values": ["PHOTO", "VIDEO", "DOCUMENT", "DATA_LOG"]
                    },
                    "uri": { "type": "string", "format": "uri" },
                    "description": { "type": "string" }
                  }
                },
                "description": "Test evidence attachments"
              },
              "retestRequired": {
                "type": "boolean",
                "description": "Whether retest is needed"
              },
              "retestDate": {
                "type": "date",
                "description": "Scheduled retest date if required"
              },
              "notes": {
                "type": "string",
                "description": "Additional test notes"
              }
            },
            "output": {
              "functionalTest": {
                "type": "FunctionalTest",
                "description": "Created functional test record"
              },
              "testUrn": {
                "type": "urn",
                "description": "URN of test record"
              },
              "systemUpdated": {
                "type": "CommissioningSystem",
                "description": "Updated system with test results"
              },
              "issuesCreated": {
                "type": "array",
                "items": "CxIssue",
                "description": "Issues auto-created from deficiencies"
              },
              "closeoutImpact": {
                "type": "object",
                "properties": {
                  "systemStatus": { "type": "string" },
                  "closeoutBlocked": { "type": "boolean" },
                  "remainingTests": { "type": "integer" }
                }
              },
              "notificationsSent": {
                "type": "array",
                "items": "NotificationResult"
              }
            }
          },
          {
            "name": "link_cx_issue_to_decision_tool",
            "description": "Connect a commissioning issue to the PM decision(s) that caused it for root cause traceability",
            "authorityRequired": 2,
            "input": {
              "issueUrn": {
                "type": "urn",
                "required": true,
                "description": "URN of commissioning issue"
              },
              "decisionUrns": {
                "type": "array",
                "items": "urn",
                "required": true,
                "minItems": 1,
                "description": "PM decisions that contributed to issue"
              },
              "linkType": {
                "type": "enum",
                "values": [
                  "ROOT_CAUSE",
                  "CONTRIBUTING_FACTOR",
                  "RELATED",
                  "SUPERSEDES"
                ],
                "required": true,
                "description": "Type of relationship"
              },
              "analysis": {
                "type": "string",
                "required": true,
                "description": "Root cause analysis explanation"
              },
              "preventionRecommendation": {
                "type": "string",
                "description": "Recommendation to prevent similar issues"
              },
              "costImpact": {
                "type": "number",
                "description": "Cost to resolve issue"
              },
              "scheduleImpact": {
                "type": "number",
                "description": "Schedule impact in hours"
              },
              "linkedBy": {
                "type": "urn",
                "required": true,
                "description": "Participant who performed analysis"
              }
            },
            "output": {
              "issue": {
                "type": "CxIssue",
                "description": "Updated issue with decision links"
              },
              "graphEdges": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "from": { "type": "urn" },
                    "to": { "type": "urn" },
                    "edgeType": { "type": "string" },
                    "metadata": { "type": "object" }
                  }
                },
                "description": "Created graph edges"
              },
              "relatedDecisions": {
                "type": "array",
                "items": "PMDecision",
                "description": "Full decision records"
              },
              "decisionChain": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "decisionUrn": { "type": "urn" },
                    "title": { "type": "string" },
                    "date": { "type": "datetime" },
                    "approvedBy": { "type": "string" },
                    "impact": { "type": "string" }
                  }
                },
                "description": "Chain of decisions leading to issue"
              },
              "lessonsLearned": {
                "type": "object",
                "properties": {
                  "pattern": { "type": "string" },
                  "frequency": { "type": "integer" },
                  "recommendation": { "type": "string" }
                },
                "description": "Pattern analysis from similar issues"
              }
            }
          },
          {
            "name": "generate_cx_documentation_tool",
            "description": "Generate comprehensive commissioning documentation package for closeout",
            "authorityRequired": 3,
            "input": {
              "projectId": {
                "type": "string",
                "required": true,
                "description": "Project identifier"
              },
              "systemUrns": {
                "type": "array",
                "items": "urn",
                "description": "Specific systems to include (all if omitted)"
              },
              "documentTypes": {
                "type": "array",
                "items": {
                  "type": "enum",
                  "values": [
                    "CX_PLAN",
                    "PREFUNCTIONAL_CHECKLISTS",
                    "FPT_REPORTS",
                    "ISSUES_LOG",
                    "SYSTEMS_MANUAL",
                    "TRAINING_RECORDS",
                    "SEASONAL_CX_PLAN",
                    "EXECUTIVE_SUMMARY"
                  ]
                },
                "required": true,
                "description": "Types of documents to generate"
              },
              "format": {
                "type": "enum",
                "values": ["PDF", "DOCX", "HTML", "ZIP_PACKAGE"],
                "default": "PDF",
                "description": "Output format"
              },
              "includeEvidence": {
                "type": "boolean",
                "default": true,
                "description": "Include photo/video evidence in package"
              },
              "includeDecisionLinks": {
                "type": "boolean",
                "default": true,
                "description": "Include linked PM decision references"
              },
              "branding": {
                "type": "object",
                "properties": {
                  "companyLogo": { "type": "string", "format": "uri" },
                  "projectLogo": { "type": "string", "format": "uri" },
                  "headerText": { "type": "string" },
                  "footerText": { "type": "string" }
                },
                "description": "Document branding options"
              },
              "recipients": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "email": { "type": "string", "format": "email" },
                    "name": { "type": "string" },
                    "role": { "type": "string" }
                  }
                },
                "description": "Recipients to email documentation"
              }
            },
            "output": {
              "documents": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "documentType": { "type": "string" },
                    "filename": { "type": "string" },
                    "url": { "type": "string", "format": "uri" },
                    "pageCount": { "type": "integer" },
                    "generatedAt": { "type": "datetime" }
                  }
                },
                "description": "Generated documents"
              },
              "packageUrl": {
                "type": "string",
                "format": "uri",
                "description": "URL to download complete package"
              },
              "summary": {
                "type": "object",
                "properties": {
                  "totalSystems": { "type": "integer" },
                  "systemsPassed": { "type": "integer" },
                  "systemsFailed": { "type": "integer" },
                  "systemsConditional": { "type": "integer" },
                  "totalTests": { "type": "integer" },
                  "totalIssues": { "type": "integer" },
                  "issuesResolved": { "type": "integer" },
                  "issuesOutstanding": { "type": "integer" }
                }
              },
              "decisionTraceability": {
                "type": "object",
                "properties": {
                  "issuesWithDecisionLinks": { "type": "integer" },
                  "rootCausesIdentified": { "type": "integer" },
                  "lessonsDocumented": { "type": "integer" }
                }
              },
              "emailsSent": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "recipient": { "type": "string" },
                    "sent": { "type": "boolean" },
                    "sentAt": { "type": "datetime" }
                  }
                }
              }
            }
          }
        ]
      }
    ]
  },
  "restApi": {
    "baseUrl": "/api/commissioning",
    "endpoints": [
      {
        "method": "GET",
        "path": "/projects/:projectId/systems",
        "description": "List commissioning systems for project",
        "authorityRequired": 0
      },
      {
        "method": "POST",
        "path": "/systems",
        "description": "Create commissioning system",
        "authorityRequired": 2
      },
      {
        "method": "GET",
        "path": "/systems/:urn",
        "description": "Get commissioning system by URN",
        "authorityRequired": 0
      },
      {
        "method": "PUT",
        "path": "/systems/:urn",
        "description": "Update commissioning system",
        "authorityRequired": 2
      },
      {
        "method": "POST",
        "path": "/systems/:urn/tests",
        "description": "Log functional test result",
        "authorityRequired": 2,
        "requestBody": "FPTRequest",
        "response": "FunctionalTestResponse"
      },
      {
        "method": "GET",
        "path": "/systems/:urn/tests",
        "description": "Get tests for system",
        "authorityRequired": 0
      },
      {
        "method": "GET",
        "path": "/tests/:urn",
        "description": "Get functional test by URN",
        "authorityRequired": 0
      },
      {
        "method": "POST",
        "path": "/issues",
        "description": "Create commissioning issue",
        "authorityRequired": 1
      },
      {
        "method": "GET",
        "path": "/issues/:urn",
        "description": "Get issue by URN",
        "authorityRequired": 0
      },
      {
        "method": "PUT",
        "path": "/issues/:urn",
        "description": "Update issue",
        "authorityRequired": 1
      },
      {
        "method": "POST",
        "path": "/issues/:urn/link-decision",
        "description": "Link issue to PM decision",
        "authorityRequired": 2,
        "requestBody": "DecisionLinkRequest",
        "response": "DecisionLinkResponse"
      },
      {
        "method": "POST",
        "path": "/issues/:urn/resolve",
        "description": "Resolve issue",
        "authorityRequired": 2
      },
      {
        "method": "POST",
        "path": "/projects/:projectId/documentation",
        "description": "Generate Cx documentation",
        "authorityRequired": 3,
        "requestBody": "DocumentationRequest",
        "response": "DocumentationResponse"
      },
      {
        "method": "GET",
        "path": "/projects/:projectId/summary",
        "description": "Get Cx summary for project",
        "authorityRequired": 0
      }
    ]
  },
  "webhooks": [
    {
      "event": "fpt.completed",
      "description": "Fired when functional test is completed",
      "payload": "FPTEvent"
    },
    {
      "event": "fpt.failed",
      "description": "Fired when functional test fails",
      "payload": "FPTFailureEvent"
    },
    {
      "event": "system.status_changed",
      "description": "Fired when system commissioning status changes",
      "payload": "SystemStatusEvent"
    },
    {
      "event": "issue.created",
      "description": "Fired when Cx issue is created",
      "payload": "CxIssueEvent"
    },
    {
      "event": "issue.linked_to_decision",
      "description": "Fired when issue is linked to PM decision",
      "payload": "DecisionLinkEvent"
    },
    {
      "event": "issue.resolved",
      "description": "Fired when Cx issue is resolved",
      "payload": "CxIssueEvent"
    },
    {
      "event": "documentation.generated",
      "description": "Fired when Cx documentation is generated",
      "payload": "DocumentationEvent"
    },
    {
      "event": "project.cx_complete",
      "description": "Fired when all systems are commissioned",
      "payload": "ProjectCxEvent"
    }
  ],
  "errorCodes": [
    {
      "code": "SYSTEM_NOT_FOUND",
      "httpStatus": 404,
      "description": "Commissioning system URN does not exist"
    },
    {
      "code": "TEST_NOT_FOUND",
      "httpStatus": 404,
      "description": "Functional test URN does not exist"
    },
    {
      "code": "ISSUE_NOT_FOUND",
      "httpStatus": 404,
      "description": "Cx issue URN does not exist"
    },
    {
      "code": "DECISION_NOT_FOUND",
      "httpStatus": 404,
      "description": "Referenced PM decision does not exist"
    },
    {
      "code": "INSUFFICIENT_AUTHORITY",
      "httpStatus": 403,
      "description": "Authority level too low for operation"
    },
    {
      "code": "SYSTEM_ALREADY_COMPLETE",
      "httpStatus": 409,
      "description": "Cannot modify completed system"
    },
    {
      "code": "PREFUNCTIONAL_INCOMPLETE",
      "httpStatus": 400,
      "description": "Prefunctional checks required before FPT"
    },
    {
      "code": "ISSUE_ALREADY_RESOLVED",
      "httpStatus": 409,
      "description": "Issue already resolved"
    },
    {
      "code": "INVALID_LINK_TYPE",
      "httpStatus": 400,
      "description": "Invalid decision link type"
    },
    {
      "code": "DOCUMENTATION_GENERATION_FAILED",
      "httpStatus": 500,
      "description": "Failed to generate documentation"
    }
  ],
  "graphMetadata": {
    "inEdges": ["urn:luhtech:ectropy:feature:commissioning-integration"],
    "outEdges": []
  }
}
