{
  "$schema": "https://luhtech.dev/schemas/graph-architecture.schema.json",
  "$id": "urn:luhtech:ectropy:architecture:pm-decision-graph",
  "schemaVersion": "3.0.0",
  "meta": {
    "ventureId": "ectropy",
    "featureId": "decision-lifecycle",
    "createdAt": "2026-01-07T00:00:00Z",
    "lastUpdated": "2026-01-07T00:00:00Z",
    "author": "erik",
    "sourceDoc": ".roadmap/features/decision-lifecycle/graph-architecture.json"
  },
  "summary": "Graph architecture for PM Decision Lifecycle - 7 new node types, 12 edge types, bridging ADR and PM decisions",
  "nodeTypes": [
    {
      "nodeType": "voxel",
      "urnPattern": "urn:luhtech:{project}:voxel:{voxelId}",
      "idPattern": "^VOX-[A-Z0-9-]+$",
      "scope": "project",
      "description": "3D spatial decision container",
      "schemaRef": ".roadmap/schemas/voxel/voxel-v3.schema.json"
    },
    {
      "nodeType": "pm-decision",
      "urnPattern": "urn:luhtech:{project}:pm-decision:{decisionId}",
      "idPattern": "^DEC-[0-9]{4}-[0-9]{4}$",
      "scope": "project",
      "description": "Construction decision record",
      "schemaRef": ".roadmap/schemas/decision/pm-decision.schema.json"
    },
    {
      "nodeType": "schedule-proposal",
      "urnPattern": "urn:luhtech:{project}:schedule-proposal:{proposalId}",
      "idPattern": "^PROP-[0-9]{4}-[0-9]{4}$",
      "scope": "project",
      "description": "Look-ahead modification request",
      "schemaRef": ".roadmap/schemas/schedule/schedule-proposal-v3.schema.json"
    },
    {
      "nodeType": "consequence",
      "urnPattern": "urn:luhtech:{project}:consequence:{consequenceId}",
      "idPattern": "^CONSQ-[0-9]{4}-[0-9]{4}$",
      "scope": "project",
      "description": "Decision outcome/downstream effect",
      "schemaRef": ".roadmap/schemas/consequence/consequence-v3.schema.json"
    },
    {
      "nodeType": "inspection",
      "urnPattern": "urn:luhtech:{project}:inspection:{inspectionId}",
      "idPattern": "^INSP-[0-9]{4}-[0-9]{4}$",
      "scope": "project",
      "description": "Field inspection record",
      "schemaRef": ".roadmap/schemas/inspection/inspection.schema.json"
    },
    {
      "nodeType": "participant",
      "urnPattern": "urn:luhtech:{project}:participant:{participantId}",
      "idPattern": "^[a-z0-9-]+$",
      "scope": "project",
      "description": "Project stakeholder reference"
    },
    {
      "nodeType": "authority-level",
      "urnPattern": "urn:luhtech:{venture}:authority-level:{levelId}",
      "idPattern": "^pm-level-[0-6]$",
      "scope": "venture",
      "description": "Authority tier definition",
      "schemaRef": ".roadmap/schemas/authority/authority-level.schema.json"
    }
  ],
  "edgeTypes": [
    {
      "edgeType": "contains",
      "fromNode": "voxel",
      "toNode": "pm-decision",
      "cardinality": "1:N",
      "description": "Voxel contains multiple decisions"
    },
    {
      "edgeType": "triggers",
      "fromNode": "pm-decision",
      "toNode": "consequence",
      "cardinality": "1:N",
      "description": "Decision causes consequences"
    },
    {
      "edgeType": "proposes",
      "fromNode": "pm-decision",
      "toNode": "schedule-proposal",
      "cardinality": "1:N",
      "description": "Decision proposes schedule changes"
    },
    {
      "edgeType": "escalates-to",
      "fromNode": "pm-decision",
      "toNode": "pm-decision",
      "cardinality": "1:1",
      "description": "Decision escalated to higher authority"
    },
    {
      "edgeType": "validates",
      "fromNode": "inspection",
      "toNode": "pm-decision",
      "cardinality": "1:N",
      "description": "Inspection validates decision compliance"
    },
    {
      "edgeType": "authored-by",
      "fromNode": "pm-decision",
      "toNode": "participant",
      "cardinality": "N:1",
      "description": "Decision authored by participant"
    },
    {
      "edgeType": "approved-by",
      "fromNode": "pm-decision",
      "toNode": "participant",
      "cardinality": "N:1",
      "description": "Decision approved by participant"
    },
    {
      "edgeType": "affects",
      "fromNode": "consequence",
      "toNode": "voxel",
      "cardinality": "N:M",
      "description": "Consequence affects voxel area(s)"
    },
    {
      "edgeType": "adjacent-to",
      "fromNode": "voxel",
      "toNode": "voxel",
      "cardinality": "N:M",
      "description": "Spatial adjacency for propagation"
    },
    {
      "edgeType": "depends-on",
      "fromNode": "voxel",
      "toNode": "voxel",
      "cardinality": "N:M",
      "description": "Work dependency (predecessor/successor)"
    },
    {
      "edgeType": "supersedes",
      "fromNode": "pm-decision",
      "toNode": "pm-decision",
      "cardinality": "1:1",
      "description": "Decision replaces previous decision"
    },
    {
      "edgeType": "references",
      "fromNode": "pm-decision",
      "toNode": "pm-decision",
      "cardinality": "N:M",
      "description": "Non-causal decision association"
    }
  ],
  "authorityCascade": {
    "description": "7-tier authority cascade for decision routing",
    "levels": [
      {
        "level": 0,
        "name": "FIELD",
        "title": "Field Worker",
        "budgetLimit": 0,
        "varianceTolerance": "0\"",
        "scheduleAuthority": "0 days",
        "scheduleAuthorityHours": 0,
        "autoApprove": true,
        "urn": "urn:luhtech:ectropy:authority-level:pm-level-0",
        "permissions": ["CAPTURE_DECISION"]
      },
      {
        "level": 1,
        "name": "FOREMAN",
        "title": "Foreman",
        "budgetLimit": 500,
        "varianceTolerance": "1/8\"",
        "scheduleAuthority": "4 hours",
        "scheduleAuthorityHours": 4,
        "autoApprove": false,
        "urn": "urn:luhtech:ectropy:authority-level:pm-level-1",
        "permissions": [
          "CAPTURE_DECISION",
          "APPROVE_DECISION",
          "REJECT_DECISION",
          "ESCALATE_DECISION"
        ]
      },
      {
        "level": 2,
        "name": "SUPERINTENDENT",
        "title": "Superintendent",
        "budgetLimit": 5000,
        "varianceTolerance": "1/4\"",
        "scheduleAuthority": "1 day",
        "scheduleAuthorityHours": 24,
        "autoApprove": false,
        "urn": "urn:luhtech:ectropy:authority-level:pm-level-2",
        "permissions": [
          "CAPTURE_DECISION",
          "APPROVE_DECISION",
          "REJECT_DECISION",
          "ESCALATE_DECISION",
          "CREATE_TOLERANCE_OVERRIDE",
          "MODIFY_SCHEDULE",
          "REQUEST_INSPECTION"
        ]
      },
      {
        "level": 3,
        "name": "PM",
        "title": "Project Manager",
        "budgetLimit": 50000,
        "varianceTolerance": "1/2\"",
        "scheduleAuthority": "1 week",
        "scheduleAuthorityHours": 168,
        "autoApprove": false,
        "urn": "urn:luhtech:ectropy:authority-level:pm-level-3",
        "permissions": [
          "CAPTURE_DECISION",
          "APPROVE_DECISION",
          "REJECT_DECISION",
          "ESCALATE_DECISION",
          "CREATE_TOLERANCE_OVERRIDE",
          "CREATE_PRE_APPROVAL",
          "MODIFY_SCHEDULE",
          "REQUEST_INSPECTION"
        ]
      },
      {
        "level": 4,
        "name": "ARCHITECT",
        "title": "Architect/Engineer",
        "budgetLimit": "design",
        "varianceTolerance": "visible",
        "scheduleAuthority": "2 weeks",
        "scheduleAuthorityHours": 336,
        "autoApprove": false,
        "urn": "urn:luhtech:ectropy:authority-level:pm-level-4",
        "permissions": [
          "APPROVE_DECISION",
          "REJECT_DECISION",
          "ESCALATE_DECISION",
          "APPROVE_DESIGN_CHANGE"
        ]
      },
      {
        "level": 5,
        "name": "OWNER",
        "title": "Owner Representative",
        "budgetLimit": "project",
        "varianceTolerance": "major",
        "scheduleAuthority": "1 month",
        "scheduleAuthorityHours": 720,
        "autoApprove": false,
        "urn": "urn:luhtech:ectropy:authority-level:pm-level-5",
        "permissions": [
          "APPROVE_DECISION",
          "REJECT_DECISION",
          "ESCALATE_DECISION"
        ]
      },
      {
        "level": 6,
        "name": "REGULATORY",
        "title": "Authority Having Jurisdiction",
        "budgetLimit": "code",
        "varianceTolerance": "safety",
        "scheduleAuthority": "any",
        "scheduleAuthorityHours": null,
        "autoApprove": false,
        "urn": "urn:luhtech:ectropy:authority-level:pm-level-6",
        "permissions": [
          "APPROVE_DECISION",
          "REJECT_DECISION",
          "APPROVE_CODE_VARIANCE",
          "COMPLETE_INSPECTION"
        ]
      }
    ],
    "escalationRules": [
      {
        "id": "budget-exceeded",
        "trigger": "BUDGET_EXCEEDED",
        "description": "Budget impact exceeds current authority limit",
        "thresholds": [
          { "minBudget": 0, "maxBudget": 500, "requiredLevel": 1 },
          { "minBudget": 500, "maxBudget": 5000, "requiredLevel": 2 },
          { "minBudget": 5000, "maxBudget": 50000, "requiredLevel": 3 },
          { "minBudget": 50000, "maxBudget": null, "requiredLevel": 5 }
        ]
      },
      {
        "id": "schedule-exceeded",
        "trigger": "SCHEDULE_EXCEEDED",
        "description": "Schedule delay exceeds current authority limit",
        "thresholds": [
          { "minHours": 0, "maxHours": 4, "requiredLevel": 1 },
          { "minHours": 4, "maxHours": 24, "requiredLevel": 2 },
          { "minHours": 24, "maxHours": 168, "requiredLevel": 3 },
          { "minHours": 168, "maxHours": 336, "requiredLevel": 4 },
          { "minHours": 336, "maxHours": 720, "requiredLevel": 5 },
          { "minHours": 720, "maxHours": null, "requiredLevel": 5 }
        ]
      },
      {
        "id": "safety-concern",
        "trigger": "SAFETY_CONCERN",
        "description": "Safety-critical issue requires regulatory authority",
        "requiredLevel": 6
      },
      {
        "id": "design-change",
        "trigger": "DESIGN_CHANGE",
        "description": "Design modification requires architect approval",
        "requiredLevel": 4
      },
      {
        "id": "code-variance",
        "trigger": "CODE_VARIANCE",
        "description": "Building code variance requires regulatory authority",
        "requiredLevel": 6
      }
    ]
  },
  "voxelAttachmentTypes": [
    {
      "type": "PRIMARY",
      "description": "Decision originated at this voxel"
    },
    {
      "type": "AFFECTED",
      "description": "Decision impacts this voxel (consequence propagation zone)"
    },
    {
      "type": "ADJACENT",
      "description": "Adjacent voxel for awareness (spatial proximity notification)"
    },
    {
      "type": "DOWNSTREAM",
      "description": "Decision affects future work (schedule dependency)"
    }
  ],
  "traversalPatterns": {
    "findVoxelDecisions": {
      "description": "Find all decisions for a voxel",
      "startNode": "voxel",
      "direction": "out",
      "edgeTypes": ["contains"],
      "filterNodeTypes": ["pm-decision"]
    },
    "traceConsequenceRootCause": {
      "description": "Trace consequence back to root decision",
      "startNode": "consequence",
      "direction": "in",
      "edgeTypes": ["triggers"],
      "maxDepth": 10
    },
    "getEscalationPath": {
      "description": "Get escalation history for a decision",
      "startNode": "pm-decision",
      "direction": "out",
      "edgeTypes": ["escalates-to"],
      "maxDepth": 6
    },
    "findAffectedVoxels": {
      "description": "Find all voxels affected by a consequence",
      "startNode": "consequence",
      "direction": "out",
      "edgeTypes": ["affects"],
      "filterNodeTypes": ["voxel"]
    }
  },
  "graphMetadata": {
    "inEdges": ["urn:luhtech:ectropy:feature:decision-lifecycle"],
    "outEdges": []
  }
}
