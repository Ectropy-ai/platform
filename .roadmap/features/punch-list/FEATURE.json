  "featureId": "punch-list-management",
  "name": "Punch List Management",
  "version": "1.0.0",
  "status": "PLANNED",
  "priority": "MEDIUM",
  "owner": "Team",
  "repository": "luhtech/Ectropy",
  "targetRelease": "2026-09-01",
  "schemaVersion": "3.0.0",
  "meta": {
    "sourceOfTruth": ".roadmap/features/punch-list/FEATURE.json",
    "lastUpdated": "2026-01-16T00:00:00Z"
  },
  "description": "Spatially-organized punch list management with voxel attachment, photo verification, and SMS-based field worker interaction. Transform punch list from spreadsheet chaos into navigable 3D resolution workflow.",
  "coreInnovation": {
    "before": {
      "creation": "Walk building with clipboard, manual data entry",
      "assignment": "Email/phone to subcontractors",
      "tracking": "Spreadsheet updates, manual status calls",
      "verification": "Re-walk building, visual inspection only"
    },
    "after": {
      "creation": "Tap location in 3D model, voice note, auto-categorize",
      "assignment": "SMS to worker with exact voxel location",
      "tracking": "Real-time dashboard, automated reminders",
      "verification": "Photo with GPS/timestamp validation"
    }
  },
  "value": {
    "creationTimeReduction": "80% faster punch list creation",
    "assignmentCommunication": "Instant SMS vs hours of calls",
    "resolutionTracking": "Real-time vs daily spreadsheet updates",
    "verificationConfidence": "Photo + GPS proof vs visual memory",
    "differentiator": "Voxel-attached punch items with SMS workflow"
  },
  "milestones": [
    {
      "id": "M1",
      "name": "Punch Item Database & Schema",
      "targetDate": "2026-07-15",
      "status": "NOT_STARTED",
      "description": "Database infrastructure for punch list items",
      "deliverables": [
        "Prisma model for PunchItem (extends closeout schema)",
        "Database migrations",
        "Category taxonomy (architectural, mechanical, electrical, etc.)",
        "Priority levels and SLA definitions"
      ]
    },
    {
      "id": "M2",
      "name": "Punch List Creation UI",
      "targetDate": "2026-08-01",
      "status": "NOT_STARTED",
      "description": "Interface for creating and managing punch items",
      "deliverables": [
        "3D model click-to-create workflow",
        "Voice note transcription",
        "Photo attachment with auto-location",
        "Batch import from G704 walkthrough",
        "Category auto-suggestion"
      ]
    },
    {
      "id": "M3",
      "name": "SMS Assignment Workflow",
      "targetDate": "2026-08-15",
      "status": "NOT_STARTED",
      "description": "SMS-based assignment and completion workflow",
      "deliverables": [
        "Twilio integration for punch SMS",
        "Worker SMS acknowledgment flow",
        "Completion photo submission via SMS",
        "Automated reminder sequences",
        "Escalation for overdue items"
      ]
    },
    {
      "id": "M4",
      "name": "MCP Tools & Verification",
      "targetDate": "2026-09-01",
      "status": "NOT_STARTED",
      "description": "MCP tools and photo verification system",
      "deliverables": [
        "create_punch_item_tool",
        "update_punch_item_tool",
        "assign_punch_item_tool",
        "validate_punch_completion_tool",
        "GPS/timestamp validation logic",
        "Before/after photo comparison"
      ]
    }
  ],
