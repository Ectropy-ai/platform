  "priorityLevels": [
    {
      "level": "CRITICAL",
      "slaHours": 24,
      "description": "Life safety or prevents occupancy"
    },
    {
      "level": "HIGH",
      "slaHours": 72,
      "description": "Functional issue or visible defect"
    },
    {
