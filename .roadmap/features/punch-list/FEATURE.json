  "smsWorkflow": {
    "description": "SMS-based punch item lifecycle",
    "messages": {
      "assignment": "PUNCH #{id}: {description} at {location}. Reply ACCEPT to confirm. SLA: {slaHours}hrs",
      "reminder": "REMINDER: PUNCH #{id} due in {hoursRemaining}hrs. Reply DONE + photo when complete.",
      "completion": "PUNCH #{id} marked complete. Send photo for verification.",
      "verified": "PUNCH #{id} VERIFIED. Thank you!",
      "rejected": "PUNCH #{id} NOT VERIFIED: {reason}. Please rework and resubmit photo."
    },
    "responses": {
      "ACCEPT": "Worker accepts assignment",
      "DONE": "Worker claims completion",
      "HELP": "Request assistance or clarification",
      "DELAY": "Request deadline extension"
    }
  },
  "dependencies": {
    "schemas": [".roadmap/schemas/closeout/punch-item.schema.json"],
    "features": ["decision-lifecycle", "closeout"],
    "services": ["api-gateway", "postgresql", "twilio-sms", "file-storage"]
  },
  "integrations": {
    "voxels": {
      "description": "Punch items attached to voxel locations",
      "edgeType": "LOCATED_IN",
      "bidirectional": true
    },
    "closeout": {
      "description": "Punch completion drives closeout phase",
      "dependency": "All critical/high items must be complete for final completion"
    },
    "sms": {
      "description": "Twilio integration for worker communication",
      "provider": "Twilio",
      "features": ["assignment", "reminders", "photo submission"]
    },
    "decisions": {
      "description": "Punch items can trigger PM decisions for scope questions",
      "edgeType": "TRIGGERS",
      "bidirectional": true
    }
  },
