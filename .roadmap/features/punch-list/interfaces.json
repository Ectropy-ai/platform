{
  "$schema": "https://luhtech.dev/schemas/interfaces.schema.json",
  "$id": "urn:luhtech:ectropy:interfaces:punch-list",
  "schemaVersion": "3.0.0",
  "meta": {
    "ventureId": "ectropy",
    "featureId": "punch-list-management",
    "createdAt": "2026-01-16T00:05:00Z",
    "lastUpdated": "2026-01-16T00:05:00Z",
    "author": "erik",
    "sourceDoc": ".roadmap/features/punch-list/interfaces.json"
  },
  "summary": "MCP tools for punch list management - 4 tools for creation, updates, assignment, and photo-verified completion",
  "mcpTools": {
    "totalCount": 4,
    "categories": [
      {
        "name": "Punch List Operations",
        "tools": [
          {
            "name": "create_punch_item_tool",
            "description": "Create a voxel-attached punch list item from walkthrough or inspection",
            "authorityRequired": 1,
            "input": {
              "closeoutUrn": {
                "type": "urn",
                "required": true,
                "description": "Reference to project closeout"
              },
              "voxelUrn": {
                "type": "urn",
                "required": true,
                "description": "Voxel location of punch item"
              },
              "title": {
                "type": "string",
                "required": true,
                "minLength": 5,
                "maxLength": 200,
                "description": "Brief description of punch item"
              },
              "description": {
                "type": "string",
                "description": "Detailed description of deficiency"
              },
              "category": {
                "type": "enum",
                "values": [
                  "ARCHITECTURAL",
                  "MECHANICAL",
                  "ELECTRICAL",
                  "SPECIALTY",
                  "LIFE_SAFETY"
                ],
                "required": true,
                "description": "Primary category"
              },
              "subcategory": {
                "type": "string",
                "description": "Subcategory (e.g., 'Paint', 'HVAC')"
              },
              "priority": {
                "type": "enum",
                "values": ["CRITICAL", "HIGH", "MEDIUM", "LOW"],
                "required": true,
                "description": "Priority level with SLA implications"
              },
              "identifiedBy": {
                "type": "urn",
                "required": true,
                "description": "Participant who identified the item"
              },
              "identifiedAt": {
                "type": "datetime",
                "description": "When item was identified (defaults to now)"
              },
              "responsibleTrade": {
                "type": "string",
                "description": "Trade responsible for resolution"
              },
              "responsiblePartyUrn": {
                "type": "urn",
                "description": "Specific party responsible"
              },
              "photos": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "uri": { "type": "string", "format": "uri" },
                    "description": { "type": "string" },
                    "timestamp": { "type": "datetime" },
                    "gpsCoordinates": {
                      "type": "object",
                      "properties": {
                        "latitude": { "type": "number" },
                        "longitude": { "type": "number" }
                      }
                    }
                  }
                },
                "description": "Photos documenting the deficiency"
              },
              "voiceNote": {
                "type": "object",
                "properties": {
                  "uri": { "type": "string", "format": "uri" },
                  "transcription": { "type": "string" },
                  "duration": { "type": "number" }
                },
                "description": "Voice note with auto-transcription"
              },
              "estimatedCost": {
                "type": "number",
                "description": "Estimated cost to resolve"
              },
              "relatedDecisionUrn": {
                "type": "urn",
                "description": "PM decision that may have caused this"
              },
              "tags": {
                "type": "array",
                "items": "string",
                "description": "Additional tags for filtering"
              }
            },
            "output": {
              "punchItem": {
                "type": "PunchItem",
                "description": "Created punch item"
              },
              "punchItemUrn": {
                "type": "urn"
              },
              "slaDeadline": {
                "type": "datetime",
                "description": "Calculated SLA deadline based on priority"
              },
              "closeoutImpact": {
                "type": "object",
                "properties": {
                  "totalItems": { "type": "integer" },
                  "criticalItems": { "type": "integer" },
                  "blocksCompletion": { "type": "boolean" }
                }
              },
              "suggestedAssignment": {
                "type": "object",
                "properties": {
                  "trade": { "type": "string" },
                  "partyUrn": { "type": "urn" },
                  "partyName": { "type": "string" },
                  "confidence": { "type": "number" }
                },
                "description": "AI-suggested responsible party"
              }
            }
          },
          {
            "name": "update_punch_item_tool",
            "description": "Update punch item status, description, or metadata",
            "authorityRequired": 1,
            "input": {
              "punchItemUrn": {
                "type": "urn",
                "required": true,
                "description": "URN of punch item to update"
              },
              "status": {
                "type": "enum",
                "values": [
                  "OPEN",
                  "ASSIGNED",
                  "IN_PROGRESS",
                  "PENDING_VERIFICATION",
                  "VERIFIED",
                  "REJECTED",
                  "DEFERRED"
                ],
                "description": "New status"
              },
              "priority": {
                "type": "enum",
                "values": ["CRITICAL", "HIGH", "MEDIUM", "LOW"],
                "description": "Updated priority"
              },
              "description": {
                "type": "string",
                "description": "Updated description"
              },
              "estimatedCost": {
                "type": "number",
                "description": "Updated cost estimate"
              },
              "deferralReason": {
                "type": "string",
                "description": "Reason for deferral (required if status=DEFERRED)"
              },
              "deferUntil": {
                "type": "date",
                "description": "Date to revisit deferred item"
              },
              "notes": {
                "type": "string",
                "description": "Additional notes"
              },
              "updatedBy": {
                "type": "urn",
                "required": true,
                "description": "Participant making update"
              }
            },
            "output": {
              "punchItem": {
                "type": "PunchItem",
                "description": "Updated punch item"
              },
              "previousStatus": {
                "type": "string"
              },
              "slaImpact": {
                "type": "object",
                "properties": {
                  "previousDeadline": { "type": "datetime" },
                  "newDeadline": { "type": "datetime" },
                  "slaChanged": { "type": "boolean" }
                }
              },
              "historyEntry": {
                "type": "object",
                "properties": {
                  "changedAt": { "type": "datetime" },
                  "changedBy": { "type": "urn" },
                  "changes": { "type": "array", "items": "string" }
                }
              }
            }
          },
          {
            "name": "assign_punch_item_tool",
            "description": "Assign punch item to a trade worker with SMS notification",
            "authorityRequired": 2,
            "input": {
              "punchItemUrn": {
                "type": "urn",
                "required": true,
                "description": "URN of punch item to assign"
              },
              "assigneeUrn": {
                "type": "urn",
                "required": true,
                "description": "Participant to assign to"
              },
              "assigneePhone": {
                "type": "string",
                "description": "Phone number for SMS (uses participant profile if omitted)"
              },
              "deadline": {
                "type": "datetime",
                "description": "Custom deadline (uses SLA if omitted)"
              },
              "instructions": {
                "type": "string",
                "description": "Additional instructions for worker"
              },
              "notificationMethod": {
                "type": "enum",
                "values": ["SMS", "EMAIL", "PUSH", "ALL"],
                "default": "SMS",
                "description": "How to notify assignee"
              },
              "reminderSchedule": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "hoursBeforeDeadline": { "type": "integer" },
                    "method": {
                      "type": "enum",
                      "values": ["SMS", "EMAIL", "PUSH"]
                    }
                  }
                },
                "description": "Reminder schedule (default: 24h, 4h before deadline)"
              },
              "assignedBy": {
                "type": "urn",
                "required": true,
                "description": "Participant making assignment"
              }
            },
            "output": {
              "punchItem": {
                "type": "PunchItem",
                "description": "Updated punch item with assignment"
              },
              "assignment": {
                "type": "object",
                "properties": {
                  "assigneeUrn": { "type": "urn" },
                  "assigneeName": { "type": "string" },
                  "assignedAt": { "type": "datetime" },
                  "deadline": { "type": "datetime" }
                }
              },
              "notificationsSent": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "method": { "type": "string" },
                    "destination": { "type": "string" },
                    "sent": { "type": "boolean" },
                    "messageId": { "type": "string" }
                  }
                }
              },
              "smsConversationUrn": {
                "type": "urn",
                "description": "URN of SMS conversation for tracking"
              },
              "remindersScheduled": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "scheduledFor": { "type": "datetime" },
                    "method": { "type": "string" }
                  }
                }
              }
            }
          },
          {
            "name": "validate_punch_completion_tool",
            "description": "Validate punch item completion with photo verification and GPS/timestamp validation",
            "authorityRequired": 2,
            "input": {
              "punchItemUrn": {
                "type": "urn",
                "required": true,
                "description": "URN of punch item to validate"
              },
              "completionPhotos": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "uri": { "type": "string", "format": "uri" },
                    "timestamp": { "type": "datetime" },
                    "gpsCoordinates": {
                      "type": "object",
                      "properties": {
                        "latitude": { "type": "number" },
                        "longitude": { "type": "number" }
                      }
                    },
                    "deviceId": { "type": "string" }
                  }
                },
                "required": true,
                "minItems": 1,
                "description": "Photos proving completion"
              },
              "validatedBy": {
                "type": "urn",
                "required": true,
                "description": "Participant validating completion"
              },
              "validationType": {
                "type": "enum",
                "values": [
                  "VISUAL_ONLY",
                  "PHOTO_VERIFIED",
                  "INSPECTOR_VERIFIED",
                  "OWNER_ACCEPTED"
                ],
                "default": "PHOTO_VERIFIED",
                "description": "Level of validation"
              },
              "autoValidateGps": {
                "type": "boolean",
                "default": true,
                "description": "Auto-verify GPS matches voxel location"
              },
              "autoValidateTimestamp": {
                "type": "boolean",
                "default": true,
                "description": "Auto-verify timestamp is after assignment"
              },
              "notes": {
                "type": "string",
                "description": "Validation notes"
              },
              "rejection": {
                "type": "object",
                "properties": {
                  "reject": { "type": "boolean" },
                  "reason": { "type": "string" },
                  "requiresRework": { "type": "boolean" },
                  "reworkInstructions": { "type": "string" }
                },
                "description": "Rejection details if not accepting"
              }
            },
            "output": {
              "punchItem": {
                "type": "PunchItem",
                "description": "Updated punch item"
              },
              "validationResult": {
                "type": "object",
                "properties": {
                  "status": {
                    "type": "enum",
                    "values": ["VERIFIED", "REJECTED", "PENDING_REVIEW"]
                  },
                  "gpsValidation": {
                    "type": "object",
                    "properties": {
                      "passed": { "type": "boolean" },
                      "distanceFromVoxel": { "type": "number" },
                      "threshold": { "type": "number" }
                    }
                  },
                  "timestampValidation": {
                    "type": "object",
                    "properties": {
                      "passed": { "type": "boolean" },
                      "photoTimestamp": { "type": "datetime" },
                      "assignmentTimestamp": { "type": "datetime" }
                    }
                  },
                  "visualComparison": {
                    "type": "object",
                    "properties": {
                      "beforePhotoUrn": { "type": "string" },
                      "afterPhotoUrn": { "type": "string" },
                      "changeDetected": { "type": "boolean" }
                    }
                  }
                }
              },
              "closeoutImpact": {
                "type": "object",
                "properties": {
                  "remainingItems": { "type": "integer" },
                  "criticalRemaining": { "type": "integer" },
                  "completionPercentage": { "type": "number" },
                  "canProceedToFinal": { "type": "boolean" }
                }
              },
              "notificationsSent": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "recipient": { "type": "string" },
                    "method": { "type": "string" },
                    "message": { "type": "string" }
                  }
                },
                "description": "Notifications sent (to worker on rejection, to PM on completion)"
              },
              "slaMetrics": {
                "type": "object",
                "properties": {
                  "deadline": { "type": "datetime" },
                  "completedAt": { "type": "datetime" },
                  "withinSla": { "type": "boolean" },
                  "hoursOverUnder": { "type": "number" }
                }
              }
            }
          }
        ]
      }
    ]
  },
  "restApi": {
    "baseUrl": "/api/punch-list",
    "endpoints": [
      {
        "method": "GET",
        "path": "/closeouts/:closeoutUrn/items",
        "description": "List punch items for closeout",
        "authorityRequired": 0,
        "queryParams": ["status", "category", "priority", "assignee", "trade"]
      },
      {
        "method": "POST",
        "path": "/items",
        "description": "Create punch item",
        "authorityRequired": 1,
        "requestBody": "CreatePunchItemRequest",
        "response": "PunchItemResponse"
      },
      {
        "method": "GET",
        "path": "/items/:urn",
        "description": "Get punch item by URN",
        "authorityRequired": 0
      },
      {
        "method": "PUT",
        "path": "/items/:urn",
        "description": "Update punch item",
        "authorityRequired": 1,
        "requestBody": "UpdatePunchItemRequest"
      },
      {
        "method": "POST",
        "path": "/items/:urn/assign",
        "description": "Assign punch item",
        "authorityRequired": 2,
        "requestBody": "AssignPunchItemRequest",
        "response": "AssignmentResponse"
      },
      {
        "method": "POST",
        "path": "/items/:urn/complete",
        "description": "Mark item as pending verification",
        "authorityRequired": 0
      },
      {
        "method": "POST",
        "path": "/items/:urn/validate",
        "description": "Validate punch item completion",
        "authorityRequired": 2,
        "requestBody": "ValidatePunchRequest",
        "response": "ValidationResponse"
      },
      {
        "method": "POST",
        "path": "/items/:urn/defer",
        "description": "Defer punch item",
        "authorityRequired": 3
      },
      {
        "method": "GET",
        "path": "/items/:urn/history",
        "description": "Get punch item history",
        "authorityRequired": 0
      },
      {
        "method": "GET",
        "path": "/closeouts/:closeoutUrn/summary",
        "description": "Get punch list summary",
        "authorityRequired": 0
      },
      {
        "method": "POST",
        "path": "/closeouts/:closeoutUrn/batch-assign",
        "description": "Batch assign items by trade",
        "authorityRequired": 2
      },
      {
        "method": "POST",
        "path": "/sms/webhook",
        "description": "Twilio SMS webhook for worker responses",
        "authorityRequired": null,
        "note": "Authenticated via Twilio signature"
      }
    ]
  },
  "smsWebhooks": {
    "description": "Twilio webhook handlers for SMS workflow",
    "inbound": {
      "endpoint": "/api/punch-list/sms/webhook",
      "handlers": [
        {
          "trigger": "ACCEPT",
          "action": "Update item status to ASSIGNED, confirm to worker"
        },
        {
          "trigger": "DONE",
          "action": "Update status to PENDING_VERIFICATION, request photo"
        },
        {
          "trigger": "PHOTO_RECEIVED",
          "action": "Attach photo, trigger validation workflow"
        },
        {
          "trigger": "HELP",
          "action": "Escalate to PM, send clarification request"
        },
        {
          "trigger": "DELAY",
          "action": "Log delay request, notify PM for approval"
        }
      ]
    },
    "outbound": {
      "templates": [
        {
          "name": "ASSIGNMENT",
          "template": "PUNCH #{id}: {title} at {location}. {description}. Reply ACCEPT to confirm. Deadline: {deadline}"
        },
        {
          "name": "REMINDER_24H",
          "template": "REMINDER: PUNCH #{id} due tomorrow. Reply DONE + send photo when complete."
        },
        {
          "name": "REMINDER_4H",
          "template": "URGENT: PUNCH #{id} due in 4 hours. Complete ASAP and send photo."
        },
        {
          "name": "OVERDUE",
          "template": "OVERDUE: PUNCH #{id} is past deadline. Please complete immediately or reply DELAY with reason."
        },
        {
          "name": "VERIFIED",
          "template": "VERIFIED: PUNCH #{id} approved. Great work!"
        },
        {
          "name": "REJECTED",
          "template": "NOT VERIFIED: PUNCH #{id} - {reason}. Please rework and send new photo."
        }
      ]
    }
  },
  "webhooks": [
    {
      "event": "punch_item.created",
      "description": "Fired when punch item is created",
      "payload": "PunchItemEvent"
    },
    {
      "event": "punch_item.assigned",
      "description": "Fired when item is assigned",
      "payload": "PunchAssignmentEvent"
    },
    {
      "event": "punch_item.accepted",
      "description": "Fired when worker accepts assignment via SMS",
      "payload": "PunchAcceptEvent"
    },
    {
      "event": "punch_item.completed",
      "description": "Fired when worker marks complete",
      "payload": "PunchCompletionEvent"
    },
    {
      "event": "punch_item.verified",
      "description": "Fired when completion is verified",
      "payload": "PunchVerificationEvent"
    },
    {
      "event": "punch_item.rejected",
      "description": "Fired when completion is rejected",
      "payload": "PunchRejectionEvent"
    },
    {
      "event": "punch_item.overdue",
      "description": "Fired when item passes SLA deadline",
      "payload": "PunchOverdueEvent"
    },
    {
      "event": "punch_list.complete",
      "description": "Fired when all critical/high items verified",
      "payload": "PunchListCompleteEvent"
    }
  ],
  "errorCodes": [
    {
      "code": "PUNCH_ITEM_NOT_FOUND",
      "httpStatus": 404,
      "description": "Punch item URN does not exist"
    },
    {
      "code": "CLOSEOUT_NOT_FOUND",
      "httpStatus": 404,
      "description": "Closeout URN does not exist"
    },
    {
      "code": "VOXEL_NOT_FOUND",
      "httpStatus": 404,
      "description": "Voxel URN does not exist"
    },
    {
      "code": "INSUFFICIENT_AUTHORITY",
      "httpStatus": 403,
      "description": "Authority level too low for operation"
    },
    {
      "code": "ITEM_ALREADY_ASSIGNED",
      "httpStatus": 409,
      "description": "Item already has active assignment"
    },
    {
      "code": "ITEM_ALREADY_VERIFIED",
      "httpStatus": 409,
      "description": "Item already verified"
    },
    {
      "code": "INVALID_STATUS_TRANSITION",
      "httpStatus": 400,
      "description": "Cannot transition to requested status"
    },
    {
      "code": "PHOTO_REQUIRED",
      "httpStatus": 400,
      "description": "Completion photo required for verification"
    },
    {
      "code": "GPS_VALIDATION_FAILED",
      "httpStatus": 400,
      "description": "Photo GPS does not match voxel location"
    },
    {
      "code": "TIMESTAMP_VALIDATION_FAILED",
      "httpStatus": 400,
      "description": "Photo timestamp precedes assignment"
    },
    {
      "code": "SMS_DELIVERY_FAILED",
      "httpStatus": 500,
      "description": "Failed to deliver SMS notification"
    },
    {
      "code": "INVALID_PHONE_NUMBER",
      "httpStatus": 400,
      "description": "Phone number format invalid"
    }
  ],
  "graphMetadata": {
    "inEdges": ["urn:luhtech:ectropy:feature:punch-list-management"],
    "outEdges": []
  }
}
