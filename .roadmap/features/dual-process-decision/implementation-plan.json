  "configurationOptions": [
    {
      "name": "SDI_CRITICAL_THRESHOLD",
      "envVar": "DUAL_PROCESS_SDI_CRITICAL",
      "default": 100,
      "type": "number",
      "description": "SDI below which crisis mode activates"
    },
    {
      "name": "SDI_WARNING_THRESHOLD",
      "envVar": "DUAL_PROCESS_SDI_WARNING",
      "default": 1000,
      "type": "number",
      "description": "SDI below which exploration is constrained"
    },
    {
      "name": "SDI_HEALTHY_THRESHOLD",
      "envVar": "DUAL_PROCESS_SDI_HEALTHY",
      "default": 10000,
      "type": "number",
      "description": "SDI above which normal operations apply"
    },
    {
      "name": "SDI_ABUNDANT_THRESHOLD",
      "envVar": "DUAL_PROCESS_SDI_ABUNDANT",
      "default": 100000,
      "type": "number",
      "description": "SDI above which full exploration is enabled"
    },
    {
      "name": "PATTERN_SIMILARITY_THRESHOLD",
      "envVar": "DUAL_PROCESS_SIMILARITY_THRESHOLD",
      "default": 0.85,
      "type": "number",
      "description": "Minimum eigenmode similarity for pattern matching"
    },
    {
      "name": "PATTERN_DECAY_HALF_LIFE_DAYS",
      "envVar": "DUAL_PROCESS_DECAY_HALF_LIFE",
      "default": 180,
      "type": "number",
      "description": "Half-life for pattern confidence decay"
    },
    {
      "name": "PATTERN_PRUNE_THRESHOLD",
      "envVar": "DUAL_PROCESS_PRUNE_THRESHOLD",
      "default": 0.1,
      "type": "number",
      "description": "Confidence below which patterns are pruned"
    },
    {
      "name": "EXPLORATION_BUDGET_SDI_WEIGHT",
      "envVar": "DUAL_PROCESS_BUDGET_SDI_WEIGHT",
      "default": 0.4,
      "type": "number",
      "description": "Weight of SDI factor in budget calculation"
    },
    {
      "name": "EXPLORATION_BUDGET_STABILITY_WEIGHT",
      "envVar": "DUAL_PROCESS_BUDGET_STABILITY_WEIGHT",
      "default": 0.35,
      "type": "number",
      "description": "Weight of stability factor in budget calculation"
    },
    {
      "name": "EXPLORATION_BUDGET_RESOURCE_WEIGHT",
      "envVar": "DUAL_PROCESS_BUDGET_RESOURCE_WEIGHT",
      "default": 0.25,
      "type": "number",
      "description": "Weight of resource factor in budget calculation"
    },
    {
      "name": "MAX_PATTERN_QUERY_RESULTS",
      "envVar": "DUAL_PROCESS_MAX_PATTERN_RESULTS",
      "default": 10,
      "type": "number",
      "description": "Maximum patterns returned from Success Stack query"
    },
    {
      "name": "ENGINE2_COMPUTATION_DEPTH",
      "envVar": "DUAL_PROCESS_COMPUTATION_DEPTH",
      "default": 3,
      "type": "number",
      "description": "Default search depth for option generation"
    },
    {
      "name": "ENABLE_GLOBAL_PATTERNS",
      "envVar": "DUAL_PROCESS_GLOBAL_PATTERNS",
      "default": true,
      "type": "boolean",
      "description": "Allow patterns to be shared across projects"
    }
  ],
  "openQuestions": [
    {
      "id": "OQ-1",
      "question": "Should pattern decay rate vary by domain (electrical vs. mechanical)?",
      "currentAssumption": "Uniform 180-day half-life",
      "resolutionStrategy": "Calibrate during pilot, add domain-specific decay if needed",
      "priority": "medium"
    },
    {
      "id": "OQ-2",
      "question": "What SDI thresholds work for different project types (commercial vs residential)?",
      "currentAssumption": "Single threshold set, configurable per project",
      "resolutionStrategy": "Collect data during pilot, develop project-type presets",
      "priority": "high"
    },
    {
      "id": "OQ-3",
      "question": "How to handle cross-project pattern sharing with multi-tenant isolation?",
      "currentAssumption": "Global patterns are opt-in, project patterns are isolated",
      "resolutionStrategy": "Privacy review required, implement tenant-aware pattern namespacing",
      "priority": "high"
    },
    {
      "id": "OQ-4",
