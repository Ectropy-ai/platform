      }
    ],
    "extendedTypes": [
      {
        "name": "PMNodeType",
        "file": "apps/mcp-server/src/types/pm.types.ts",
        "additions": [
          "decision-event",
          "success-pattern",
          "sdi-snapshot",
          "monitoring-trigger",
          "exploration-budget",
          "mediation-decision",
          "eigenmode-context",
          "possibility-option"
        ]
      }
    ]
  },
  "databaseModels": {
    "prismaModels": [
      {
        "name": "DecisionEvent",
        "table": "decision_events",
        "fields": [
          { "name": "id", "type": "UUID", "primary": true },
          { "name": "urn", "type": "String", "unique": true },
          { "name": "timestamp", "type": "DateTime" },
          { "name": "projectId", "type": "UUID", "relation": "Project" },
          { "name": "zoneId", "type": "UUID", "nullable": true },
          { "name": "actorId", "type": "String" },
          { "name": "triggerType", "type": "DecisionTriggerType" },
          { "name": "triggerSource", "type": "String" },
          { "name": "triggerUrgency", "type": "Float" },
          { "name": "stateSdi", "type": "Float" },
          { "name": "stateEigenmodes", "type": "Float[]", "length": 12 },
          { "name": "engine1Output", "type": "Json" },
          { "name": "engine2Output", "type": "Json" },
          { "name": "mediation", "type": "Json" },
          { "name": "outcome", "type": "Json", "nullable": true }
        ],
        "indexes": ["projectId", "timestamp", "actorId"]
      },
      {
        "name": "SuccessPattern",
        "table": "success_patterns",
        "fields": [
          { "name": "id", "type": "UUID", "primary": true },
          { "name": "urn", "type": "String", "unique": true },
          { "name": "contextSignature", "type": "Float[]", "length": 12 },
          { "name": "actionType", "type": "String" },
          { "name": "outcomeProfile", "type": "Json" },
          { "name": "confidence", "type": "Float" },
          { "name": "frequency", "type": "Int", "default": 1 },
          { "name": "lastApplied", "type": "DateTime" },
          { "name": "contextBreadth", "type": "Float", "default": 1 },
          { "name": "sourceDecisions", "type": "String[]" },
          { "name": "decayFactor", "type": "Float", "default": 1 },
          { "name": "projectId", "type": "UUID", "nullable": true },
          { "name": "isGlobal", "type": "Boolean", "default": false }
        ],
        "indexes": ["projectId", "actionType", "confidence"]
      },
      {
        "name": "SDISnapshot",
        "table": "sdi_snapshots",
        "fields": [
          { "name": "id", "type": "UUID", "primary": true },
          { "name": "urn", "type": "String", "unique": true },
          { "name": "timestamp", "type": "DateTime" },
          { "name": "projectId", "type": "UUID", "relation": "Project" },
          { "name": "zoneId", "type": "UUID", "nullable": true },
          { "name": "sdiValue", "type": "Float" },
          { "name": "sdiLog", "type": "Float" },
          { "name": "shannonEntropy", "type": "Float" },
          { "name": "classification", "type": "SDIClassification" },
          { "name": "components", "type": "Json" }
        ],
        "indexes": ["projectId", "timestamp", "classification"]
      },
      {
        "name": "MonitoringTrigger",
        "table": "monitoring_triggers",
        "fields": [
          { "name": "id", "type": "UUID", "primary": true },
          { "name": "urn", "type": "String", "unique": true },
          { "name": "decisionEventId", "type": "UUID" },
          { "name": "triggerType", "type": "MonitoringTriggerType" },
          { "name": "conditionMetric", "type": "String" },
          { "name": "conditionOperator", "type": "String" },
          { "name": "conditionThreshold", "type": "Float" },
          { "name": "response", "type": "MonitoringResponse" },
          { "name": "checkIntervalMs", "type": "Int" },
          { "name": "isActive", "type": "Boolean", "default": true },
          { "name": "lastChecked", "type": "DateTime", "nullable": true },
          { "name": "triggeredAt", "type": "DateTime", "nullable": true }
        ],
        "indexes": ["decisionEventId", "isActive"]
      }
    ],
    "prismaEnums": [
      {
        "name": "DecisionTriggerType",
        "values": ["SCHEDULED", "EXCEPTION", "OPPORTUNITY", "ESCALATION"]
      },
      {
        "name": "SDIClassification",
        "values": ["CRITICAL", "WARNING", "HEALTHY", "ABUNDANT"]
      },
      {
        "name": "MonitoringTriggerType",
        "values": ["SDI_BREACH", "TIMELINE_DEVIATION", "RESOURCE_EXHAUSTION", "CASCADE_DETECTION", "CONFIDENCE_COLLAPSE"]
      },
      {
        "name": "MonitoringResponse",
        "values": ["FALLBACK", "ESCALATE", "CONSTRAIN", "RE_MEDIATE"]
      }
    ],
    "migrationFile": "prisma/migrations/20260122_dual_process_decision/migration.sql"
  },
