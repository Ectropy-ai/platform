{
  "$schema": "https://luhtech.dev/schemas/implementation-plan.schema.json",
  "$id": "urn:luhtech:ectropy:implementation:dual-process-decision",
  "schemaVersion": "3.0.0",
  "meta": {
    "ventureId": "ectropy",
    "featureId": "dual-process-decision",
    "createdAt": "2026-01-22T00:00:00Z",
    "lastUpdated": "2026-01-22T00:00:00Z",
    "author": "claude",
    "sourceDoc": ".roadmap/features/dual-process-decision/implementation-plan.json"
  },
  "summary": "Implementation plan for Dual-Process Decision Architecture extending USF with Success Stack, SDI, and explicit arbitration",
  "strategicAlignment": {
    "currentPhase": "5b",
    "phaseName": "Pilot Foundation + EIL",
    "platformProgress": 68,
    "decisionLifecycleStatus": "IN_DEVELOPMENT",
    "decisionLifecycleProgress": 45,
    "efasStatus": "Schema defined, integration pending",
    "targetIntegration": "Post Decision-Lifecycle M3 (Prisma), Pre M4 (GraphQL)"
  },
  "dependencyChain": [
    {
      "dependency": "decision-lifecycle-m3",
      "type": "blocking",
      "description": "Prisma models must be complete",
      "status": "IN_PROGRESS"
    },
    {
      "dependency": "efas-eigenmode-schema",
      "type": "required",
      "description": "Schema defined, needs activation",
      "status": "READY"
    },
    {
      "dependency": "usf-event-handler",
      "type": "required",
      "description": "Extend existing event system",
      "status": "READY"
    },
    {
      "dependency": "authority-cascade",
      "type": "integration",
      "description": "7-tier cascade for escalations",
      "status": "READY"
    }
  ],
  "valueProposition": {
    "problemStatement": "Decision-making expertise remains siloed in individuals and projects, leading to repeated mistakes and inability to scale judgment",
    "solution": "Compress validated decisions into reusable patterns with explicit arbitration between proven paths and novel exploration",
    "targetMetrics": {
      "patternReuseRate": {
        "target": 0.6,
        "description": "60%+ decisions match existing patterns"
      },
      "explorationSuccessRate": {
        "target": 0.4,
        "description": "40%+ exploratory decisions improve on patterns"
      },
      "learningVelocity": {
        "target": 7,
        "unit": "days",
        "description": "New patterns emerge within 7 days of validated outcomes"
      },
      "auditabilityScore": {
        "target": 1.0,
        "description": "100% decisions have rationale documented"
      }
    }
  },
  "serviceArchitecture": {
    "newServices": [
      {
        "name": "SDICalculatorService",
        "file": "apps/mcp-server/src/services/sdi-calculator.service.ts",
        "responsibility": "Compute Solution Density Index and classification",
        "dependencies": ["EFASService", "ResourceService"],
        "exports": [
          "calculateSDI",
          "getSDIThresholds",
          "classifySDI",
          "computeExplorationBudget"
        ]
      },
      {
        "name": "SuccessStackService",
        "file": "apps/mcp-server/src/services/success-stack.service.ts",
        "responsibility": "Engine 1 - Pattern storage and retrieval",
        "dependencies": ["EigenmodeSimilarityService", "PatternCompressionService"],
        "exports": [
          "queryPatterns",
          "getPatternDetails",
          "storePattern",
          "decayPatterns"
        ]
      },
      {
        "name": "PatternCompressionService",
        "file": "apps/mcp-server/src/services/pattern-compression.service.ts",
        "responsibility": "Validate and compress decisions into patterns",
        "dependencies": ["EigenmodeSimilarityService"],
        "exports": [
          "validateForCompression",
          "compressDecision",
          "mergePatterns",
          "prunePatterns"
        ]
      },
      {
        "name": "EigenmodeSimilarityService",
        "file": "apps/mcp-server/src/services/eigenmode-similarity.service.ts",
        "responsibility": "Compute eigenmode vector similarity",
        "dependencies": [],
        "exports": [
          "computeSimilarity",
          "computeContextSignature",
          "computeStability"
        ]
      },
      {
        "name": "PossibilitySpaceService",
        "file": "apps/mcp-server/src/services/possibility-space.service.ts",
        "responsibility": "Engine 2 - Option generation",
        "dependencies": ["SDIProjectorService", "ConstraintService"],
        "exports": [
          "generateOptions",
          "filterByConstraints",
          "computeRiskProfiles"
        ]
      },
      {
        "name": "SDIProjectorService",
        "file": "apps/mcp-server/src/services/sdi-projector.service.ts",
        "responsibility": "Project SDI impact of proposed actions",
        "dependencies": ["SDICalculatorService"],
        "exports": [
          "projectSDIImpact",
          "computeCascadingEffects"
        ]
      },
      {
        "name": "USFMediatorService",
        "file": "apps/mcp-server/src/services/usf-mediator.service.ts",
        "responsibility": "Arbitrate between Engine 1 and Engine 2",
        "dependencies": ["SuccessStackService", "PossibilitySpaceService", "ExplorationBudgetService"],
        "exports": [
          "mediate",
          "selectDecisionPath",
          "generateRationale"
        ]
      },
      {
        "name": "ExplorationBudgetService",
        "file": "apps/mcp-server/src/services/exploration-budget.service.ts",
        "responsibility": "Calculate exploration budget from state",
        "dependencies": ["SDICalculatorService", "EigenmodeSimilarityService"],
        "exports": [
          "computeBudget",
          "getBudgetBreakdown"
        ]
      },
      {
        "name": "MonitoringTriggerService",
        "file": "apps/mcp-server/src/services/monitoring-trigger.service.ts",
        "responsibility": "Manage monitoring triggers for exploratory decisions",
        "dependencies": ["SDICalculatorService"],
        "exports": [
          "createTrigger",
          "checkTriggers",
          "executeTriggerResponse",
          "deactivateTrigger"
        ]
      },
      {
        "name": "DecisionEventHandlerService",
        "file": "apps/mcp-server/src/services/decision-event-handler.service.ts",
        "responsibility": "Handle decision event lifecycle",
        "dependencies": ["USFMediatorService", "PatternCompressionService"],
        "exports": [
          "createDecisionEvent",
          "recordOutcome",
          "triggerCompression"
        ]
      },
      {
        "name": "PatternLearningService",
        "file": "apps/mcp-server/src/services/pattern-learning.service.ts",
        "responsibility": "Orchestrate pattern learning from outcomes",
        "dependencies": ["PatternCompressionService", "SuccessStackService"],
        "exports": [
          "learnFromOutcome",
          "runDecayJob",
          "runPruneJob"
        ]
      }
    ],
    "extendedServices": [
      {
        "name": "USFService",
        "file": "apps/mcp-server/src/services/usf.service.ts",
        "additions": [
          "computeSDIFromUSF",
          "getSDIComponents"
        ]
      },
      {
        "name": "USFEventHandlerService",
        "file": "apps/mcp-server/src/services/usf-event-handler.service.ts",
        "additions": [
          "handleDecisionEventCreated",
          "handleDecisionEventMediated",
          "handlePatternCompressed",
          "handleSDIThresholdBreach"
        ]
      },
      {
        "name": "PMDecisionToolsService",
        "file": "apps/mcp-server/src/services/pm-decision-tools.ts",
        "additions": [
          "calculate_sdi",
          "get_sdi_thresholds",
          "query_success_stack",
          "get_pattern_details",
          "compress_decision_pattern",
          "generate_options",
          "project_sdi_impact",
          "mediate_decision",
          "get_exploration_budget",
          "set_monitoring_trigger",
          "check_monitoring_triggers",
          "record_decision_outcome"
        ]
      }
    ]
  },
  "typeDefinitions": {
