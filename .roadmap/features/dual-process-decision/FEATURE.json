        {
          "priority": 5,
          "name": "Default Blend",
          "condition": "None of above",
          "action": "Weighted blend based on exploration budget",
          "exploration": "budget-dependent"
        }
      ]
    },
    "sdi": {
      "name": "Solution Density Index",
      "range": "10^3 to 10^6",
