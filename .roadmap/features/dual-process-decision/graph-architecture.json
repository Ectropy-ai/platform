{
  "$schema": "https://luhtech.dev/schemas/graph-architecture.schema.json",
  "$id": "urn:luhtech:ectropy:architecture:dual-process-decision-graph",
  "schemaVersion": "3.0.0",
  "meta": {
    "ventureId": "ectropy",
    "featureId": "dual-process-decision",
    "createdAt": "2026-01-22T00:00:00Z",
    "lastUpdated": "2026-01-22T00:00:00Z",
    "author": "claude",
    "sourceDoc": ".roadmap/features/dual-process-decision/graph-architecture.json"
  },
  "summary": "Graph architecture for Dual-Process Decision Architecture - 8 new node types, 14 edge types, extending USF with Success Stack and SDI",
  "nodeTypes": [
    {
      "nodeType": "decision-event",
      "urnPattern": "urn:luhtech:{project}:decision-event:DEV-{YYYY}-{NNNN}",
      "idPattern": "^DEV-[0-9]{4}-[0-9]{4,}$",
      "scope": "project",
      "description": "Full decision event capture with engine outputs and mediation",
      "schemaRef": ".roadmap/schemas/decision/decision-event.schema.json"
    },
    {
      "nodeType": "success-pattern",
      "urnPattern": "urn:luhtech:{project}:success-pattern:PAT-{YYYY}-{NNNN}",
      "idPattern": "^PAT-[0-9]{4}-[0-9]{4,}$",
      "scope": "project",
      "description": "Compressed validated decision pattern for Success Stack",
      "schemaRef": ".roadmap/schemas/decision/success-pattern.schema.json"
    },
    {
      "nodeType": "sdi-snapshot",
      "urnPattern": "urn:luhtech:{project}:sdi-snapshot:SDI-{YYYY}-{NNNN}",
      "idPattern": "^SDI-[0-9]{4}-[0-9]{4,}$",
      "scope": "project",
      "description": "Solution Density Index calculation snapshot",
      "schemaRef": ".roadmap/schemas/decision/sdi-snapshot.schema.json"
    },
    {
      "nodeType": "monitoring-trigger",
      "urnPattern": "urn:luhtech:{project}:monitoring-trigger:MON-{YYYY}-{NNNN}",
      "idPattern": "^MON-[0-9]{4}-[0-9]{4,}$",
      "scope": "project",
      "description": "Active monitoring trigger for exploratory decisions"
    },
    {
      "nodeType": "exploration-budget",
      "urnPattern": "urn:luhtech:{project}:exploration-budget:EXP-{YYYY}-{NNNN}",
      "idPattern": "^EXP-[0-9]{4}-[0-9]{4,}$",
      "scope": "project",
      "description": "Exploration budget allocation record"
    },
    {
      "nodeType": "mediation-decision",
      "urnPattern": "urn:luhtech:{project}:mediation-decision:MED-{YYYY}-{NNNN}",
      "idPattern": "^MED-[0-9]{4}-[0-9]{4,}$",
      "scope": "project",
      "description": "USF Mediator arbitration record"
    },
    {
      "nodeType": "eigenmode-context",
      "urnPattern": "urn:luhtech:{project}:eigenmode-context:EIG-{YYYY}-{NNNN}",
      "idPattern": "^EIG-[0-9]{4}-[0-9]{4,}$",
      "scope": "project",
      "description": "12-element eigenmode state snapshot from EFAS"
    },
    {
      "nodeType": "possibility-option",
      "urnPattern": "urn:luhtech:{project}:possibility-option:OPT-{YYYY}-{NNNN}",
      "idPattern": "^OPT-[0-9]{4}-[0-9]{4,}$",
      "scope": "project",
      "description": "Generated option from Engine 2 (Possibility Space)"
    }
  ],
  "edgeTypes": [
    {
      "edgeType": "triggered-by",
      "fromNode": "decision-event",
      "toNode": "pm-decision",
      "cardinality": "1:1",
      "description": "Decision event triggered by PM decision"
    },
    {
      "edgeType": "captured-sdi",
      "fromNode": "decision-event",
      "toNode": "sdi-snapshot",
      "cardinality": "1:1",
      "description": "Decision event captured SDI at this state"
    },
    {
      "edgeType": "matched-pattern",
      "fromNode": "decision-event",
      "toNode": "success-pattern",
      "cardinality": "N:M",
      "description": "Engine 1 matched these patterns"
    },
    {
      "edgeType": "generated-option",
      "fromNode": "decision-event",
      "toNode": "possibility-option",
      "cardinality": "1:N",
      "description": "Engine 2 generated these options"
    },
    {
      "edgeType": "selected-action",
      "fromNode": "decision-event",
      "toNode": "possibility-option",
      "cardinality": "1:1",
      "description": "Mediation selected this option"
    },
    {
      "edgeType": "compressed-to",
      "fromNode": "decision-event",
      "toNode": "success-pattern",
      "cardinality": "N:1",
      "description": "Validated decision compressed to pattern"
    },
    {
      "edgeType": "monitors",
      "fromNode": "monitoring-trigger",
      "toNode": "decision-event",
      "cardinality": "N:1",
      "description": "Trigger monitors this decision"
    },
    {
      "edgeType": "fallback-to",
      "fromNode": "decision-event",
      "toNode": "success-pattern",
      "cardinality": "1:1",
      "description": "Fallback pattern if exploration fails"
    },
    {
      "edgeType": "similar-to",
      "fromNode": "success-pattern",
      "toNode": "success-pattern",
      "cardinality": "N:M",
      "description": "Eigenmode similarity between patterns"
    },
    {
      "edgeType": "supersedes-pattern",
      "fromNode": "success-pattern",
      "toNode": "success-pattern",
      "cardinality": "1:1",
      "description": "Pattern merged into newer pattern"
    },
    {
      "edgeType": "eigenmode-state",
      "fromNode": "decision-event",
      "toNode": "eigenmode-context",
      "cardinality": "1:1",
      "description": "Eigenmode state at decision time"
    },
    {
      "edgeType": "projects-sdi",
      "fromNode": "possibility-option",
      "toNode": "sdi-snapshot",
      "cardinality": "1:1",
      "description": "Option projects this SDI outcome"
    },
    {
      "edgeType": "escalated-from-mediation",
      "fromNode": "decision-event",
      "toNode": "pm-decision",
      "cardinality": "1:1",
      "description": "Mediation escalated to authority cascade"
    },
    {
      "edgeType": "budget-for",
      "fromNode": "exploration-budget",
      "toNode": "decision-event",
      "cardinality": "1:1",
      "description": "Exploration budget allocated for decision"
    }
  ],
  "dualProcessArchitecture": {
    "description": "Dual-process decision architecture mirroring Kahneman's System 1/System 2",
    "engines": {
      "engine1": {
        "name": "Success Stack",
        "cognitiveParallel": "System 1 (Fast/Intuitive)",
        "function": "Pattern matching against validated decisions",
        "latencyTarget": "50ms",
        "dataSource": "success-pattern nodes",
        "matchingAlgorithm": "Eigenmode cosine similarity",
        "similarityThreshold": 0.85
      },
      "engine2": {
        "name": "Possibility Space",
        "cognitiveParallel": "System 2 (Slow/Deliberative)",
        "function": "Generate all viable options regardless of precedent",
        "latencyTarget": "100ms",
        "dataSource": "Constraint satisfaction + resource availability",
        "generationAlgorithm": "Constraint propagation with SDI projection"
      }
    },
    "mediator": {
      "name": "USF Mediator",
      "function": "Arbitrate between Engine 1 and Engine 2 outputs",
      "decisionPaths": [
        {
          "priority": 1,
          "name": "Crisis Mode",
          "condition": "SDI < SDI_CRITICAL_THRESHOLD",
          "action": "Use Engine 1 only (exploit validated patterns)",
          "explorationAllocation": 0,
          "rationale": "SDI below critical. Constraining to validated patterns."
        },
        {
          "priority": 2,
          "name": "High Confidence Match",
          "condition": "Engine1.confidence > 0.9 AND NOT Engine2.significantlyBetter",
          "action": "Use Engine 1 with minimal exploration",
          "explorationAllocation": 0.1,
          "rationale": "Strong pattern match. No significant improvement from alternatives."
        },
        {
          "priority": 3,
          "name": "Promising Exploration",
          "condition": "Engine2.significantlyBetter AND explorationBudget > 0.3",
          "action": "Use Engine 2 with fallback to Engine 1",
          "explorationAllocation": "budget-dependent",
          "rationale": "Novel option projects improvement. SDI supports exploration.",
          "requiresFallback": true,
          "requiresMonitoring": true
        },
        {
          "priority": 4,
          "name": "No Applicable Patterns",
          "condition": "Engine1.applicablePatterns.length === 0",
          "action": "Escalate or use lowest-risk option",
          "explorationAllocation": 1.0,
          "rationale": "No patterns available. Selecting lowest-risk path or escalating.",
          "mayEscalate": true
        },
        {
          "priority": 5,
          "name": "Default Blend",
          "condition": "None of above",
          "action": "Weighted blend based on exploration budget",
          "explorationAllocation": "budget-dependent",
          "rationale": "Blended decision with exploration weight."
        }
      ]
    }
  },
  "sdiConfiguration": {
    "description": "Solution Density Index - measure of decision space density",
    "mathematicalFoundation": {
      "shannonEntropy": "H = log2(SDI)",
      "interpretation": "Higher SDI = more viable paths = safer to explore"
    },
    "typicalRange": {
      "minimum": 100,
      "maximum": 1000000,
      "logRange": "2-6"
    },
    "thresholds": {
      "critical": {
        "value": 100,
        "action": "Crisis mode - exploit only",
        "explorationBudget": 0
      },
      "warning": {
        "value": 1000,
        "action": "Constrain exploration",
        "explorationBudget": 0.2
      },
      "healthy": {
        "value": 10000,
        "action": "Normal operations",
        "explorationBudget": 0.5
      },
      "abundant": {
        "value": 100000,
        "action": "Full exploration enabled",
        "explorationBudget": 0.8
      }
    },
    "components": [
      {
        "name": "viablePathCount",
        "weight": 0.3,
        "description": "Number of constraint-satisfying decision paths"
      },
      {
        "name": "resourceSlackRatio",
        "weight": 0.25,
        "description": "Available slack in labor, material, equipment, budget"
      },
      {
        "name": "eigenmodeStability",
        "weight": 0.25,
        "description": "Stability of eigenmode vector over recent window"
      },
      {
        "name": "constraintDensity",
        "weight": 0.2,
        "description": "Inverse of active constraint count"
      }
    ]
  },
  "explorationBudgetCalculation": {
    "formula": "(sdiFactor * 0.4) + (stabilityFactor * 0.35) + (resourceFactor * 0.25)",
    "factors": {
      "sdiFactor": {
        "weight": 0.4,
        "calculation": "min(log10(SDI) / 6, 1)",
        "description": "More viable paths = more room to experiment"
      },
      "stabilityFactor": {
        "weight": 0.35,
        "calculation": "eigenmodeStability over 7-day window",
        "description": "Stable eigenmodes = safer to experiment"
      },
      "resourceFactor": {
        "weight": 0.25,
        "calculation": "resourceAvailability.slackRatio",
        "description": "Resource slack enables risk-taking"
      }
    }
  },
  "patternCompression": {
    "description": "Pipeline for compressing validated decisions into reusable patterns",
    "validationGates": [
      {
        "gate": 1,
        "name": "succeeded",
        "description": "Decision achieved desired outcome",
        "requirement": "outcome.success === true"
      },
      {
        "gate": 2,
        "name": "replicable",
        "description": "Context can be matched by eigenmode signature",
        "requirement": "eigenmodeVector variance < threshold"
      },
      {
        "gate": 3,
        "name": "generalizable",
        "description": "Pattern applies beyond single instance",
        "requirement": "contextBreadth > 1 OR similar patterns exist"
      },
      {
        "gate": 4,
        "name": "significant",
        "description": "Outcome improvement justifies pattern storage",
        "requirement": "actualVsProjected > 0.1 OR frequency > 3"
      }
    ],
    "decayMechanism": {
      "halfLifeDays": 180,
      "formula": "confidence * Math.pow(0.5, daysSinceLastApplied / 180)",
      "pruneThreshold": 0.1
    },
    "mergingStrategy": {
      "similarityThreshold": 0.95,
      "action": "Merge into existing pattern, update frequency and confidence"
    }
  },
  "monitoringTriggerTypes": [
    {
      "type": "sdi_breach",
      "description": "SDI drops below threshold",
      "defaultResponse": "fallback",
      "defaultCheckInterval": 60000
    },
    {
      "type": "timeline_deviation",
      "description": "Actual timeline deviates from projected",
      "defaultResponse": "escalate",
      "defaultCheckInterval": 300000
    },
    {
      "type": "resource_exhaustion",
      "description": "Resource availability drops critically",
      "defaultResponse": "constrain",
      "defaultCheckInterval": 120000
    },
    {
      "type": "cascade_detection",
      "description": "Downstream effects exceed projection",
      "defaultResponse": "re_mediate",
      "defaultCheckInterval": 180000
    },
    {
      "type": "confidence_collapse",
      "description": "Pattern confidence drops during execution",
      "defaultResponse": "fallback",
      "defaultCheckInterval": 60000
    }
  ],
  "traversalPatterns": {
    "findApplicablePatterns": {
      "description": "Find patterns matching current eigenmode context",
      "startNode": "eigenmode-context",
      "direction": "similarity-search",
      "edgeTypes": ["similar-to"],
      "filterNodeTypes": ["success-pattern"],
      "similarityThreshold": 0.85
    },
    "tracePatternOrigin": {
      "description": "Trace pattern back to source decisions",
      "startNode": "success-pattern",
      "direction": "in",
      "edgeTypes": ["compressed-to"],
      "filterNodeTypes": ["decision-event"]
    },
    "getDecisionOutcome": {
      "description": "Get outcome of a decision event",
      "startNode": "decision-event",
      "direction": "out",
      "edgeTypes": ["triggered-by"],
      "filterNodeTypes": ["pm-decision"]
    },
    "findMonitoredDecisions": {
      "description": "Find all decisions with active monitoring",
      "startNode": "monitoring-trigger",
      "direction": "out",
      "edgeTypes": ["monitors"],
      "filter": "isActive === true"
    },
    "getSDITrend": {
      "description": "Get SDI snapshots for trend analysis",
      "startNode": "project",
      "direction": "out",
      "edgeTypes": ["captured-sdi"],
      "filterNodeTypes": ["sdi-snapshot"],
      "orderBy": "timestamp",
      "limit": 30
    }
  },
  "integrationPoints": {
    "efas": {
      "description": "EFAS provides 12-element eigenmode vectors for context signatures",
      "schemaRef": ".roadmap/schemas/efas/eigenmode-forecast.schema.json",
      "integration": "computeEigenmodes(projectId) returns EigenmodeVector"
    },
    "usf": {
      "description": "USF provides quality/cost/speed factors",
      "serviceRef": "apps/mcp-server/src/services/usf.service.ts",
      "integration": "Extends USF event system with dual-process events"
    },
    "authorityCascade": {
      "description": "Authority cascade handles escalations from mediation",
      "graphRef": ".roadmap/features/decision-lifecycle/graph-architecture.json",
      "integration": "escalate() routes to 7-tier authority system"
    },
    "decisionLifecycle": {
      "description": "Decision lifecycle provides PM decision foundation",
      "featureRef": ".roadmap/features/decision-lifecycle/FEATURE.json",
      "integration": "decision-event links to pm-decision via triggered-by edge"
    }
  },
  "graphMetadata": {
    "inEdges": [
      "urn:luhtech:ectropy:feature:dual-process-decision",
      "urn:luhtech:ectropy:feature:decision-lifecycle"
    ],
    "outEdges": [
      "urn:luhtech:ectropy:schema:decision:decision-event",
      "urn:luhtech:ectropy:schema:decision:success-pattern",
      "urn:luhtech:ectropy:schema:decision:sdi-snapshot"
    ]
  }
}
