  "schemaExtensions": {
    "roadmapMilestoneV31": {
      "description": "Extended milestone schema with cognitive fields",
      "newFields": {
        "classification": {
          "type": "string",
          "enum": ["LEAD", "DERIVED", "EXTERNAL", "FLEXIBLE"],
          "description": "Atomic Reference Strategy classification",
          "default": "LEAD"
        },
        "healthScore": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "SDI-derived milestone health (0=crisis, 1=abundant)"
        },
        "eigenmodeSnapshot": {
          "type": "array",
          "items": {"type": "number"},
          "minItems": 12,
          "maxItems": 12,
          "description": "Platform eigenmode values at milestone assessment"
        },
        "patternConfidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Success Stack match confidence for approach"
        },
        "explorationBudget": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Permitted exploration for novel approaches"
        },
        "linkedDecisions": {
          "type": "array",
          "items": {"type": "string"},
          "description": "URNs of decisions that drove this milestone"
        },
        "monitoringTriggers": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "type": {"type": "string", "enum": ["SDI_BREACH", "TIMELINE_DEVIATION", "SCOPE_CREEP", "DEPENDENCY_BLOCK"]},
              "threshold": {"type": "number"},
              "action": {"type": "string", "enum": ["alert", "escalate", "constrain", "re_mediate"]}
            }
          }
        }
      },
      "example": {
        "id": "PA-M1",
