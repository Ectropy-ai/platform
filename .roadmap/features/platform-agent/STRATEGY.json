  "executiveSummary": {
    "objective": "Implement the Dual-Process Decision Engine for Ectropy's internal development planning",
    "approach": "Leverage the production-ready decision engine (424 tests, 23 MCP tools) with platform-specific context isolation",
    "keyInsight": "Same cognitive architecture, completely different data - Platform Agent never sees tenant data, Tenant Agents never see code/roadmap",
    "effort": "96 hours (4 weeks part-time)",
    "dependencies": [
      "Dual-Process Decision Engine (COMPLETE)",
      "Multi-Tenant Foundation (COMPLETE)",
      "Repository Split (January 30, 2026)"
    ]
  },
  "architecturePrinciples": {
    "principle1": {
      "name": "Context Isolation Above All",
      "description": "Platform Agent operates exclusively on code/feature planning data. Zero access to tenant construction data.",
      "enforcement": [
        "Repository boundary (private repo for platform files)",
        "PostgreSQL RLS bypass via tenant_id = NULL",
        "MCP tool excluded_contexts configuration",
        "Separate Success Stack tier"
      ]
    },
    "principle2": {
      "name": "Cognitive Consistency",
      "description": "Same dual-process architecture (Engine 1 + Engine 2 + USF Mediation) for both platform and tenant decisions",
      "benefit": "Pattern reuse, consistent tooling, single codebase"
    },
    "principle3": {
      "name": "Dogfooding",
      "description": "Ectropy uses its own decision intelligence for development planning - validates the architecture at the meta-level",
      "benefit": "Credibility, real-world testing, continuous improvement"
    }
  },
