          "predecessors": [],
          "successors": ["urn:luhtech:ectropy:milestone:PA-M2"]
        }
      }
    },
    "decisionEventV31": {
      "description": "Extended decision event schema with roadmap linking",
      "newFields": {
        "linkedMilestoneUrn": {
          "type": "string",
          "pattern": "^urn:luhtech:[^:]+:milestone:.+$",
          "description": "Milestone this decision affects"
        },
        "linkedFeatureUrn": {
          "type": "string",
          "pattern": "^urn:luhtech:[^:]+:feature:.+$",
          "description": "Feature this decision affects"
        },
        "classification": {
          "type": "string",
          "enum": ["LEAD", "DERIVED", "EXTERNAL", "FLEXIBLE"],
          "description": "Inherited from trigger type or explicit"
        },
        "authorityLevel": {
          "type": "integer",
          "minimum": 0,
          "maximum": 3,
          "description": "Platform authority cascade level required"
        },
        "dependsOn": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Predecessor decision URNs"
        },
        "blocks": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Successor decision URNs"
        }
      }
    }
  },
  "successStackTiers": {
    "description": "Three-tier Success Stack architecture for complete isolation",
    "tiers": {
      "platform": {
        "scope": "LuhTech Internal",
        "content": "Feature delivery, venture coordination, schema design patterns",
        "access": "Platform Agent ONLY",
        "storage": ".roadmap/success-stack-platform.json (private repo)",
        "examplePatterns": [
          {
            "id": "PAT-PLATFORM-FEAT-001",
            "name": "M7_MILESTONE_DECOMPOSITION",
            "actionType": "decompose_feature",
            "confidence": 0.85,
            "frequency": 47,
            "conditions": "Feature complexity >= medium, has schema changes"
          },
          {
            "id": "PAT-PLATFORM-SCHEMA-001",
            "name": "V3_SCHEMA_EVOLUTION",
            "actionType": "evolve_schema",
            "confidence": 0.90,
            "frequency": 23,
            "conditions": "Breaking change required"
          }
        ]
      },
      "global": {
        "scope": "All Tenants",
        "content": "Anonymized construction patterns (no PII, no tenant identification)",
        "access": "All Tenant Agents",
        "storage": "PostgreSQL success_patterns table (isGlobal = true)",
        "anonymization": {
          "removedFields": ["tenant_id", "project_id", "sourceDecisions"],
          "keptFields": ["contextSignature", "actionTemplate", "outcomeProfile"]
        }
      },
      "tenant": {
        "scope": "Single Tenant",
        "content": "Tenant-specific construction patterns",
        "access": "That Tenant Agent ONLY",
        "storage": "PostgreSQL success_patterns table (tenant_id = specific)",
        "isolation": "PostgreSQL RLS enforces tenant_id match"
      }
    },
    "queryFlow": {
      "platformAgent": "Query Platform tier only → Never sees Global or Tenant patterns",
      "tenantAgent": "Query Tenant tier first → Fallback to Global tier → Never sees Platform tier"
    }
  },
  "platformAuthorityMapping": {
    "description": "4-tier authority cascade for platform development decisions",
    "cascade": [
      {
        "level": 0,
        "role": "CLAUDE_AGENT",
        "description": "Automated decisions within established patterns",
        "thresholds": {
          "maxEffortHours": 4,
          "scopeLimit": "Single file changes",
          "patternConfidenceRequired": 0.9
        },
        "permissions": [
          "Apply high-confidence patterns",
          "Fix lint/type errors",
          "Update documentation",
          "Run tests and report"
        ],
        "escalationTriggers": [
          "Novel situation (no pattern match)",
          "Multi-file changes required",
          "Schema modifications"
        ]
      },
      {
        "level": 1,
        "role": "DEVELOPER",
        "description": "Implementation decisions within approved features",
        "thresholds": {
          "maxEffortHours": 40,
          "scopeLimit": "Single feature/service",
          "patternConfidenceRequired": 0.7
        },
        "permissions": [
          "Implement approved features",
          "Create new services",
          "Add tests",
          "Refactor within scope"
        ],
        "escalationTriggers": [
          "Cross-feature changes",
          "Schema design decisions",
          "External integrations"
        ]
      },
      {
        "level": 2,
        "role": "ARCHITECT",
        "description": "Design decisions affecting multiple features",
        "thresholds": {
          "maxEffortHours": 200,
          "scopeLimit": "Multi-feature/cross-cutting",
          "explorationPermitted": true
        },
        "permissions": [
          "Schema design",
          "Architecture decisions",
          "Cross-feature refactoring",
          "Integration design"
        ],
        "escalationTriggers": [
          "Strategic direction changes",
          "Venture-level impact",
          "Funding gate decisions"
        ]
      },
      {
        "level": 3,
        "role": "ERIK",
        "description": "Strategic decisions and venture coordination",
        "thresholds": {
          "maxEffortHours": "unlimited",
          "scopeLimit": "Strategic/venture-level"
        },
        "permissions": [
          "All decisions",
          "Venture priorities",
          "Funding allocation",
          "Strategic direction"
        ]
      }
    ]
  },
