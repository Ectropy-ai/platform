{
  "$schema": "https://luhtech.dev/schemas/integration-spec.json",
  "$id": "urn:luhtech:ectropy:integration:platform-agent-seppa",
  "schemaVersion": "1.0.0",
  "lastUpdated": "2026-01-29T00:00:00Z",
  "metadata": {
    "documentId": "platform-agent-seppa-integration",
    "title": "Platform Agent - SEPPA Integration Architecture",
    "purpose": "Documents the integration and isolation between Platform Decision Agent (Ectropy internal) and SEPPA (tenant-facing construction intelligence)",
    "maintainer": "platform-team",
    "relatedDocuments": [
      ".roadmap/features/platform-agent/FEATURE.json",
      ".roadmap/features/platform-agent/STRATEGY.json",
      ".roadmap/architecture/mcp-seppa-backend.json",
      "apps/mcp-server/data/multi-tenant-architecture-decision-2026-01-25.json"
    ]
  },
  "executiveSummary": {
    "overview": "The Platform Decision Agent and SEPPA (Seppä Construction Intelligence Agent) share the underlying Dual-Process Decision Engine but operate in completely isolated contexts. Platform Agent manages Ectropy's internal roadmapping while SEPPA serves tenant construction projects.",
    "keyPrinciple": "Complete isolation: Platform Agent NEVER accesses tenant data, and SEPPA NEVER accesses Ectropy's internal development patterns.",
    "isolationLayers": [
      "Repository boundary (luhtech/Ectropy only for Platform)",
      "PostgreSQL Row-Level Security (tenant_id=NULL for platform)",
      "Success Stack tier separation (platform/global/tenant)",
      "MCP tool context injection",
      "Tool whitelist/blocklist enforcement"
    ]
  },
  "architectureOverview": {
    "sharedComponents": {
      "dualProcessEngine": {
        "description": "Both agents use the same Dual-Process Decision Engine infrastructure",
        "engine1": "Success Stack (pattern matching) - with tier isolation",
        "engine2": "Possibility Space (option generation) - shared logic",
        "usf": "USF Mediation - shared logic with context-specific thresholds"
      },
      "eigenmodeCalculation": {
        "description": "Both use eigenmode vectors, but with different dimensions",
        "platformEigenmodes": [
          "codebase_health",
          "test_coverage",
          "technical_debt",
          "dependency_freshness",
          "ci_stability",
          "deployment_frequency",
          "documentation_coverage",
          "api_stability",
          "performance_regression",
          "security_posture",
          "team_velocity",
          "feature_completion"
        ],
        "tenantEigenmodes": [
          "safety_index",
          "schedule_performance",
          "cost_variance",
          "quality_index",
          "resource_utilization",
          "risk_index",
          "stakeholder_satisfaction",
          "regulatory_compliance",
          "sustainability_index",
          "innovation_index",
          "collaboration_index",
          "documentation_index"
        ]
      },
      "sdiCalculation": {
        "description": "Solution Density Index calculation is shared",
        "platformContext": "Uses platform-specific thresholds",
        "tenantContext": "Uses tenant-specific thresholds per project"
      }
    },
    "isolatedComponents": {
      "successStackTiers": {
        "platform": {
          "description": "Ectropy's internal development patterns",
          "dataSource": ".roadmap/success-stack-platform.json",
          "isolation": "Complete - never queries global or tenant patterns",
          "examples": [
            "M7_MILESTONE_DECOMPOSITION",
            "V3_SCHEMA_EVOLUTION",
            "STAGING_FIRST_DEPLOYMENT"
          ]
        },
        "global": {
          "description": "Anonymized cross-tenant patterns",
          "dataSource": "PostgreSQL with tenant_id aggregation",
          "isolation": "Anonymized - no tenant identifiers",
          "examples": [
            "Electrical_rough_in patterns",
            "Schedule_acceleration patterns"
          ]
        },
        "tenant": {
          "description": "Tenant-specific patterns",
          "dataSource": "PostgreSQL with tenant_id filter",
          "isolation": "RLS enforced - only tenant's own patterns",
          "examples": [
            "Project-specific learned patterns"
          ]
        }
      },
      "authorityLevels": {
        "platform": {
          "levels": ["CLAUDE_AGENT", "DEVELOPER", "ARCHITECT", "ERIK"],
          "maxLevels": 4,
          "thresholds": {
            "CLAUDE_AGENT": { "maxEffortHours": 2, "scopeLimit": "single_file" },
            "DEVELOPER": { "maxEffortHours": 8, "scopeLimit": "single_feature" },
            "ARCHITECT": { "maxEffortHours": 40, "scopeLimit": "multi_feature" },
            "ERIK": { "maxEffortHours": "unlimited", "scopeLimit": "strategic" }
          }
        },
        "tenant": {
          "levels": ["L0_FIELD_WORKER", "L1_FOREMAN", "L2_SUPER", "L3_PM", "L4_CONSTRUCTION_MANAGER", "L5_OWNER_REP", "L6_EXECUTIVE"],
          "maxLevels": 7,
          "thresholds": "Per-tenant configurable"
        }
      },
      "toolAvailability": {
        "platformAgent": {
          "allowed": [
            "query_success_stack",
            "store_success_pattern",
            "generate_options",
            "calculate_sdi",
            "get_exploration_budget",
            "compute_eigenmode_similarity"
          ],
          "blocked": [
            "capture_decision",
            "route_decision",
            "approve_decision",
            "voxelize_model",
            "query_voxels",
            "attach_decision_to_voxel",
            "request_inspection",
            "complete_inspection",
            "apply_tolerance_override",
            "get_voxel_decisions",
            "navigate_decision_surface",
            "track_consequence",
            "escalate_decision",
            "reject_decision",
            "query_decision_history",
            "get_authority_graph",
            "find_decision_authority",
            "validate_authority_level"
          ],
          "reason": "Platform Agent manages Ectropy development, not construction projects"
        },
        "seppaAgent": {
          "allowed": "All 24 PM decision and voxel tools",
          "blocked": "Platform-internal tools (file operations on .roadmap)",
          "reason": "SEPPA manages tenant construction projects"
        }
      }
    }
  },
  "dataIsolation": {
    "database": {
      "model": "Shared Schema with Row-Level Security",
      "platformData": {
        "tenantId": "NULL",
        "tables": [
          "Platform decisions (decision_events WHERE tenant_id IS NULL)",
          "Platform patterns (success_patterns WHERE tier = 'platform')"
        ],
        "access": "Only Platform Agent and platform admins"
      },
      "tenantData": {
        "tenantId": "UUID (per tenant)",
        "tables": [
          "Tenant decisions (decision_events WHERE tenant_id = ?)",
          "Tenant patterns (success_patterns WHERE tier = 'tenant')"
        ],
        "access": "Only that tenant's users via RLS"
      },
      "rlsPolicies": {
        "decisionEvents": "tenant_id = current_setting('app.current_tenant_id')::uuid OR tenant_id IS NULL AND is_platform_admin = true",
        "successPatterns": "tier = 'platform' OR tenant_id = current_setting('app.current_tenant_id')::uuid"
      }
    },
    "fileSystem": {
      "platformData": {
        "paths": [
          ".roadmap/success-stack-platform.json",
          ".roadmap/features/platform-agent/",
          ".roadmap/projects/ectropy-roadmap/"
        ],
        "access": "Platform Agent only"
      },
      "tenantData": {
        "paths": "Not on filesystem - stored in PostgreSQL",
        "access": "Via API with tenant context"
      }
    }
  },
  "contextInjection": {
    "platformAgent": {
      "injectedContext": {
        "agentType": "PLATFORM",
        "tenantId": null,
        "successStackTier": "platform",
        "excludedContexts": ["tenant", "customer", "project", "construction"]
      },
      "queryModifications": {
        "query_success_stack": {
          "tier": "platform",
          "excludeGlobal": true,
          "excludeTenant": true
        },
        "store_success_pattern": {
          "tier": "platform",
          "isGlobal": false
        },
        "calculate_sdi": {
          "eigenmodeLabels": "[platform eigenmodes]"
        }
      }
    },
    "seppaAgent": {
      "injectedContext": {
        "agentType": "TENANT",
        "tenantId": "[from X-Tenant-ID header]",
        "successStackTier": "tenant",
        "includeGlobalPatterns": true
      }
    }
  },
  "integrationPoints": {
    "successStackQueries": {
      "platformFlow": [
        "1. Platform Agent calls query_success_stack",
        "2. platform-context.service.ts injects tier='platform', excludeGlobal=true",
        "3. success-stack.service.ts filters to platformPatterns only",
        "4. Only platform patterns returned - no tenant data leakage"
      ],
      "tenantFlow": [
        "1. SEPPA Agent calls query_success_stack",
        "2. Assistant service injects tenantId from X-Tenant-ID header",
        "3. success-stack.service.ts includes tenant + global patterns",
        "4. RLS ensures tenant isolation"
      ]
    },
    "patternStorage": {
      "platformFlow": [
        "1. Platform Agent calls store_success_pattern",
        "2. Context injection sets tier='platform', isGlobal=false",
        "3. Pattern stored with tier='platform'",
        "4. Indexed in platformPatterns set"
      ],
      "tenantFlow": [
        "1. SEPPA Agent calls compress_decision_pattern",
        "2. Pattern created with tenantId and tier='tenant'",
        "3. If approved for global, anonymized copy created with tier='global'",
        "4. Original stays in tenantPatterns index"
      ]
    },
    "decisionLifecycle": {
      "platformDecisions": {
        "captures": "Ectropy development decisions (schema changes, deployments)",
        "links": "To milestones in .roadmap/features/platform-agent/FEATURE.json",
        "classification": "LEAD/DERIVED/EXTERNAL/FLEXIBLE (Atomic Reference Strategy)",
        "storage": "decision_events WHERE tenant_id IS NULL"
      },
      "tenantDecisions": {
        "captures": "Construction PM decisions (RFIs, change orders, inspections)",
        "links": "To voxels and takt zones",
        "classification": "Standard PM workflow",
        "storage": "decision_events WHERE tenant_id = [tenant UUID]"
      }
    }
  },
  "securityConsiderations": {
    "dataLeakagePrevention": [
      "Platform Agent tool blocklist prevents access to tenant tools",
      "Context injection enforces tier='platform' on all queries",
      "RLS at database level as defense-in-depth",
      "Success Stack tier indexes ensure physical separation"
    ],
    "crossContamination": [
      "Platform patterns NEVER influence tenant decisions",
      "Tenant patterns NEVER visible to platform queries",
      "Global patterns are anonymized before sharing"
    ],
    "auditTrail": [
      "All decisions logged with agentType (PLATFORM/TENANT)",
      "Tier explicitly recorded on all patterns",
      "Context injection logged for debugging"
    ]
  },
  "implementationStatus": {
    "completed": [
      "Platform Agent tool whitelist/blocklist",
      "Platform context injection service",
      "Platform eigenmode service (12 metrics)",
      "Decision-milestone linker service",
      "Success Stack tier-based filtering (query + storage)",
      "Platform pattern seeder with initial patterns",
      "V3.1 schemas with tier support"
    ],
    "validated": [
      "Tool isolation verified in integration tests",
      "Context injection verified",
      "Authority cascade verified"
    ],
    "pending": [
      "Production database tier column migration",
      "Global pattern anonymization pipeline",
      "Tenant pattern RLS policy updates"
    ]
  },
  "testingStrategy": {
    "unitTests": [
      "success-stack.service.spec.ts - tier filtering",
      "platform-context.service.spec.ts - context injection",
      "platform-eigenmode.service.spec.ts - metric calculation"
    ],
    "integrationTests": [
      "platform-agent.integration.spec.ts - full isolation verification",
      "Tool availability enforcement",
      "Authority cascade with tier context"
    ],
    "e2eTests": [
      "Platform Agent cannot access tenant data",
      "SEPPA Agent cannot access platform data",
      "Cross-tier queries return empty results"
    ]
  }
}
