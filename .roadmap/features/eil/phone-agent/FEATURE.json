  "deliverable": {
    "id": "p5b-d24",
    "$id": "urn:luhtech:ectropy:deliverable:p5b-d24",
    "name": "Phone Agent Service MVP",
    "targetDate": "2026-03-15",
    "estimatedHours": 120,
    "status": "in_progress",
    "successCriteria": [
      "Twilio webhook integration operational",
      "User identity resolution from phone number → user → project",
      "Multi-turn SMS conversation state machine implemented",
      "Intent classification >85% accuracy",
      "<3s P95 SMS round-trip latency",
      "Photo attachment handling (MMS)",
      "160-char aware response formatting"
    ],
    "interfaces": {
      "smsWebhook": {
        "endpoint": "POST /api/phone/v1/webhooks/twilio/sms",
        "input": "Twilio SMS webhook payload",
        "output": "TwiML response or empty 200",
        "security": "Twilio signature validation"
      },
      "voiceWebhook": {
        "endpoint": "POST /api/phone/v1/webhooks/twilio/voice",
        "input": "Twilio Voice webhook payload",
        "output": "TwiML voice instructions",
        "security": "Twilio signature validation"
      },
      "sendSms": {
        "endpoint": "POST /api/phone/v1/send",
        "input": {
          "to": "E.164 phone",
          "body": "string",
          "mediaUrl": "optional"
        },
        "output": { "messageId": "string", "status": "queued" }
      },
      "conversationStatus": {
        "endpoint": "GET /api/phone/v1/conversations/:sessionId",
        "output": { "state": "enum", "history": "array", "context": "object" }
      }
    }
  },
