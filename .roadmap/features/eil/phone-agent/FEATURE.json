  "feature": {
    "id": "phone-agent",
    "name": "Phone Agent Service (SMS/Voice)",
    "description": "Zero-friction field data capture via SMS and voice channels using Twilio integration with multi-turn conversation support",
    "status": "IN_PROGRESS",
    "priority": "critical",
    "targetRelease": "2026-03-15",
    "parent": "seppa-agent"
  },
  "businessValue": {
    "problem": "Construction software adoption rates <30% for mobile apps",
    "solution": "SMS-first approach achieving >95% adoption",
    "metrics": {
      "adoptionRate": {
        "mobileApp": "<30%",
        "sms": ">95%",
        "improvement": "3x+"
      },
      "dataCaptureTime": {
        "mobileApp": "45s",
        "sms": "8s",
        "improvement": "5.6x faster"
      },
      "trainingRequired": { "mobileApp": "Yes", "sms": "No" },
      "offlineSupport": { "mobileApp": "Limited", "sms": "Always (queued)" }
    }
  },
  "architecture": {
    "service": {
      "serviceId": "phone-agent-service",
      "name": "Phone Agent Service",
      "port": 4007,
      "technology": "Node.js + Express + TypeScript + Twilio SDK",
      "description": "SMS/Voice channel handling, conversation state machine"
    },
    "channels": [
      {
        "channel": "SMS",
        "provider": "Twilio",
        "status": "Implemented",
        "authorityLevels": "0-3"
      },
      {
        "channel": "Voice",
        "provider": "Twilio",
        "status": "Implemented",
        "authorityLevels": "0-3"
      },
      {
        "channel": "Teams",
        "provider": "Microsoft Bot Framework",
        "status": "Post-Pilot",
        "authorityLevels": "2-6"
      },
      {
        "channel": "Slack",
        "provider": "Slack API",
        "status": "Post-Pilot",
        "authorityLevels": "2-6"
      }
    ],
    "conversationStateMachine": {
      "states": [
        {
          "state": "IDLE",
          "description": "Awaiting inbound message",
          "transitionsTo": ["IDENTIFY_USER"]
        },
        {
          "state": "IDENTIFY_USER",
          "description": "Match phone → user → project",
          "transitionsTo": ["CLASSIFY_INTENT", "ERROR"]
        },
        {
          "state": "CLASSIFY_INTENT",
          "description": "Determine user's goal",
          "transitionsTo": ["EXTRACT_ENTITIES"]
        },
        {
          "state": "EXTRACT_ENTITIES",
          "description": "Pull voxel, zone, values from message",
          "transitionsTo": ["COLLECT_DATA", "VALIDATE"]
        },
        {
          "state": "COLLECT_DATA",
          "description": "Multi-turn: request missing fields",
          "transitionsTo": ["VALIDATE"]
        },
        {
          "state": "VALIDATE",
          "description": "Check authority, data completeness",
          "transitionsTo": ["CONFIRM", "ESCALATE"]
        },
        {
          "state": "CONFIRM",
          "description": "Request user confirmation",
          "transitionsTo": ["EXECUTE", "IDLE"]
        },
        {
          "state": "EXECUTE",
          "description": "Call appropriate tool(s)",
          "transitionsTo": ["RESPOND"]
        },
        {
          "state": "RESPOND",
          "description": "Format and send response",
          "transitionsTo": ["IDLE"]
        }
      ]
    }
  },
  "roleMapping": [
    {
      "role": "Field Worker",
