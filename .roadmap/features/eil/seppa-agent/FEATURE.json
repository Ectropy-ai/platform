{
  "$schema": "https://luhtech.dev/schemas/feature.schema.json",
  "$id": "urn:luhtech:ectropy:feature:seppa-agent",
  "schemaVersion": "1.0.0",
  "meta": {
    "ventureId": "ectropy",
    "createdAt": "2026-01-07T20:00:00Z",
