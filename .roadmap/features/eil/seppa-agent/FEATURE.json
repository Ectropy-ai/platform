  "feature": {
    "id": "seppa-agent",
    "name": "Seppä Construction Intelligence Agent",
    "description": "AI-powered construction assistant using Claude for natural language interaction with PM decision lifecycle, RAG retrieval, and multi-channel access",
    "etymology": {
      "finnish": "Seppä (master builder, journeyman)",
      "acronym": "Spatial Element Processing Prediction Aggregation"
    },
    "status": "IN_DEVELOPMENT",
    "priority": "critical",
    "targetRelease": "2026-03-01",
    "pilot": "Canadian Plant Facility"
  },
  "businessValue": {
    "problem": "Construction teams spend 28+ hours per decision escalation, field workers have <30% app adoption",
    "solution": "AI agent that understands construction context, respects authority cascade, and meets workers via SMS/voice",
    "differentiator": "Only AI assistant with voxel-attached decision context and 7-tier authority awareness",
    "metrics": {
      "targetAdoptionRate": ">95% (via SMS vs <30% mobile apps)",
      "targetResponseTime": "<5s P95 simple queries, <15s P95 complex",
      "targetAccuracy": ">90% tool selection accuracy",
      "targetROI": "1,485% per project"
    }
  },
  "architecture": {
    "services": [
      {
        "serviceId": "assistant-service",
        "name": "Assistant Service",
        "port": 4005,
        "technology": "Node.js + Express + Anthropic SDK",
        "description": "Claude API orchestration, tool execution, conversation management"
      },
      {
        "serviceId": "rag-service",
        "name": "RAG Service",
        "port": 4006,
        "technology": "Node.js + Qdrant + Jina Embeddings v3",
        "description": "Vector search, embedding generation, context assembly"
      },
      {
        "serviceId": "phone-agent-service",
        "name": "Phone Agent Service",
        "port": 4007,
        "technology": "Node.js + Express + Twilio SDK",
        "description": "SMS/Voice channel handling, multi-turn conversations"
      }
    ],
    "integrations": [
      {
        "system": "MCP Server",
        "port": 3002,
        "method": "REST API",
        "purpose": "PM Decision tools, deliverable CRUD, roadmap queries"
      },
      {
        "system": "Qdrant",
        "port": 6333,
        "method": "gRPC/HTTP",
        "purpose": "Vector storage and similarity search"
      },
      {
        "system": "Twilio",
        "method": "Webhooks",
        "purpose": "SMS/Voice inbound and outbound messaging"
      }
    ],
    "claudeModels": {
      "production": {
        "model": "claude-sonnet-4-20250514",
        "maxTokens": 4096,
        "useCase": "Primary assistant, tool orchestration"
      },
      "costOptimized": {
        "model": "claude-haiku-4-5-20251001",
        "maxTokens": 2048,
        "useCase": "Simple queries, high-volume SMS"
      },
      "complex": {
        "model": "claude-opus-4-5-20251101",
        "maxTokens": 8192,
        "useCase": "Multi-step reasoning, report generation"
      }
    }
  },
  "tools": {
    "pmDecisionTools": {
      "count": 17,
      "categories": [
        {
          "name": "Decision Management",
          "count": 6,
          "tools": [
            "capture_decision",
            "route_decision",
            "approve_decision",
            "reject_decision",
            "escalate_decision",
            "batch_decisions"
          ]
        },
        {
          "name": "Authority Graph",
          "count": 2,
          "tools": ["get_authority_graph", "calculate_required_authority"]
        },
        {
          "name": "Voxel Operations",
          "count": 2,
          "tools": ["get_voxel_decisions", "get_spatial_context"]
        },
        {
          "name": "Consequence Tracking",
          "count": 3,
          "tools": [
            "query_consequences",
            "project_consequence_impact",
            "record_consequence_occurrence"
          ]
        },
        {
          "name": "Inspection & Schedule",
          "count": 3,
          "tools": [
            "schedule_inspection",
            "record_inspection_result",
            "get_inspection_requirements"
          ]
        },
        {
          "name": "Graph Query",
          "count": 1,
          "tools": ["traverse_decision_graph"]
        }
      ]
    }
  },
  "multiTenant": {
    "isolationLayers": [
      {
        "layer": "Database",
        "strategy": "Schema per tenant with PostgreSQL RLS"
      },
      {
        "layer": "Vector DB",
        "strategy": "Qdrant namespaced collections per tenant"
      },
      {
        "layer": "Cache",
        "strategy": "Redis key prefix pattern: {tenantId}:*"
      },
      {
        "layer": "LLM Context",
        "strategy": "System prompt includes tenant scope"
      },
      {
        "layer": "File Storage",
        "strategy": "S3-compatible with tenant prefix"
      },
      { "layer": "Audit Logs", "strategy": "All logs include tenantId field" }
    ],
    "resourceQuotas": {
      "standard": {
        "claudeApiCalls": 1000,
        "smsMessages": 500,
        "vectorStorage": 100000,
        "documentStorage": "10GB",
        "concurrentUsers": 50
      },
      "enterprise": {
        "claudeApiCalls": 10000,
        "smsMessages": 5000,
        "vectorStorage": 1000000,
        "documentStorage": "100GB",
        "concurrentUsers": 500
      }
    }
  },
  "schemas": [
    {
      "name": "assistant-message.schema.json",
      "path": ".roadmap/schemas/eil/assistant-message.schema.json",
      "purpose": "Chat message format with tool calls and citations"
    },
    {
      "name": "assistant-conversation.schema.json",
      "path": ".roadmap/schemas/eil/assistant-conversation.schema.json",
      "purpose": "Conversation container with tenant and user context"
    },
    {
      "name": "tool-call.schema.json",
      "path": ".roadmap/schemas/eil/tool-call.schema.json",
      "purpose": "Tool invocation record with timing and status"
    },
    {
      "name": "rag-context.schema.json",
      "path": ".roadmap/schemas/eil/rag-context.schema.json",
      "purpose": "Retrieved context assembly with citations"
    }
  ],
