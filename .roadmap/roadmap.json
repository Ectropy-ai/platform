  "pitch": {
    "oneLiner": "delivering validated ground truth to every construction decision",
    "problem": {
      "headline": "Construction Is Losing the War on Waste",
      "subheadline": "Siloed data, vanishing knowledge, no unified record layer",
      "problemColumns": [
        {
          "header": "The Challenge",
          "bullets": [
            "BIM, schedules, and field data remain siloed across every project",
            "Knowledge walks out the door when crews rotate",
            "No unified record of why decisions were made"
          ]
        },
        {
          "header": "The Impact",
          "bullets": [
            "28+ hours average decision latency at $13,210 per incident",
            "67% of projects exceed budgets with 83-day payment cycles",
            "$1.6T in annual industry waste — the most avoidable number in construction"
          ]
        },
        {
          "header": "The Gap",
          "bullets": [
            "Less than 1% of construction R&D spend reaches field tools",
            "No open platform owns the decision record layer",
            "Construction remains the least digitized major industry on earth"
          ]
        }
      ]
    },
    "solution": "Federated data platform with AI-powered decision lifecycle, voxel decision surfaces for proactive field navigation, and zero-friction capture via phone agents",
    "market": "Construction Tech - $22 trillion industry, $15B software market, 12% CAGR",
    "differentiator": "Proactive decision attachment to physical space (voxels), 7-tier authority cascade, AI graph traversal, offline-first edge architecture",
    "businessModel": "Open-core: Apache 2.0 platform + commercial extensions + professional services",
    "traction": "92/100 production readiness score, 35/62 E2E tests passing in staging CI (fixture improvements in progress), 11 services operational on staging, decision lifecycle schemas validated (4 new schemas), Canadian pilot March 2026 ($50K verbal commitment), partner demo completed Dec 2025",
    "ask": "Pre-seed $500K-$1M targeting Q2 2026. Pilot validation → 15-20 investor meetings → close. Use: 60% team, 15% infrastructure, 15% operations, 10% buffer.",
    "technology": "Cloud-native platform: Next.js + TypeScript, PostgreSQL + PostGIS, Redis, Speckle Server (BIM federation), Docker Compose orchestration, 5-layer immutable architecture, 11 operational services, 24/39 MCP decision tools operational, Qdrant vector DB for RAG",
    "missionLine": "One truth. One goal. One team.",
    "mantra": "Changing the vector of global construction.",
    "coverStat": {
      "value": "$1.6T",
      "label": "annual waste in construction",
      "source": "McKinsey Global Institute, 2017"
    },
    "solutionScreenshotDriveId": "1mSnU5kIaxlPn0dO-lRO-YSZVlC88ysTP"
  },
