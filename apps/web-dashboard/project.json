{
  "name": "web-dashboard",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/web-dashboard/src",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "@nx/webpack:webpack",
      "outputs": ["{options.outputPath}"],
      "defaultConfiguration": "production",
      "options": {
        "compiler": "babel",
        "outputPath": "dist/apps/web-dashboard",
        "index": "apps/web-dashboard/src/index.html",
        "baseHref": "/",
        "main": "apps/web-dashboard/src/main.tsx",
        "tsConfig": "apps/web-dashboard/tsconfig.app.json",
        "assets": ["apps/web-dashboard/src/favicon.ico", "apps/web-dashboard/src/assets"],
        "styles": ["apps/web-dashboard/src/styles.css"],
        "scripts": [],
        "webpackConfig": "apps/web-dashboard/webpack.config.cjs"
      },
      "configurations": {
        "development": {
          "extractLicenses": false,
          "optimization": false,
          "sourceMap": true,
          "vendorChunk": true
        },
        "production": {
          "fileReplacements": [
            {
              "replace": "apps/web-dashboard/src/environments/environment.ts",
              "with": "apps/web-dashboard/src/environments/environment.prod.ts"
            }
          ],
          "optimization": true,
          "outputHashing": "all",
          "sourceMap": false,
          "namedChunks": false,
          "extractLicenses": true,
          "vendorChunk": false
        }
      }
    },
    "serve": {
      "executor": "@nx/webpack:dev-server",
      "defaultConfiguration": "development",
      "options": {
        "buildTarget": "web-dashboard:build",
        "hmr": true,
        "port": 4200,
        "host": "localhost"
      },
      "configurations": {
        "development": {
          "buildTarget": "web-dashboard:build:development",
          "port": 4200
        },
        "production": {
          "buildTarget": "web-dashboard:build:production",
          "hmr": false,
          "port": 4200
        }
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["apps/web-dashboard/**/*.{ts,tsx,js,jsx}"]
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "echo 'ℹ️  web-dashboard uses Vite + Playwright for testing. Run: pnpm test:e2e:docker'"
      }
    },
    "type-check": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx tsc --noEmit -p apps/web-dashboard/tsconfig.app.json"
      }
    },
    "health": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "echo '🔍 Web Dashboard Health Check'",
          "curl -f -s http://localhost:4200/ > /dev/null && echo '✅ Dashboard: Accessible on port 4200' || echo '❌ Dashboard: Not accessible on port 4200'",
          "test -d dist/apps/web-dashboard && echo '✅ Build: Assets present' || echo '⚠️  Build: No build artifacts found'",
          "echo '🎯 Web Dashboard health check complete'"
        ],
        "parallel": false
      }
    }
  },
  "tags": ["scope:web", "type:app"]
}
