{
  "name": "api-gateway",
  "version": "1.0.0",
  "description": "API Gateway for Federated Construction Platform",
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/enhanced-server.js",
    "start:original": "node dist/server.js",
    "dev": "ts-node src/enhanced-server.ts",
    "dev:original": "ts-node src/server.ts",
    "build": "tsc",
    "build:enhanced": "tsc src/enhanced-server.ts --outDir dist --target ES2020 --module commonjs --strict --esModuleInterop --skipLibCheck",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:security": "vitest --testPathPattern=security",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "security:scan": "../../scripts/security/setup-secure-config.sh validate",
    "clean": "rimraf dist"
  },
  "keywords": [
    "api",
    "gateway",
    "construction",
    "federated"
  ],
  "author": "Federated Construction Platform Team",
  "license": "MIT",
  "packageManager": "pnpm@10.14.0",
  "dependencies": {
    "@aws-sdk/client-s3": "3.873.0",
    "@ectropy/database": "workspace:*",
    "@prisma/client": "6.16.3",
    "@types/multer": "^2.0.0",
    "append-field": "^1.0.0",
    "asynckit": "^0.4.0",
    "axios": "^1.7.7",
    "bcryptjs": "^3.0.2",
    "busboy": "^1.6.0",
    "combined-stream": "^1.0.8",
    "compression": "^1.8.0",
    "concat-stream": "2.0.0",
    "connect-pg-simple": "^10.0.0",
    "connect-redis": "^7.1.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "date-fns": "^3.6.0",
    "dotenv": "^16.3.0",
    "envalid": "8.1.1",
    "es-set-tostringtag": "^2.1.0",
    "express": "^4.19.2",
    "express-rate-limit": "7.2.0",
    "express-session": "^1.18.1",
    "express-validator": "^7.0.1",
    "form-data": "^4.0.0",
    "graphql": "^16.11.0",
    "graphql-tag": "^2.12.6",
    "handlebars": "4.7.8",
    "hasown": "^2.0.2",
    "helmet": "^7.2.0",
    "ioredis": "^5.8.2",
    "isomorphic-dompurify": "^2.9.0",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.3",
    "mime-types": "^2.1.35",
    "mkdirp": "3.0.1",
    "multer": "^1.4.5-lts.1",
    "object-assign": "^4.1.1",
    "openai": "^4.28.0",
    "passport": "0.7.0",
    "passport-google-oauth20": "2.0.0",
    "pg": "^8.11.3",
    "prom-client": "^15.1.3",
    "rate-limit-redis": "^4.2.3",
    "redis": "^4.6.13",
    "resend": "^6.6.0",
    "type-is": "^1.6.18",
    "uuid": "^9.0.1",
    "winston": "^3.17.0",
    "ws": "^8.14.2",
    "xtend": "^4.0.2",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.9",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.2",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.0.13",
    "@types/passport": "1.0.17",
    "@types/passport-google-oauth20": "2.0.17",
    "@types/pg": "^8.10.9",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.10",
    "bcrypt": "^5.1.1",
    "jest": "^30.0.4",
    "supertest": "^7.1.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3",
    "vitest": "^2.1.9"
  }
}
