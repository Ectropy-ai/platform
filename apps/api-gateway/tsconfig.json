{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "../../dist/apps/api-gateway",
    "skipLibCheck": true,
    "paths": {
      "@ectropy/schemas": [
        "./node_modules/@ectropy/schemas/types/index.ts"
      ],
      "@ectropy/schemas/types": [
        "./node_modules/@ectropy/schemas/types/index.ts"
      ],
      "@ectropy/schemas/types/bundle": [
        "./node_modules/@ectropy/schemas/types/bundle.types.ts"
      ],
      "@ectropy/schemas/types/decision-seed": [
        "./node_modules/@ectropy/schemas/types/decision-seed.types.ts"
      ],
      "@ectropy/schemas/types/ifc-extraction": [
        "./node_modules/@ectropy/schemas/types/ifc-extraction.types.ts"
      ],
      "@ectropy/shared/config": [
        "libs/shared/config/src/index.ts"
      ],
      "@ectropy/shared/integrations": [
        "libs/shared/integrations/src"
      ],
      "@ectropy/shared/audit": [
        "libs/shared/audit/src"
      ],
      "@ectropy/shared/utils/browser": [
        "libs/shared/utils/src/browser.ts"
      ],
      "@ectropy/shared/utils": [
        "libs/shared/utils/src/index.ts"
      ],
      "@ectropy/shared/types": [
        "libs/shared/types/src/index.ts"
      ],
      "@ectropy/shared/types/*": [
        "libs/shared/types/src/*"
      ],
      "@ectropy/shared": [
        "libs/shared/src/index.ts"
      ],
      "@ectropy/shared/*": [
        "libs/shared/src/*"
      ],
      "@ectropy/ai-agents/*": [
        "libs/ai-agents/src/*"
      ],
      "@ectropy/ai-agents-shared": [
        "libs/ai-agents/shared/index.ts"
      ],
      "@ectropy/ai-agents-shared/*": [
        "libs/ai-agents/shared/*"
      ],
      "@ectropy/ifc-processing": [
        "libs/ifc-processing/src/index.ts"
      ],
      "@ectropy/speckle-integration": [
        "libs/speckle-integration/src/index.ts"
      ],
      "@ectropy/demo-scenarios": [
        "libs/demo-scenarios/src/index.ts"
      ],
      "@ectropy/mcp-server/*": [
        "apps/mcp-server/src/*"
      ]
    }
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "src/**/*.spec.ts",
    "src/**/*.test.ts"
  ]
}
