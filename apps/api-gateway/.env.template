# API Gateway Configuration
API_GATEWAY_PORT=4000
NODE_ENV=development

# Database Configuration (NEW COMPONENT APPROACH)
DATABASE_HOST=${DATABASE_HOST:-localhost}
DATABASE_PORT=5432
DATABASE_NAME=${DATABASE_NAME:-ectropy}
DATABASE_USER=${DATABASE_USER:-postgres}
DB_PASSWORD=${DB_PASSWORD}

# Legacy URL format (DEPRECATED - will be removed)
DATABASE_URL=postgresql://${DATABASE_USER}:${DB_PASSWORD}@${DATABASE_HOST}:${DATABASE_PORT}/${DATABASE_NAME}

# Redis Configuration (NEW COMPONENT APPROACH)
REDIS_HOST=${REDIS_HOST:-localhost}
REDIS_PORT=6379
REDIS_PASSWORD=${REDIS_PASSWORD}

# Legacy URL format (DEPRECATED - will be removed)
REDIS_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}
# For local development without Docker, replace the hostnames above with `localhost`.

# JWT Configuration
# Generate a strong secret with: openssl rand -base64 32
JWT_SECRET=
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# Security Configuration
BCRYPT_ROUNDS=12
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000
AUTH_RATE_LIMIT_MAX_REQUESTS=5

# Logging
LOG_LEVEL=info

# CRM Integration (Twenty CRM v1.18.1)
# Set CRM_ENABLED=true to activate CRM sync on lifecycle transitions
CRM_ENABLED=false
CRM_API_URL=https://crm.luh.tech/graphql
CRM_API_KEY=
CRM_WEBHOOK_SECRET=
