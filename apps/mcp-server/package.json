    "@prisma/client": "6.16.3",
    "@qdrant/js-client-rest": "1.15.1",
    "abort-controller": "^3.0.0",
    "agentkeepalive": "^4.5.0",
    "body-parser": "2.2.1",
    "compression": "^1.8.1",
    "cors": "2.8.5",
