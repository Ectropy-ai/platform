{
  "name": "mcp-server",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/mcp-server/src",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "@nx/webpack:webpack",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/mcp-server",
        "main": "apps/mcp-server/src/main.ts",
        "tsConfig": "apps/mcp-server/tsconfig.app.json",
        "compiler": "tsc",
        "target": "node",
        "webpackConfig": "apps/mcp-server/webpack.config.cjs",
        "generatePackageJson": true,
        "outputFileName": "main.js",
        "assets": [
          {
            "input": "apps/mcp-server/data",
            "glob": "**/*.json",
            "output": "data"
          }
        ]
      },
      "configurations": {
        "production": {
          "optimization": true,
          "extractLicenses": true,
          "inspect": false,
          "fileReplacements": [
            {
              "replace": "apps/mcp-server/src/environments/environment.ts",
              "with": "apps/mcp-server/src/environments/environment.prod.ts"
            }
          ]
        }
      }
    },
    "serve": {
      "executor": "@nx/js:node",
      "options": {
        "buildTarget": "mcp-server:build",
        "runBuildTargetDependencies": false,
        "host": "localhost",
        "port": 3001,
        "inspect": false
      },
      "configurations": {
        "production": {
          "buildTarget": "mcp-server:build:production"
        },
        "development": {
          "buildTarget": "mcp-server:build:development"
        }
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["apps/mcp-server/**/*.ts"],
        "noErrorOnUnmatchedPattern": true,
        "eslintConfig": "eslint.config.js"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "command": "vitest run --config apps/mcp-server/vitest.config.ts",
        "passWithNoTests": true
      },
      "configurations": {
        "ci": {
          "command": "vitest run --config apps/mcp-server/vitest.config.ts --coverage"
        }
      }
    },
    "prepare": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node scripts/mcp/prepare-mcp-dist.mjs"
      }
    },
    "type-check": {
      "executor": "nx:run-commands",
      "dependsOn": ["^build"],
      "options": {
        "command": "npx tsc --noEmit -p apps/mcp-server/tsconfig.app.json"
      }
    }
  },
  "tags": ["scope:mcp", "type:app", "platform:node"]
}
