      "Docker Desktop installation and daemon status check",
      "Docker resource allocation validation (CPU, Memory)",
      "Port availability verification for all services",
      "Environment file validation (.env.local)",
      "Critical environment variable verification",
      "Docker Compose configuration validation",
      "Database migration file verification",
      "Disk space requirement check"
    ],
    "prerequisites": [
      "Docker Desktop installed (Windows)",
      "PowerShell 5.1 or higher",
      "Minimum 8GB RAM available for Docker",
      "Minimum 20GB free disk space",
      "Access to project root directory"
