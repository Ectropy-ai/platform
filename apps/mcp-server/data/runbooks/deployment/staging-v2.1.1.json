  "deploymentSteps": [
    {
      "phase": 1,
      "name": "Pre-Deployment Checklist",
      "estimatedDuration": "15 minutes",
      "steps": [
        {
          "step": "1.1",
          "name": "Verify staging server access",
          "command": "ssh staging-server",
          "purpose": "Ensure SSH access to staging environment",
          "required": true
        },
        {
          "step": "1.2",
          "name": "Navigate to application directory",
          "command": "cd /opt/ectropy",
          "purpose": "Set working directory",
          "required": true
        },
        {
          "step": "1.3",
          "name": "Create backup",
          "commands": [
            "docker compose -f docker-compose.staging.yml down",
            "tar -czf backups/pre-deployment-$(date +%Y%m%d-%H%M%S).tar.gz data/"
          ],
          "purpose": "Backup current state for rollback capability",
          "required": true,
          "rollbackRelevant": true
        },
        {
          "step": "1.4",
          "name": "Verify environment variables",
          "command": "cat .env.staging | grep -E \"DATABASE_URL|REDIS_URL|JWT_SECRET|SPECKLE_\"",
          "purpose": "Confirm critical environment variables are set",
          "required": true,
          "validation": [
            "DATABASE_URL must be set",
            "REDIS_URL must be set",
            "JWT_SECRET must be minimum 32 characters",
            "SPECKLE_CLIENT_ID must be set",
            "SPECKLE_CLIENT_SECRET must be set",
            "SPECKLE_REDIRECT_URI must match staging URL"
          ]
        },
        {
          "step": "1.5",
          "name": "Pull latest code",
          "commands": [
            "git fetch origin",
            "git checkout develop",
            "git pull origin develop"
          ],
          "purpose": "Update to v2.1.1 with TypeScript fixes",
          "required": true,
          "expectedCommit": "4055896d"
        }
      ]
    },
    {
      "phase": 2,
      "name": "Build Production Images",
      "estimatedDuration": "20 minutes",
      "steps": [
        {
          "step": "2.1",
          "name": "Build with staging configuration",
          "command": "docker compose -f docker-compose.staging.yml build --no-cache",
          "purpose": "Build fresh images without cache",
          "required": true,
          "timeout": "1200s"
        },
        {
          "step": "2.2",
          "name": "Verify image sizes",
          "command": "docker images | grep ectropy",
          "purpose": "Ensure images built successfully",
          "required": true,
          "expectedImages": [
            "ectropy-api-gateway",
            "ectropy-mcp-server",
            "ectropy-web-dashboard"
          ]
        },
        {
          "step": "2.3",
          "name": "Tag images for staging",
          "commands": [
            "docker tag ectropy-api-gateway:latest ectropy-api-gateway:v2.1.1",
            "docker tag ectropy-mcp-server:latest ectropy-mcp-server:v2.1.1",
            "docker tag ectropy-web-dashboard:latest ectropy-web-dashboard:v2.1.1"
          ],
          "purpose": "Version tracking and rollback capability",
          "required": true
        }
      ]
    },
    {
      "phase": 3,
      "name": "Database Migration",
      "estimatedDuration": "10 minutes",
      "steps": [
        {
          "step": "3.1",
          "name": "Check current migration status",
          "command": "docker compose -f docker-compose.staging.yml exec postgres psql -U postgres -d ectropy -c \"SELECT * FROM _prisma_migrations ORDER BY finished_at DESC LIMIT 5;\"",
          "purpose": "Verify migration history",
          "required": true
        },
        {
          "step": "3.2",
          "name": "Apply new migrations",
          "commands": [
            "cd libs/database",
            "npx prisma migrate deploy --schema=./schema.prisma"
          ],
          "purpose": "Apply project_members table migration",
          "required": true,
          "rollbackRelevant": true,
          "migrations": ["004_project_members.sql"]
        },
        {
          "step": "3.3",
          "name": "Verify project_members table",
          "command": "docker compose -f docker-compose.staging.yml exec postgres psql -U postgres -d ectropy -c \"\\d project_members\"",
          "purpose": "Confirm new table exists",
          "required": true,
          "expectedColumns": [
            "id",
            "project_id",
            "user_id",
            "role",
            "created_at",
            "updated_at"
          ]
        }
      ]
    },
    {
      "phase": 4,
      "name": "Deploy Services",
      "estimatedDuration": "15 minutes",
      "steps": [
        {
          "step": "4.1",
          "name": "Start infrastructure services",
          "command": "docker compose -f docker-compose.staging.yml up -d postgres redis qdrant minio",
          "purpose": "Boot databases before applications",
          "required": true,
          "serviceOrder": "infrastructure-first"
        },
        {
          "step": "4.2",
          "name": "Wait for databases",
          "command": "sleep 30",
          "purpose": "Allow databases to initialize",
          "required": true,
          "waitDuration": "30s"
        },
        {
          "step": "4.3",
          "name": "Deploy application services",
          "command": "docker compose -f docker-compose.staging.yml up -d api-gateway mcp-server web-dashboard",
          "purpose": "Start Ectropy core services",
          "required": true,
          "services": [
            "api-gateway (port 4000)",
            "mcp-server (ports 3001-3002)",
            "web-dashboard (port 3000)"
          ]
        },
        {
          "step": "4.4",
          "name": "Deploy Speckle services",
          "command": "docker compose -f docker-compose.staging.yml up -d speckle-server speckle-frontend speckle-preview speckle-fileimport speckle-webhook",
          "purpose": "Start BIM integration services",
          "required": true,
          "services": [
            "speckle-server",
            "speckle-frontend",
            "speckle-preview",
            "speckle-fileimport",
            "speckle-webhook"
          ]
        },
        {
          "step": "4.5",
          "name": "Start nginx reverse proxy",
          "command": "docker compose -f docker-compose.staging.yml up -d nginx",
          "purpose": "Enable external access via HTTPS",
          "required": true,
          "routingConfig": "infrastructure/nginx/staging.conf"
        }
      ]
    },
    {
      "phase": 5,
      "name": "Health Check Validation",
      "estimatedDuration": "10 minutes",
      "steps": [
        {
          "step": "5.1",
          "name": "Wait for services to start",
          "command": "sleep 60",
          "purpose": "Allow containers to initialize",
          "required": true,
          "waitDuration": "60s"
        },
        {
          "step": "5.2",
          "name": "Check container status",
          "command": "docker compose -f docker-compose.staging.yml ps",
          "purpose": "Verify all containers are running",
          "required": true,
          "expectedState": "Up"
        },
        {
          "step": "5.3",
          "name": "Validate API Gateway health",
          "command": "curl -s https://staging.ectropy.com/api/health | jq .",
          "purpose": "Check API Gateway health endpoint",
          "required": true,
          "expectedStatus": 200,
          "expectedHealthScore": ">= 70",
          "healthCheckUrl": "https://staging.ectropy.com/api/health"
        },
        {
          "step": "5.4",
          "name": "Validate MCP Server health",
          "command": "curl -s https://staging.ectropy.com/mcp/health | jq .",
          "purpose": "Check MCP Server health endpoint",
          "required": true,
          "expectedStatus": 200,
          "healthCheckUrl": "https://staging.ectropy.com/mcp/health"
        },
        {
          "step": "5.5",
          "name": "Check container logs for errors",
          "commands": [
            "docker compose -f docker-compose.staging.yml logs --tail=50 api-gateway",
            "docker compose -f docker-compose.staging.yml logs --tail=50 mcp-server",
            "docker compose -f docker-compose.staging.yml logs --tail=50 web-dashboard"
          ],
          "purpose": "Identify startup errors",
          "required": true,
          "errorPatterns": [
            "Error",
            "FATAL",
            "Connection refused",
            "ECONNREFUSED"
          ]
        }
      ]
    },
    {
      "phase": 6,
      "name": "Smoke Tests",
      "estimatedDuration": "15 minutes",
      "steps": [
        {
          "step": "6.1",
          "name": "Test authentication endpoint",
          "command": "curl -X POST https://staging.ectropy.com/api/auth/login -H \"Content-Type: application/json\" -d '{\"email\":\"test@example.com\",\"password\":\"test123\"}'",
          "purpose": "Verify authentication flow",
          "required": true,
          "expectedStatus": [200, 401],
          "endpoint": "/api/auth/login"
        },
        {
          "step": "6.2",
          "name": "Test Speckle OAuth redirect",
          "command": "curl -I https://staging.ectropy.com/api/speckle/auth",
          "purpose": "Verify Speckle OAuth routing",
          "required": true,
          "expectedStatus": [302, 200],
          "endpoint": "/api/speckle/auth",
          "relatedFiles": [
            "apps/api-gateway/src/routes/speckle.routes.enterprise.ts"
          ]
        },
        {
          "step": "6.3",
          "name": "Test web dashboard availability",
          "command": "curl -I https://staging.ectropy.com/",
          "purpose": "Verify frontend is serving",
          "required": true,
          "expectedStatus": 200,
          "endpoint": "/"
        },
        {
          "step": "6.4",
          "name": "Test database connectivity",
          "command": "curl -s https://staging.ectropy.com/api/health | jq '.database.status'",
          "purpose": "Verify database connection",
          "required": true,
          "expectedValue": "connected",
          "expectedLatency": "< 100ms"
        },
        {
          "step": "6.5",
          "name": "Test Redis caching",
          "command": "curl -s https://staging.ectropy.com/api/health | jq '.services.redis'",
          "purpose": "Verify Redis is operational",
          "required": true,
          "expectedValue": "connected"
        }
      ]
    }
  ],
