        "step": 1,
        "name": "Stop current services",
        "command": "docker compose -f docker-compose.staging.yml down",
        "purpose": "Halt v2.1.1 deployment"
      },
      {
        "step": 2,
        "name": "Restore from backup",
        "command": "tar -xzf backups/pre-deployment-YYYYMMDD-HHMMSS.tar.gz -C data/",
        "purpose": "Restore previous data state",
        "note": "Replace YYYYMMDD-HHMMSS with actual backup timestamp"
      },
      {
        "step": 3,
        "name": "Start previous version",
        "command": "docker compose -f docker-compose.staging.yml up -d",
        "purpose": "Revert to previous stable deployment"
      },
      {
        "step": 4,
        "name": "Verify rollback",
        "command": "curl -s https://staging.ectropy.com/api/health",
        "purpose": "Confirm system is operational",
        "expectedStatus": 200
      }
    ],
    "estimatedRollbackTime": "10 minutes",
