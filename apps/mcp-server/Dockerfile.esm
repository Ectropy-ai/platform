FROM node:20-alpine

WORKDIR /app
RUN npm install -g pnpm@10.14.0

# Copy package files
COPY package*.json pnpm-lock.yaml ./
COPY scripts ./scripts

# Install pnpm and dependencies
RUN corepack enable && pnpm install --frozen-lockfile

# Copy source code
COPY . .

# Expose port
EXPOSE 3001

# Start application with ESM
CMD ["node", "--loader", "tsx/esm", "apps/mcp-server/src/server.ts"]
