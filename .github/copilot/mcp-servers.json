{
  "mcpServers": {
    "ectropy-validation": {
      "command": "node",
      "args": [
        "apps/mcp-server/src/server-simple.js"
      ],
      "env": {
        "NODE_ENV": "development",
        "PORT": "3001",
        "MCP_PORT": "3001",
        "API_GATEWAY_HOST": "localhost",
        "API_GATEWAY_PORT": "4000",
        "DATABASE_URL": "postgresql://postgres:postgres@localhost:5432/ectropy_test",
        "REDIS_HOST": "localhost",
        "REDIS_PORT": "6379",
        "VALIDATION_ONLY": "true"
      },
      "workingDirectory": "${GITHUB_WORKSPACE}",
      "timeout": 30000,
      "retry": {
        "attempts": 3,
        "delay": 2000
      }
    }
  }
}
