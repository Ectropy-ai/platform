{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compileOnSave": false,
  "compilerOptions": {
    "target": "ES2022",
    "module": "esnext",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable",
      "WebWorker",
      "ES2015.Promise",
      "ES2015.Core"
    ],
    "moduleResolution": "node",
    "typeRoots": ["./node_modules/@types", "./types"],
    "types": ["node", "jest"],
    "skipLibCheck": true,

    "jsx": "react-jsx",
    "outDir": "./dist",
    "rootDir": ".",
    "sourceMap": true,
    "inlineSourceMap": false,
    "declaration": true,
    "declarationMap": true,
    "removeComments": false,
    "preserveConstEnums": true,
    "incremental": true,
    "tsBuildInfoFile": "./dist/.tsbuildinfo",

    "strict": true,
    "noImplicitAny": false,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "strictBindCallApply": true,
    "strictPropertyInitialization": true,
    "noImplicitReturns": false,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": false,
    "exactOptionalPropertyTypes": false,
    "noImplicitThis": true,
    "alwaysStrict": true,
    "noImplicitOverride": false,
    "noPropertyAccessFromIndexSignature": false,
    "allowUnusedLabels": false,
    "allowUnreachableCode": false,
    "useUnknownInCatchVariables": true,

    "noUnusedLocals": false,
    "noUnusedParameters": false,

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "skipDefaultLibCheck": true,
    "importHelpers": true,

    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,

    "allowJs": false,
    "checkJs": false,
    "downlevelIteration": false,

    "baseUrl": ".",
    "paths": {
      "@ectropy/shared": ["libs/shared/src/index.ts"],
      "@ectropy/shared/*": ["libs/shared/src/*"],
      "@ectropy/shared/integrations": ["libs/shared/integrations/src/index.ts"],
      "@ectropy/shared/integrations/*": ["libs/shared/integrations/src/*"],
      "@ectropy/shared/audit": ["libs/shared/audit/src/index.ts"],
      "@ectropy/shared/audit/*": ["libs/shared/audit/src/*"],
      "@ectropy/shared/config": ["libs/shared/config/src/index.ts"],
      "@ectropy/shared/config/*": ["libs/shared/config/src/*"],
      "@ectropy/shared/errors": ["libs/shared/errors/src/index.ts"],
      "@ectropy/shared/errors/*": ["libs/shared/errors/src/*"],
      "@ectropy/shared/utils": ["libs/shared/utils/src/index.ts"],
      "@ectropy/shared/utils/*": ["libs/shared/utils/src/*"],
      "@ectropy/shared/middleware": ["libs/shared/middleware/src/index.ts"],
      "@ectropy/shared/middleware/*": ["libs/shared/middleware/src/*"],
      "@ectropy/shared/security": ["libs/shared/security/src/index.ts"],
      "@ectropy/shared/security/*": ["libs/shared/security/src/*"],
      "@ectropy/shared/types": ["libs/shared/types/src/index.ts"],
      "@ectropy/shared/types/*": ["libs/shared/types/src/*"],
      "@ectropy/auth": ["libs/auth/src/index.ts"],
      "@ectropy/auth/*": ["libs/auth/src/*"],
      "@ectropy/auth/enhanced": ["libs/auth/enhanced/index.ts"],
      "@ectropy/auth/enhanced/*": ["libs/auth/enhanced/*"],
      "@ectropy/database": ["packages/database/src/index.ts"],
      "@ectropy/database/*": ["packages/database/src/*"],
      "@ectropy/blockchain": ["libs/blockchain/src/index.ts"],
      "@ectropy/blockchain/*": ["libs/blockchain/src/*"],
      "@ectropy/ifc-processing": ["libs/ifc-processing/src/index.ts"],
      "@ectropy/ifc-processing/*": ["libs/ifc-processing/src/*"],
      "@ectropy/speckle-integration": ["libs/speckle-integration/src/index.ts"],
      "@ectropy/speckle-integration/*": ["libs/speckle-integration/src/*"],
      "@ectropy/ai-agents": ["libs/ai-agents/src/index.ts"],
      "@ectropy/ai-agents/*": ["libs/ai-agents/src/*"],
      "@ectropy/iot-edge": ["libs/iot-edge/src/index.ts"],
      "@ectropy/iot-edge/*": ["libs/iot-edge/src/*"],
      "@ectropy/secrets-management": ["libs/secrets-management/src/index.ts"],
      "@ectropy/secrets-management/*": ["libs/secrets-management/src/*"],
      "@ectropy/demo-scenarios": ["libs/demo-scenarios/src/index.ts"],
      "@ectropy/demo-scenarios/*": ["libs/demo-scenarios/src/*"],
      "@ectropy/mcp-server/*": ["apps/mcp-server/src/*"],
      "@apps/*": ["apps/*"],
      "@libs/*": ["libs/*"],
      "@/*": ["src/*"],
      "@/types": ["types/*"],
      "uuid": ["types/uuid.d.ts"],
      "type-fest": ["types/type-fest.d.ts"],
      "type-fest/*": ["types/type-fest.d.ts"],
      "express-rate-limit": ["types/express-rate-limit.d.ts"],
      "true-myth": ["types/true-myth.d.ts"],
      "true-myth/*": ["types/true-myth.d.ts"]
    }
  },

  "watchOptions": {
    "watchFile": "useFsEvents",
    "watchDirectory": "useFsEvents",
    "fallbackPolling": "dynamicPriority",
    "synchronousWatchDirectory": true,
    "excludeFiles": ["**/node_modules/**/*"]
  },

  "typeAcquisition": {
    "enable": false,
    "disableFilenameBasedTypeAcquisition": true
  },

  "include": [
    "apps/**/*.ts",
    "apps/**/*.tsx",
    "libs/**/*.ts",
    "libs/**/*.tsx",
    "config/**/*.ts",
    "global.d.ts",
    "types/**/*.ts",
    "types/**/*.d.ts"
  ],

  "exclude": [
    "node_modules",
    "dist",
    "build",
    "tmp",
    "coverage",
    ".nx",
    "__mocks__/**/*",
    "**/*.test.*",
    "**/*.spec.*",
    "**/tests/**/*",
    "**/__tests__/**/*",
    "**/*.js",
    "**/*.config.js",
    "scripts/**/*",
    "tools/**/*",
    "docs/**/*",
    "*.md",
    "archive/**/*",
    "backup*/**/*",
    ".setup-backups/**/*"
  ]
}
