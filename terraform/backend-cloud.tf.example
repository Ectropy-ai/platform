# ============================================================================
# Terraform Cloud Backend Configuration - RECOMMENDED FOR PRODUCTION
# ============================================================================
#
# Migration from DigitalOcean Spaces to Terraform Cloud
#
# WHY THIS CHANGE:
# - DigitalOcean Spaces (S3-compatible) does NOT support state locking
# - Without locking: concurrent terraform operations can corrupt state file
# - P0 Critical Gap identified in infrastructure analysis (2026-01-01)
#
# TERRAFORM CLOUD BENEFITS:
# - ✅ Built-in state locking (prevents concurrent operations)
# - ✅ State versioning with full history
# - ✅ Team collaboration with role-based access
# - ✅ Remote execution (optional)
# - ✅ Free tier: up to 500 resources
# - ✅ Audit logging
# - ✅ Cost estimation
# - ✅ Policy as code (Sentinel)
#
# MIGRATION STEPS:
#
# 1. Create Terraform Cloud Account & Organization
#    - Visit: https://app.terraform.io/signup
#    - Create organization: "ectropy" (or your preferred name)
#
# 2. Create Workspace
#    - Name: "ectropy-production" (or environment-specific)
#    - Execution mode: "Local" (runs on your machine, state in cloud)
#    - Or: "Remote" (runs in Terraform Cloud)
#
# 3. Authenticate
#    $ terraform login
#    # Follow prompts to generate API token
#    # Token stored in: ~/.terraform.d/credentials.tfrc.json
#
# 4. Rename This File
#    $ mv terraform/backend-cloud.tf.example terraform/backend-cloud.tf
#    $ mv terraform/backend.tf terraform/backend-spaces.tf.backup
#
# 5. Migrate State
#    $ cd terraform
#    $ terraform init -migrate-state
#    # Terraform will prompt: "Do you want to copy existing state to the new backend?"
#    # Answer: "yes"
#    # Your state will be safely migrated from DO Spaces to Terraform Cloud
#
# 6. Verify Migration
#    $ terraform plan
#    # Should show "No changes" if migration successful
#    # Check Terraform Cloud UI to see state file
#
# 7. CI/CD Integration (GitHub Actions)
#    - Add GitHub Secret: TF_API_TOKEN (from Terraform Cloud)
#    - Workflows will automatically use Terraform Cloud
#    - State locking works automatically in CI/CD
#
# COST: $0 (Free tier supports up to 500 resources)
# TIMELINE: 1-2 hours (including account setup and migration)
# RISK: Low (state migration is safe, can rollback if needed)
#
# ============================================================================

terraform {
  # Terraform Cloud Backend with State Locking
  cloud {
    organization = "ectropy"  # REPLACE with your Terraform Cloud organization name

    workspaces {
      # Option 1: Single workspace (simple)
      name = "ectropy-production"

      # Option 2: Workspace per environment (advanced)
      # tags = ["ectropy", "production"]
      # Use terraform workspace select/new to switch
    }
  }

  # Required Terraform version
  required_version = ">= 1.2.0"

  # Required providers (same as main configuration)
  required_providers {
    digitalocean = {
      source  = "digitalocean/digitalocean"
      version = "~> 2.0"
    }
    aws = {
      source  = "hashicorp/aws"
      version = "~> 5.0"
    }
  }
}

# ============================================================================
# ALTERNATIVE: Terraform Cloud with Remote Execution
# ============================================================================
#
# If you prefer Terraform to run in the cloud instead of locally:
#
# 1. In Terraform Cloud workspace settings:
#    - Change "Execution Mode" from "Local" to "Remote"
#
# 2. Configure environment variables in Terraform Cloud UI:
#    - DIGITALOCEAN_TOKEN (DigitalOcean API token)
#    - SPACES_ACCESS_KEY_ID (DigitalOcean Spaces access key)
#    - SPACES_SECRET_ACCESS_KEY (DigitalOcean Spaces secret key)
#
# 3. Run terraform plan/apply from local machine:
#    $ terraform plan
#    # Execution happens in Terraform Cloud, not locally
#    # You'll see streaming output in your terminal
#
# BENEFITS:
# - Consistent execution environment
# - No need to install Terraform locally
# - Credentials never on developer machines
# - Full audit trail of all operations
#
# ============================================================================

# ============================================================================
# ROLLBACK PLAN (If Migration Fails)
# ============================================================================
#
# If you need to rollback to DigitalOcean Spaces:
#
# 1. Rename files back:
#    $ mv terraform/backend-cloud.tf terraform/backend-cloud.tf.backup
#    $ mv terraform/backend-spaces.tf.backup terraform/backend.tf
#
# 2. Re-initialize:
#    $ terraform init -migrate-state
#    # Answer "yes" to copy state back to DO Spaces
#
# 3. Verify:
#    $ terraform plan
#    # Should show "No changes"
#
# NOTE: State is versioned in both locations during migration, so no data loss
#
# ============================================================================

# ============================================================================
# TEAM COLLABORATION SETUP
# ============================================================================
#
# After migration, invite team members:
#
# 1. Terraform Cloud UI → Settings → Team Access
# 2. Create teams: "Admins", "Developers", "Read-Only"
# 3. Assign permissions:
#    - Admins: Full access (plan, apply, state management)
#    - Developers: Plan, comment (cannot apply without approval)
#    - Read-Only: View runs, read state
#
# 4. Team members authenticate:
#    $ terraform login
#    # Each member gets their own API token
#
# 5. Approval workflow (optional):
#    - Require manual approval for applies
#    - Notifications via Slack/email
#    - Policy checks before apply
#
# ============================================================================
