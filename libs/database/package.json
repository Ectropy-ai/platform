{
  "name": "@ectropy/database-legacy",
  "version": "1.0.0",
  "description": "Database integration layer for PostgreSQL and Redis",
  "type": "module",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    }
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src/**/*.ts"
  },
  "dependencies": {
    "pg": "^8.16.3",
    "ioredis": "^5.8.2",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@types/pg": "^8.15.4",
    "eslint": "^9.31.0",
    "prettier": "^3.6.2",
    "typescript": "^5.8.3",
    "vitest": "^2.1.9"
  },
  "keywords": [
    "database",
    "postgresql",
    "redis",
    "cache",
    "health-check"
  ],
  "author": "Ectropy Team",
  "license": "MIT"
}
