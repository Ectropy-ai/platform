{
  "name": "@ectropy/database-legacy",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/database/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "libs/database/dist",
        "main": "libs/database/src/index.ts",
        "tsConfig": "libs/database/tsconfig.lib.json",
        "assets": ["libs/database/*.md"]
      },
      "dependsOn": ["@ectropy/shared:build"]
    },
    "migrate": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node libs/database/src/scripts/migrate.js",
        "cwd": "{workspaceRoot}"
      }
    },
    "seed": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node libs/database/src/scripts/seed.js",
        "cwd": "{workspaceRoot}"
      }
    },
    "reset": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node libs/database/src/scripts/reset.js",
        "cwd": "{workspaceRoot}"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["libs/database/**/*.js"]
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest run --passWithNoTests=false libs/database/src",
        "cwd": "{workspaceRoot}"
      }
    }
  },
  "tags": ["scope:database", "type:lib"]
}
