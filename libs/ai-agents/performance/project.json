{
  "name": "performance-agent",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/ai-agents/performance/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/ai-agents/performance",
        "main": "libs/ai-agents/performance/src/index.ts",
        "tsConfig": "libs/ai-agents/performance/tsconfig.lib.json",
        "assets": []
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["libs/ai-agents/performance/**/*.js"]
      }
    },
    "test": {
      "executor": "@nx/vite:test",
      "outputs": ["{workspaceRoot}/coverage/libs/ai-agents/performance"],
      "options": {
        "config": "libs/ai-agents/vitest.config.ts",
        "passWithNoTests": true,
        "reportsDirectory": "{workspaceRoot}/coverage/libs/ai-agents/performance"
      }
    },
    "type-check": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx tsc --noEmit -p libs/ai-agents/performance/tsconfig.lib.json"
      }
    }
  },
  "tags": ["scope:ai", "type:lib"],
  "implicitDependencies": ["@ectropy/ai-agents-shared"]
}
