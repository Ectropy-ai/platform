{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "moduleResolution": "bundler",
    "module": "ES2022",
    "outDir": "./dist",
    "declaration": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "rootDir": "../../"
  },
  "include": [
    "src/**/*",
    "shared/**/*",
    "codebase-advisor/**/*",
    "compliance/src/**/*",
    "performance/src/**/*",
    "procurement/src/**/*",
    "task-manager/src/**/*"
  ],
  "exclude": ["node_modules", "dist", "**/*.spec.ts", "**/*.test.ts"],
  "references": [
    {
      "path": "../shared"
    }
  ]
}
