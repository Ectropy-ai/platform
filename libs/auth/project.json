{
  "name": "@ectropy/auth",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/auth/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "@nx/esbuild:esbuild",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "libs/auth/dist",
        "main": "libs/auth/src/index.ts",
        "tsConfig": "libs/auth/tsconfig.lib.json",
        "assets": ["libs/auth/*.md"],
        "platform": "node",
        "format": ["esm"],
        "bundle": true,
        "thirdParty": false,
        "generatePackageJson": true,
        "external": [
          "@ectropy/shared",
          "@ectropy/database",
          "express",
          "jsonwebtoken",
          "bcryptjs",
          "speakeasy",
          "qrcode",
          "ioredis",
          "joi"
        ],
        "esbuildOptions": {
          "sourcemap": true,
          "outExtension": {
            ".js": ".js"
          }
        }
      },
      "dependsOn": ["@ectropy/shared:build", "@ectropy/database:build"]
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["libs/auth/**/*.js"]
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest run --passWithNoTests=false libs/auth/src",
        "cwd": "{workspaceRoot}"
      }
    }
  },
  "tags": ["scope:auth", "type:lib"]
}
