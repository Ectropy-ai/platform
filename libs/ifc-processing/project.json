{
  "name": "@ectropy/ifc-processing",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/ifc-processing/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "libs/ifc-processing/dist",
        "main": "libs/ifc-processing/src/index.ts",
        "tsConfig": "libs/ifc-processing/tsconfig.lib.json",
        "assets": ["libs/ifc-processing/*.md"]
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["libs/ifc-processing/**/*.js"]
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest run --passWithNoTests=false libs/ifc-processing/src",
        "cwd": "{workspaceRoot}"
      }
    }
  },
  "tags": ["scope:shared", "type:lib"]
}
