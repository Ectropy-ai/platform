{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../dist/out-tsc",
    "declaration": true,
    "types": ["node"],
    "module": "ES2022",
    "moduleResolution": "bundler"
  },
  "include": [
    "src/**/*.ts",
    "audit/src/**/*.ts",
    "config/src/**/*.ts",
    "types/src/**/*.ts",
    "middleware/src/**/*.ts",
    "security/src/**/*.ts",
    "utils/src/**/*.ts",
    "validation/src/**/*.ts",
    "errors/src/**/*.ts"
  ],
  "exclude": ["jest.config.ts", "**/*.spec.ts", "**/*.test.ts"]
}
