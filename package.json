{
  "name": "@ectropy/monorepo",
  "version": "1.3.0",
  "type": "module",
  "description": "Ectropy Construction Intelligence Platform",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "postinstall": "pnpm exec prisma generate && pnpm exec prisma generate --schema=prisma/schema.platform.prisma && pnpm exec prisma generate --schema=prisma/schema.shared.prisma",
    "prisma:generate": "pnpm exec prisma generate && pnpm exec prisma generate --schema=prisma/schema.platform.prisma && pnpm exec prisma generate --schema=prisma/schema.shared.prisma",
    "version:patch": "npm version patch -m 'chore: bump version to %s'",
    "version:minor": "npm version minor -m 'chore: bump version to %s'",
    "version:major": "npm version major -m 'chore: bump version to %s'",
    "version:check": "echo \"Current version: $(jq -r .version package.json)\"",
    "build": "pnpm nx run-many --target=build --all",
    "build:affected": "pnpm nx affected --target=build --base=origin/main --parallel=8",
    "build:core": "pnpm nx run-many --target=build --projects=mcp-server,api-gateway,web-dashboard --parallel=3",
    "build:web": "pnpm nx run web-dashboard:build",
    "build:api": "pnpm nx run api-gateway:build",
    "build:mcp": "pnpm nx run mcp-server:build",
    "test:build": "pnpm build:web && pnpm build:api && pnpm build:mcp",
    "lint:affected": "pnpm nx affected --target=lint --base=origin/main --parallel=8",
    "test:affected": "pnpm nx affected --target=test --base=origin/main --parallel=8",
    "test": "pnpm nx run-many -t test",
    "test:coverage": "pnpm nx run-many -t test -- --coverage && pnpm test:matrix:update",
    "test:mcp": "vitest run --config apps/mcp-server/vitest.config.ts",
    "test:api": "vitest run --config apps/api-gateway/vitest.config.ts",
    "test:e2e": "pnpm nx e2e web-dashboard-e2e && pnpm test:matrix:update",
    "test:e2e:ci": "pnpm nx e2e web-dashboard-e2e --configuration=ci && pnpm test:matrix:update",
    "test:e2e:production": "playwright test --config=playwright.production.config.ts",
    "test:e2e:production:ui": "playwright test --config=playwright.production.config.ts --ui",
    "test:e2e:production:report": "playwright show-report test-results/production",
    "test:e2e:docker": "playwright test --config=playwright.docker.config.ts",
    "test:e2e:docker:ui": "playwright test --config=playwright.docker.config.ts --ui",
    "test:e2e:docker:headed": "playwright test --config=playwright.docker.config.ts --headed",
    "test:e2e:staging": "E2E_BASE_URL=https://staging.ectropy.ai playwright test tests/playwright/staging-*.spec.ts tests/playwright/critical-*.spec.ts",
    "test:security": "playwright test tests/playwright/security-*.spec.ts --config=playwright.docker.config.ts",
    "test:security:xss": "playwright test tests/playwright/security-xss-csrf.spec.ts --config=playwright.docker.config.ts",
    "test:security:session": "playwright test tests/playwright/security-session-management.spec.ts --config=playwright.docker.config.ts",
    "test:api:crud": "playwright test tests/playwright/api-crud-operations.spec.ts --config=playwright.docker.config.ts",
    "test:p0": "playwright test tests/playwright/api-crud-operations.spec.ts tests/playwright/security-*.spec.ts --config=playwright.docker.config.ts --reporter=list",
    "test:p0:report": "playwright test tests/playwright/api-crud-operations.spec.ts tests/playwright/security-*.spec.ts --config=playwright.docker.config.ts --reporter=html",
    "test:enterprise": "pnpm test:p0 && pnpm test:e2e:docker && pnpm test:matrix:update",
    "test:matrix:update": "tsx scripts/testing/update-test-matrix.ts",
    "posttest": "pnpm test:matrix:update || true",
    "test:validate:fixtures": "tsx scripts/testing/validate-fixtures.ts",
    "test:validate:coverage": "tsx scripts/testing/validate-coverage.ts",
    "test:validate:deliverables": "tsx scripts/testing/validate-deliverables.ts",
    "test:generate": "tsx scripts/testing/generate-test.ts",
    "validate:deps": "node scripts/validate-dependencies.mjs",
    "validate:prepare": "node scripts/test-prepare-scripts.mjs",
    "validate": "pnpm validate:deps && pnpm validate:prepare",
    "docs:validate": "tsx scripts/docs/validate-json-schemas.ts",
    "docs:normalize": "tsx scripts/docs/normalize-schemas.ts",
    "docs:generate": "node scripts/docs/generate-current-truth-md.js && node scripts/docs/generate-decision-log.cjs && node scripts/docs/generate-infrastructure-catalog-md.cjs && tsx scripts/docs/generate-api-docs.ts && tsx scripts/docs/generate-architecture-docs.ts && tsx scripts/docs/generate-deployment-runbook.ts && tsx scripts/docs/generate-development-docs.ts && tsx scripts/docs/generate-docker-compose-docs.ts",
    "docs:generate:api": "tsx scripts/docs/generate-api-docs.ts",
    "docs:generate:architecture": "tsx scripts/docs/generate-architecture-docs.ts",
    "docs:generate:deployment": "tsx scripts/docs/generate-deployment-runbook.ts",
    "docs:generate:development": "tsx scripts/docs/generate-development-docs.ts",
    "docs:generate:docker": "tsx scripts/docs/generate-docker-compose-docs.ts",
    "roadmap:sync:pull": "tsx scripts/roadmap/sync-roadmap.ts pull",
    "roadmap:sync:push": "tsx scripts/roadmap/sync-roadmap.ts push",
    "roadmap:sync:status": "tsx scripts/roadmap/sync-roadmap.ts status",
    "truth": "./scripts/truth-baseline.sh",
    "clean": "rm -rf dist node_modules apps/*/node_modules libs/*/node_modules",
    "reset": "pnpm clean && pnpm install && pnpm nx reset"
  },
