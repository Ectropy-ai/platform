# Production Configuration Template
# Copy to .env.production and populate with actual values

# Database Configuration
DATABASE_URL=postgresql://user:password@host:5432/database
REDIS_URL=redis://host:6379

# API Keys (NEVER commit actual values)
RATE_LIMITER_SECRET=your-secret-here
API_SECRET_KEY=your-api-secret-here

# Application Settings  
NODE_ENV=production
PORT=3000
LOG_LEVEL=info

# Security Settings
CORS_ORIGIN=https://your-domain.com
SESSION_SECRET=your-session-secret-here

# JWT Configuration
JWT_SECRET=your-jwt-secret-here

# Database Connection Settings
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=ectropy_production
DATABASE_USER=ectropy_user
DATABASE_PASSWORD=your-database-password-here

# Optional Services
OPENAI_API_KEY=your-openai-key-here
QDRANT_PORT=6333