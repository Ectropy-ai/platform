# ============================================================================
# DNS Management - Cloudflare Provider
# ============================================================================
# Date: 2026-02-02
# Purpose: Infrastructure-as-code for ectropy.ai DNS records
# Root Cause: #0 - Eliminate manual DNS drift and configuration errors
# Pattern: Terraform GitOps for DNS (staging.ectropy.ai pointed to wrong IP)
# Compliance: Prevent manual errors, audit trail via Terraform state
# ============================================================================
# Cloudflare Provider Configuration
# ============================================================================
# API Token: Requires Zone:Read, DNS:Edit permissions for ectropy.ai
# Set via environment variable: CLOUDFLARE_API_TOKEN or TF_VAR_cloudflare_api_token

provider "cloudflare" {
  api_token = var.cloudflare_api_token
}

# ============================================================================
# Variables
# ============================================================================

variable "cloudflare_api_token" {
  description = "Cloudflare API token with Zone:Read and DNS:Edit permissions"
  type        = string
  sensitive   = true
}

variable "cloudflare_zone_id" {
  description = "Cloudflare Zone ID for ectropy.ai"
  type        = string
  # Zone ID for ectropy.ai (obtain from Cloudflare dashboard)
  default     = "" # Will be populated after obtaining from Cloudflare
}

# ============================================================================
# DNS Records - Staging Environment
# ============================================================================

# Staging A Record (Load Balancer)
resource "cloudflare_record" "staging" {
  zone_id = var.cloudflare_zone_id
  name    = "staging"
  content = digitalocean_loadbalancer.staging.ip
  type    = "A"
  ttl     = 300 # 5 minutes for faster failover
  proxied = true # Cloudflare proxy enabled (SSL, caching, DDoS protection)
  comment = "Staging environment - VPC isolated (143.244.210.44)"
}

# Staging API (explicit subdomain if needed)
resource "cloudflare_record" "staging_api" {
  zone_id = var.cloudflare_zone_id
  name    = "api.staging"
  content = digitalocean_loadbalancer.staging.ip
  type    = "A"
  ttl     = 300
  proxied = true
  comment = "Staging API endpoint"
}

# ============================================================================
# DNS Records - Production Environment
# ============================================================================
# NOTE: Production records commented until production deployment validated
# Root Cause: Production in alpha state, never deployed (no app running)
# Uncommenting requires:
#   1. Production load balancer defined in Terraform
#   2. Application successfully deployed to production
#   3. Health checks passing

