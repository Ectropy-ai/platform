# ============================================================================
# DNS Records - Development/Testing (if needed)
# ============================================================================

# Development environment (optional)
# resource "cloudflare_record" "dev" {
#   zone_id = var.cloudflare_zone_id
#   name    = "dev"
#   content = "dev-server-ip-here"
#   type    = "A"
#   ttl     = 300
#   proxied = true
#   comment = "Development environment"
# }

# ============================================================================
# DNS Outputs
# ============================================================================

output "staging_dns" {
  description = "Staging DNS hostname"
  value       = cloudflare_record.staging.hostname
}

output "staging_dns_target" {
  description = "Staging DNS target IP (Load Balancer)"
  value       = digitalocean_loadbalancer.staging.ip
}

# ============================================================================
# DNS Management Pattern
# ============================================================================
# Enterprise GitOps pattern for DNS:
#   1. Cloudflare API Token stored in terraform_deploy_key.tfvars (gitignored)
#   2. Zone ID obtained from Cloudflare dashboard
#   3. DNS records managed via Terraform (no manual changes)
#   4. Automatic updates when load balancer IPs change
#   5. Audit trail via Terraform state history
#
# Initial Setup:
#   1. Obtain Cloudflare API Token with Zone:Read + DNS:Edit permissions
#   2. Obtain Zone ID for ectropy.ai from Cloudflare dashboard
#   3. Add to terraform_deploy_key.tfvars:
#      cloudflare_api_token = "your-token-here"
#      cloudflare_zone_id = "your-zone-id-here"
#   4. Import existing DNS records:
#      terraform import cloudflare_record.staging <zone_id>/<record_id>
#   5. Run terraform apply to sync state
#
# Benefits:
#   ✅ No manual DNS configuration drift
#   ✅ Automatic IP updates when infrastructure changes
#   ✅ Version control for DNS changes
#   ✅ Audit trail via Terraform state
#   ✅ Prevents errors like staging pointing to wrong IP
# ============================================================================
