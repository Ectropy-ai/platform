# Git LFS Configuration for Evidence Archival
# Track archived evidence files in Git LFS to keep repository size under 100MB
# Files older than 30 days will be archived and compressed to .tar.gz format

# Archive files (compressed evidence)
evidence/archive/*.tar.gz filter=lfs diff=lfs merge=lfs -text

# Large binary assets that may be added in the future
*.zip filter=lfs diff=lfs merge=lfs -text
*.7z filter=lfs diff=lfs merge=lfs -text

# Large media files (if needed for documentation)
*.mp4 filter=lfs diff=lfs merge=lfs -text
*.mov filter=lfs diff=lfs merge=lfs -text
*.avi filter=lfs diff=lfs merge=lfs -text

# Database dumps (if used for backup)
*.sql.gz filter=lfs diff=lfs merge=lfs -text
*.dump.gz filter=lfs diff=lfs merge=lfs -text
*.png binary
*.jpg binary
*.svg binary

# =============================================================================
# Line Ending Configuration for Cross-Platform Development
# Enterprise best practice: Ensure consistent line endings across Windows/Linux
# =============================================================================

# Shell scripts must use LF (Unix) line endings for Docker/Linux compatibility
*.sh text eol=lf

# Dockerfiles must use LF line endings
Dockerfile* text eol=lf

# SQL scripts should use LF for consistency
*.sql text eol=lf

# YAML files (Docker Compose, CI/CD) should use LF
*.yml text eol=lf
*.yaml text eol=lf

# Default behavior: auto-detect text files and normalize to LF
* text=auto eol=lf
