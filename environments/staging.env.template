# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
NODE_ENV=staging
PORT=4000
WEB_PORT=3002
HOST=0.0.0.0
API_PORT=4000
ENVIRONMENT=staging
DEPLOYMENT_STAGE=staging

# =============================================================================
# DATABASE CONFIGURATION (REPLACE WITH SECURE VALUES)
# =============================================================================
DB_HOST=speckle-postgres
DB_PORT=5432
DB_NAME=ectropy_staging
DB_USER=postgres
# IMPORTANT: Replace with a strong, unique password (32+ characters)
DB_PASSWORD=REPLACE_WITH_SECURE_STAGING_DB_PASSWORD_32_CHARS_MIN
DATABASE_URL=postgresql://postgres:REPLACE_WITH_SECURE_STAGING_DB_PASSWORD_32_CHARS_MIN@speckle-postgres:5432/ectropy_staging

# PostgreSQL Docker Configuration
POSTGRES_PASSWORD=REPLACE_WITH_SECURE_STAGING_POSTGRES_PASSWORD
SPECKLE_POSTGRES_PASSWORD=REPLACE_WITH_SECURE_STAGING_SPECKLE_PASSWORD

# Database Pool Configuration - Staging optimized
DB_MAX_CONNECTIONS=30
DB_SSL=true
DB_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=60000

# =============================================================================
# REDIS CONFIGURATION (REPLACE WITH SECURE VALUES)
# =============================================================================
REDIS_HOST=speckle-redis
REDIS_PORT=6379
REDIS_PASSWORD=REPLACE_WITH_SECURE_STAGING_REDIS_PASSWORD
REDIS_URL=redis://:REPLACE_WITH_SECURE_STAGING_REDIS_PASSWORD@speckle-redis:6379
REDIS_MAX_MEMORY=512mb
REDIS_KEY_PREFIX=ectropy:staging:

# =============================================================================
# OAUTH 2.0 CONFIGURATION (REPLACE WITH ACTUAL CREDENTIALS)
# =============================================================================
# Google OAuth Configuration
# Get credentials from: https://console.cloud.google.com/apis/credentials
# Authorized origins: http://143.198.154.94, http://143.198.154.94:4000
# Redirect URIs: http://143.198.154.94:4000/auth/google/callback
GOOGLE_CLIENT_ID=REPLACE_WITH_YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=REPLACE_WITH_YOUR_GOOGLE_CLIENT_SECRET

# GitHub OAuth Configuration (Optional)
# Get credentials from: https://github.com/settings/developers
GITHUB_CLIENT_ID=REPLACE_WITH_YOUR_GITHUB_CLIENT_ID
GITHUB_CLIENT_SECRET=REPLACE_WITH_YOUR_GITHUB_CLIENT_SECRET

# OAuth Configuration
API_BASE_URL=http://143.198.154.94:4000
FRONTEND_URL=http://143.198.154.94:3002

# =============================================================================
# JWT & AUTHENTICATION CONFIGURATION (REPLACE WITH SECURE VALUES)
# =============================================================================
# CRITICAL: Use cryptographically secure random strings (64+ characters)
JWT_SECRET=REPLACE_WITH_CRYPTOGRAPHICALLY_SECURE_JWT_SECRET_64_CHARS_MIN
JWT_REFRESH_SECRET=REPLACE_WITH_SECURE_JWT_REFRESH_SECRET_64_CHARS_MIN
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=ectropy-staging
JWT_AUDIENCE=ectropy-users

# =============================================================================
# SESSION & SECURITY CONFIGURATION (REPLACE WITH SECURE VALUES)
# =============================================================================
SESSION_SECRET=REPLACE_WITH_SESSION_SECRET_32_CHARS_MIN
ENCRYPTION_KEY=REPLACE_WITH_32_BYTE_ENCRYPTION_KEY
BCRYPT_SALT_ROUNDS=12

# CORS Origins (comma-separated) - Staging domains
CORS_ORIGINS=http://localhost:3002,https://staging.ectropy.com,https://staging-api.ectropy.com

# Rate Limiting - Staging appropriate
RATE_LIMIT_MAX=1000
RATE_LIMIT_WINDOW=900000

# Security Features - Staging hardened
HELMET_ENABLED=true
CSRF_ENABLED=true
SSL_ENABLED=false
FORCE_HTTPS=false

