SPECKLE_FILEIMPORT_TIMEOUT=1800
SPECKLE_DB_HOST=speckle-postgres
SPECKLE_DB_PORT=5433
SPECKLE_DB_NAME=speckle
SPECKLE_DB_USER=speckle

