# =============================================================================
# ECTROPY PLATFORM - BASE ENVIRONMENT CONFIGURATION
# =============================================================================

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
NODE_ENV=__NODE_ENV__
PORT=__PORT__
HOST=0.0.0.0

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
DB_HOST=__DB_HOST__
DB_PORT=__DB_PORT__
DB_NAME=__DB_NAME__
DB_USER=__DB_USER__
DB_PASSWORD=__DB_PASSWORD__
DATABASE_URL=postgresql://__DB_USER__:__DB_PASSWORD__@__DB_HOST__:__DB_PORT__/__DB_NAME__

# Database Pool Configuration
DB_MAX_CONNECTIONS=__DB_MAX_CONNECTIONS__
DB_SSL=__DB_SSL__
DB_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=60000

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================
REDIS_HOST=__REDIS_HOST__
REDIS_PORT=__REDIS_PORT__
REDIS_PASSWORD=__REDIS_PASSWORD__
REDIS_URL=redis://:__REDIS_PASSWORD__@__REDIS_HOST__:__REDIS_PORT__
REDIS_MAX_MEMORY=__REDIS_MAX_MEMORY__
REDIS_KEY_PREFIX=ectropy:__ENV_PREFIX__:

# =============================================================================
# JWT & AUTHENTICATION
# =============================================================================
JWT_SECRET=__JWT_SECRET__
JWT_REFRESH_SECRET=__JWT_REFRESH_SECRET__
JWT_EXPIRES_IN=__JWT_EXPIRES_IN__
JWT_REFRESH_EXPIRES_IN=__JWT_REFRESH_EXPIRES_IN__
JWT_ISSUER=ectropy-__ENV_PREFIX__
JWT_AUDIENCE=ectropy-users

# =============================================================================
# SESSION & SECURITY
# =============================================================================
SESSION_SECRET=__SESSION_SECRET__
ENCRYPTION_KEY=__ENCRYPTION_KEY__

# CORS Origins (comma-separated)
CORS_ORIGINS=__CORS_ORIGINS__

# Rate Limiting
RATE_LIMIT_MAX=__RATE_LIMIT_MAX__
RATE_LIMIT_WINDOW=__RATE_LIMIT_WINDOW__

# Security Features
HELMET_ENABLED=true
CSRF_ENABLED=__CSRF_ENABLED__

# =============================================================================
# LOGGING & MONITORING
# =============================================================================
LOG_LEVEL=__LOG_LEVEL__
LOG_FORMAT=json
LOG_DIR=/var/log/ectropy
LOG_MAX_SIZE=10485760
LOG_MAX_FILES=5

# Monitoring
MONITORING_ENABLED=__MONITORING_ENABLED__
HEALTH_CHECK_INTERVAL=30000
METRICS_ENABLED=__METRICS_ENABLED__
PROMETHEUS_ENABLED=__PROMETHEUS_ENABLED__

# =============================================================================
# PERFORMANCE
# =============================================================================
CLUSTER_MODE=__CLUSTER_MODE__
MAX_CONCURRENT_REQUESTS=__MAX_CONCURRENT_REQUESTS__
REQUEST_TIMEOUT=__REQUEST_TIMEOUT__

# =============================================================================
# FEATURE FLAGS
# =============================================================================
ENABLE_REALTIME=__ENABLE_REALTIME__
ENABLE_BIM_VIEWER=__ENABLE_BIM_VIEWER__
ENABLE_ANALYTICS=__ENABLE_ANALYTICS__
ENABLE_BLOCKCHAIN=__ENABLE_BLOCKCHAIN__
ENABLE_AI_AGENTS=__ENABLE_AI_AGENTS__
