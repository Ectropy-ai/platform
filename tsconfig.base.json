{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "allowJs": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "removeComments": false,
    "baseUrl": ".",
    "paths": {
      "@ectropy/shared/config": ["libs/shared/config/src/index.ts"],
      "@ectropy/shared/integrations": ["libs/shared/integrations/src"],
      "@ectropy/shared/audit": ["libs/shared/audit/src"],
      "@ectropy/shared/utils/browser": ["libs/shared/utils/src/browser.ts"],
      "@ectropy/shared/utils": ["libs/shared/utils/src/index.ts"],
      "@ectropy/shared/types": ["libs/shared/types/src/index.ts"],
      "@ectropy/shared/types/*": ["libs/shared/types/src/*"],
      "@ectropy/shared": ["libs/shared/src/index.ts"],
      "@ectropy/shared/*": ["libs/shared/src/*"],
      "@ectropy/ai-agents/*": ["libs/ai-agents/src/*"],
      "@ectropy/ai-agents-shared": ["libs/ai-agents/shared/index.ts"],
      "@ectropy/ai-agents-shared/*": ["libs/ai-agents/shared/*"],
      "@ectropy/ifc-processing": ["libs/ifc-processing/src/index.ts"],
      "@ectropy/speckle-integration": ["libs/speckle-integration/src/index.ts"],
      "@ectropy/demo-scenarios": ["libs/demo-scenarios/src/index.ts"],
      "@ectropy/mcp-server/*": ["apps/mcp-server/src/*"]
    }
  },
  "exclude": [
    "node_modules",
    "dist",
    "build",
    "archive",
    "**/*.spec.ts",
    "**/*.test.ts"
  ]
}
