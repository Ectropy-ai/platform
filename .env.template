# =============================================================================
# ECTROPY PLATFORM - ENVIRONMENT TEMPLATE
# =============================================================================
# INSTRUCTIONS:
# 1. Copy this file to .env (NOT tracked in git)
# 2. Replace ALL placeholder values with actual secure values
# 3. See environments/ directory for environment-specific templates
# =============================================================================

# ─────────────────────────────────────────────────────
# Anthropic API (used by MCP Server and SEPPA)
# ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─────────────────────────────────────────────────────
# SEPPA AI Provider (packages/@ectropy/ai-provider)
# Controls which AI backend powers SEPPA responses.
#
# SEPPA_PROVIDER options:
#   anthropic  — Anthropic API (cloud deployments,
#                Qullqa, Ectropy.ai). Default.
#   ollama     — Local Ollama (JtC edge server,
#                Karbon 521, air-gapped sites).
# ─────────────────────────────────────────────────────
SEPPA_PROVIDER=anthropic

# Required when SEPPA_PROVIDER=anthropic
# ANTHROPIC_API_KEY is already documented above —
# no duplicate needed here.

# Optional: override Anthropic model
# Default: claude-sonnet-4-20250514
ANTHROPIC_MODEL=

# Required when SEPPA_PROVIDER=ollama
# Default: http://localhost:11434
OLLAMA_BASE_URL=http://ollama:11434

# Optional: override Ollama model
# Default: qwen2.5:7b-instruct-q4_K_M
OLLAMA_MODEL=
