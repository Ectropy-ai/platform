// ==============================================================================
// Model: DocumentationDecision
// Source: decision-log.json .decisions[]
// URN: urn:luhtech:{ventureId}:decision:{decisionId}
// ==============================================================================
model DocumentationDecision {
  id         String @id @default(uuid()) @db.Uuid
  urn        String @unique @db.VarChar(300)
  venture_id String @map("venture_id") @db.VarChar(100)

  decision_id String            @map("decision_id") @db.VarChar(200)
  title       String            @db.VarChar(500)
  status      DocDecisionStatus @default(PROPOSED)
  category    String            @db.VarChar(100)
  impact      DocDecisionImpact @default(MEDIUM)
  proposed_by String?           @map("proposed_by") @db.VarChar(255)

  // Dates
  proposed_date    String? @map("proposed_date") @db.VarChar(30)
  approved_date    String? @map("approved_date") @db.VarChar(30)
  implemented_date String? @map("implemented_date") @db.VarChar(30)

  // Content
  context      String? @db.Text
  decision     String? @db.Text
  consequences String? @db.Text
  rationale    String? @db.Text

  // Alternatives (array of {title, description, pros, cons, effort, risk, rejectionReason})
  alternatives Json? @db.JsonB

  // Related
  related_decisions      String[] @default([]) @map("related_decisions")
  supersedes             String?  @db.VarChar(200)
  superseded_by          String?  @map("superseded_by") @db.VarChar(200)
  evidence               String[] @default([])
  tags                   String[] @default([])
  impacted_deliverables  String[] @default([]) @map("impacted_deliverables")
  impacted_services      String[] @default([]) @map("impacted_services")
  impacted_infrastructure String[] @default([]) @map("impacted_infrastructure")
  implementation_notes   String?  @map("implementation_notes") @db.Text

  // Graph metadata
  graph_metadata Json? @map("graph_metadata") @db.JsonB

  // Timestamps
  created_at DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updated_at DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  venture RoadmapVenture @relation(fields: [venture_id], references: [venture_id], onDelete: Cascade)

  @@unique([venture_id, decision_id])
  @@index([venture_id])
  @@index([status])
  @@index([category])
  @@index([impact])
  @@map("documentation_decisions")
}

