model USFAttribution {
  id               String   @id @default(uuid()) @db.Uuid
  work_packet_id   String   @map("work_packet_id") @db.Uuid
  profile_id       String   @map("profile_id") @db.Uuid
  contribution_pct Decimal? @map("contribution_pct") @db.Decimal(5, 2)
  quality_contrib  Decimal? @map("quality_contrib") @db.Decimal(4, 3)
  cost_contrib     Decimal? @map("cost_contrib") @db.Decimal(4, 3)
  speed_contrib    Decimal? @map("speed_contrib") @db.Decimal(4, 3)
  notes            String?  @db.Text

  created_at DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  // Relations
  work_packet USFWorkPacket @relation(fields: [work_packet_id], references: [id], onDelete: Cascade)
  profile     USFProfile    @relation(fields: [profile_id], references: [id], onDelete: Cascade)

  @@unique([work_packet_id, profile_id])
  @@index([work_packet_id])
  @@index([profile_id])
  @@map("usf_attributions")
}

// ==============================================================================
// Dual-Process Decision Models (DP-M1)
// ==============================================================================
// Implements Kahneman's System 1/System 2 decision framework for construction
// System 1: Fast, intuitive, pattern-based decisions (field-level)
// System 2: Slow, deliberate, analytical decisions (escalation)
// URN: urn:luhtech:{project}:decision-event:{eventId}
//      urn:luhtech:{project}:success-pattern:{patternId}
//      urn:luhtech:{project}:sdi-snapshot:{snapshotId}
// ==============================================================================

enum DecisionProcessType {
  SYSTEM_1 // Fast, intuitive, pattern-matched
  SYSTEM_2 // Slow, deliberate, analytical
  HYBRID // Started as System 1, escalated to System 2
  AUTO_APPROVED // Pre-approved pattern match
}

enum DecisionEventType {
  INITIATED // Decision request created
  PATTERN_MATCHED // System 1 pattern recognition
  ESCALATED // Moved to System 2 processing
  ANALYZED // System 2 analysis complete
  APPROVED // Final approval
  REJECTED // Final rejection
  DEFERRED // Postponed for more info
  SUPERSEDED // Replaced by another decision
  ACKNOWLEDGED // Worker acknowledged
}

enum PatternConfidenceLevel {
  LOW // <60% confidence
  MEDIUM // 60-80% confidence
  HIGH // 80-95% confidence
  VERIFIED // >95% with validation
}

enum SDISnapshotType {
  PERIODIC // Scheduled snapshot
  EVENT_TRIGGERED // Triggered by significant event
  PRE_INSPECTION // Before inspection
  POST_INSPECTION // After inspection
  MILESTONE // Project milestone
  ANOMALY // Detected anomaly
}

// ==============================================================================
// Model 17: DecisionEvent
// Tracks the dual-process decision lifecycle events
// ==============================================================================
model DecisionEvent {
  id           String              @id @default(uuid()) @db.Uuid
  urn          String              @unique @db.VarChar(200) // urn:luhtech:{project}:decision-event:{eventId}
  project_id   String              @map("project_id") @db.Uuid
  event_id     String              @map("event_id") @db.VarChar(30) // DEVT-2026-0001
  decision_urn String              @map("decision_urn") @db.VarChar(200) // Reference to PMDecision
  event_type   DecisionEventType   @map("event_type")
  process_type DecisionProcessType @map("process_type")

  // Timing metrics (critical for System 1 vs 2 classification)
  processing_time_ms  Int? @map("processing_time_ms")
  time_to_decision_ms Int? @map("time_to_decision_ms")
  queue_wait_ms       Int? @map("queue_wait_ms")

  // Pattern matching (System 1)
  pattern_id          String?  @map("pattern_id") @db.VarChar(200) // Reference to SuccessPattern if matched
  pattern_confidence  Decimal? @map("pattern_confidence") @db.Decimal(4, 3)
  pattern_match_score Decimal? @map("pattern_match_score") @db.Decimal(4, 3)

  // Authority context
  authority_level Int?    @map("authority_level") // 0-6
  actor_urn       String? @map("actor_urn") @db.VarChar(200) // Who triggered event
  delegated_from  String? @map("delegated_from") @db.VarChar(200)

  // Voxel context
  voxel_urn         String? @map("voxel_urn") @db.VarChar(200)
  location_verified Boolean @default(false) @map("location_verified")

  // Cognitive load indicators
  concurrent_decisions Int?     @map("concurrent_decisions") // How many active decisions
  actor_fatigue_score  Decimal? @map("actor_fatigue_score") @db.Decimal(4, 3)
  time_of_day          String?  @map("time_of_day") @db.VarChar(20) // morning, afternoon, etc.

  // AI analysis
  ai_recommendation String?  @map("ai_recommendation") @db.VarChar(50)
  ai_confidence     Decimal? @map("ai_confidence") @db.Decimal(4, 3)
  ai_reasoning      Json?    @map("ai_reasoning") @db.JsonB

  // Outcome (for completed events)
  outcome       String?  @db.VarChar(50)
  outcome_value Decimal? @map("outcome_value") @db.Decimal(15, 2) // $ value impact
  quality_score Decimal? @map("quality_score") @db.Decimal(4, 3)

  // Evidence
  evidence Json?   @db.JsonB
  notes    String? @db.Text

  // Graph metadata
  graph_metadata Json? @map("graph_metadata") @db.JsonB
  meta           Json? @db.JsonB

  // Timestamps
  event_timestamp DateTime @default(now()) @map("event_timestamp") @db.Timestamptz(6)
  created_at      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([project_id, event_id])
  @@index([urn])
  @@index([decision_urn])
  @@index([project_id, event_type])
  @@index([process_type])
  @@index([pattern_id])
  @@index([event_timestamp(sort: Desc)])
  @@map("decision_events")
}

// ==============================================================================
// Model 18: SuccessPattern
// Captures patterns from successful decisions for System 1 matching
// ==============================================================================
model SuccessPattern {
  id          String  @id @default(uuid()) @db.Uuid
  urn         String  @unique @db.VarChar(200) // urn:luhtech:{project}:success-pattern:{patternId}
  project_id  String? @map("project_id") @db.Uuid // Null for global patterns
  pattern_id  String  @map("pattern_id") @db.VarChar(30) // PAT-2026-0001
  name        String  @db.VarChar(200)
  description String? @db.Text

  // Pattern classification
  category    String  @db.VarChar(100) // tolerance, schedule, budget, safety, etc.
  subcategory String? @db.VarChar(100)
  trade       String? @db.VarChar(100)
  work_type   String? @map("work_type") @db.VarChar(100)

  // Pattern definition
  trigger_conditions   Json  @map("trigger_conditions") @db.JsonB // Conditions that activate pattern
  context_requirements Json? @map("context_requirements") @db.JsonB // Required context for match
  decision_template    Json  @map("decision_template") @db.JsonB // Template for auto-decision

  // Confidence metrics
  confidence_level         PatternConfidenceLevel @default(LOW) @map("confidence_level")
  confidence_score         Decimal                @default(0.5) @map("confidence_score") @db.Decimal(4, 3)
  min_confidence_threshold Decimal                @default(0.7) @map("min_confidence_threshold") @db.Decimal(4, 3)

  // Authority scope
  max_authority_level  Int     @default(1) @map("max_authority_level") // Max level that can auto-approve
  auto_approve_enabled Boolean @default(false) @map("auto_approve_enabled")
  requires_location    Boolean @default(true) @map("requires_location")

  // Limits and constraints
  budget_limit         Decimal? @map("budget_limit") @db.Decimal(15, 2)
  schedule_limit_hours Int?     @map("schedule_limit_hours")
  variance_limit       Decimal? @map("variance_limit") @db.Decimal(6, 4) // e.g., 0.0625 = 1/16 inch

  // Learning metrics
  times_matched          Int      @default(0) @map("times_matched")
  times_succeeded        Int      @default(0) @map("times_succeeded")
  times_failed           Int      @default(0) @map("times_failed")
  times_overridden       Int      @default(0) @map("times_overridden")
  success_rate           Decimal? @map("success_rate") @db.Decimal(4, 3)
  avg_processing_time_ms Int?     @map("avg_processing_time_ms")
  total_value_saved      Decimal? @map("total_value_saved") @db.Decimal(15, 2)

  // Source decisions (training data)
  source_decisions String[] @default([]) @map("source_decisions") // Array of decision URNs
  last_match_urn   String?  @map("last_match_urn") @db.VarChar(200)

  // Validity
  is_active     Boolean   @default(true) @map("is_active")
  valid_from    DateTime  @default(now()) @map("valid_from") @db.Timestamptz(6)
  valid_until   DateTime? @map("valid_until") @db.Timestamptz(6)
  deprecated_by String?   @map("deprecated_by") @db.VarChar(200)

  // Version control
  version            Int     @default(1)
  parent_pattern_urn String? @map("parent_pattern_urn") @db.VarChar(200)

  // Graph metadata
  graph_metadata Json? @map("graph_metadata") @db.JsonB
  meta           Json? @db.JsonB

  // Timestamps
  last_matched_at DateTime? @map("last_matched_at") @db.Timestamptz(6)
  created_at      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updated_at      DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([project_id, pattern_id])
  @@index([urn])
  @@index([category])
  @@index([trade])
  @@index([confidence_level])
  @@index([is_active, confidence_score(sort: Desc)])
  @@index([created_at(sort: Desc)])
  @@map("success_patterns")
}

// ==============================================================================
// Model 19: SDISnapshot
// Spatial Decision Intelligence snapshot for voxel decision state
// ==============================================================================
model SDISnapshot {
  id            String          @id @default(uuid()) @db.Uuid
  urn           String          @unique @db.VarChar(200) // urn:luhtech:{project}:sdi-snapshot:{snapshotId}
  project_id    String          @map("project_id") @db.Uuid
  snapshot_id   String          @map("snapshot_id") @db.VarChar(30) // SDI-2026-0001
  snapshot_type SDISnapshotType @map("snapshot_type")
  description   String?         @db.Text

  // Scope
  voxel_urns String[] @default([]) @map("voxel_urns") // Voxels included
  building   String?  @db.VarChar(100)
  level      String?  @db.VarChar(50)
  zone       String?  @db.VarChar(100)

  // Aggregate metrics - Decisions
  total_decisions     Int @default(0) @map("total_decisions")
  pending_decisions   Int @default(0) @map("pending_decisions")
  approved_decisions  Int @default(0) @map("approved_decisions")
  rejected_decisions  Int @default(0) @map("rejected_decisions")
  escalated_decisions Int @default(0) @map("escalated_decisions")

  // Dual-Process metrics
  system_1_decisions Int      @default(0) @map("system_1_decisions")
  system_2_decisions Int      @default(0) @map("system_2_decisions")
  auto_approved      Int      @default(0) @map("auto_approved")
  pattern_match_rate Decimal? @map("pattern_match_rate") @db.Decimal(4, 3)

  // Time metrics
  avg_decision_time_ms Int? @map("avg_decision_time_ms")
  avg_system_1_time_ms Int? @map("avg_system_1_time_ms")
  avg_system_2_time_ms Int? @map("avg_system_2_time_ms")
  p95_decision_time_ms Int? @map("p95_decision_time_ms")

  // Value metrics
  total_value_at_risk Decimal? @map("total_value_at_risk") @db.Decimal(15, 2)
  total_value_saved   Decimal? @map("total_value_saved") @db.Decimal(15, 2)
  avoided_delay_hours Decimal? @map("avoided_delay_hours") @db.Decimal(8, 2)

  // Acknowledgment metrics
  total_acknowledgments   Int      @default(0) @map("total_acknowledgments")
  pending_acknowledgments Int      @default(0) @map("pending_acknowledgments")
  acknowledgment_rate     Decimal? @map("acknowledgment_rate") @db.Decimal(4, 3)
  avg_ack_time_ms         Int?     @map("avg_ack_time_ms")

  // Tolerance metrics
  tolerance_overrides Int @default(0) @map("tolerance_overrides")
  active_tolerances   Int @default(0) @map("active_tolerances")
  expired_tolerances  Int @default(0) @map("expired_tolerances")

  // Alert metrics
  active_alerts         Int @default(0) @map("active_alerts")
  critical_alerts       Int @default(0) @map("critical_alerts")
  unacknowledged_alerts Int @default(0) @map("unacknowledged_alerts")

  // Inspection metrics
  pending_inspections Int @default(0) @map("pending_inspections")
  passed_inspections  Int @default(0) @map("passed_inspections")
  failed_inspections  Int @default(0) @map("failed_inspections")

  // Consequence metrics
  active_consequences    Int      @default(0) @map("active_consequences")
  mitigated_consequences Int      @default(0) @map("mitigated_consequences")
  total_consequence_cost Decimal? @map("total_consequence_cost") @db.Decimal(15, 2)

  // Pattern learning metrics
  patterns_matched     Int      @default(0) @map("patterns_matched")
  patterns_created     Int      @default(0) @map("patterns_created")
  pattern_success_rate Decimal? @map("pattern_success_rate") @db.Decimal(4, 3)

  // Health scores
  decision_health_score Decimal? @map("decision_health_score") @db.Decimal(4, 3)
  acknowledgment_health Decimal? @map("acknowledgment_health") @db.Decimal(4, 3)
  overall_health_score  Decimal? @map("overall_health_score") @db.Decimal(4, 3)

  // Detailed breakdown
  decision_breakdown  Json? @map("decision_breakdown") @db.JsonB // By type, authority, etc.
  trade_breakdown     Json? @map("trade_breakdown") @db.JsonB // By trade
  authority_breakdown Json? @map("authority_breakdown") @db.JsonB // By authority level
  temporal_breakdown  Json? @map("temporal_breakdown") @db.JsonB // By time of day, day of week

  // Trigger context
  trigger_event_urn String? @map("trigger_event_urn") @db.VarChar(200)
  trigger_reason    String? @map("trigger_reason") @db.VarChar(200)

  // Graph metadata
  graph_metadata Json? @map("graph_metadata") @db.JsonB
  meta           Json? @db.JsonB

  // Timestamps
  snapshot_at  DateTime  @default(now()) @map("snapshot_at") @db.Timestamptz(6)
  period_start DateTime? @map("period_start") @db.Timestamptz(6)
  period_end   DateTime? @map("period_end") @db.Timestamptz(6)
  created_at   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([project_id, snapshot_id])
  @@index([urn])
  @@index([project_id, snapshot_type])
  @@index([snapshot_at(sort: Desc)])
  @@index([building, level, zone])
  @@map("sdi_snapshots")
}

// ==============================================================================
// User Management & Self-Service Onboarding (M2)
// ==============================================================================
// Enables self-service customer onboarding, email-based registration,
// team invitations, and marketing-controlled email communication
// Target: March 2026 Canadian pilot customer onboarding
// ==============================================================================

enum LifecycleStage {
  WAITLIST // Initial interest captured (landing page signup)
  EMAIL_SENT // Verification email sent
  EMAIL_VERIFIED // Email verified, ready for trial
  TRIAL // Trial tenant created, using platform
  TRIAL_EXPIRED // Trial period ended, awaiting conversion
  PAID // Active paying customer
  CHURNED // Cancelled subscription
  REACTIVATED // Returned after churn
}

enum InvitationStatus {
  PENDING // Invitation created, email sent
  ACCEPTED // User clicked link and joined
  EXPIRED // Token expired (default 7 days)
  REVOKED // Admin cancelled invitation
  BOUNCED // Email delivery failed
}

enum EmailTemplateType {
  VERIFICATION_EMAIL // "Verify your email address"
  WELCOME_TRIAL // "Welcome to Ectropy - Start your trial"
  TRIAL_REMINDER // "Your trial expires in X days"
  TRIAL_EXPIRED // "Your trial has expired - Upgrade now"
  INVITATION // "You've been invited to join [Tenant]"
  PAYMENT_SUCCESS // "Payment confirmed - Welcome to [Tier]"
  PAYMENT_FAILED // "Payment issue - Update your card"
  TEAM_MEMBER_ADDED // "New team member joined: [Name]"
  PROJECT_MILESTONE // "Project milestone achieved"
  SYSTEM_NOTIFICATION // Generic system notifications
}

enum EmailTemplateStatus {
  DRAFT // Being edited by marketing team
  ACTIVE // Currently in use for campaigns
  ARCHIVED // Replaced by newer version, kept for history
  A_B_TEST // Part of A/B testing variant
}

// ==============================================================================
// Model: EmailTemplate
// Marketing-controlled email content (replaces hardcoded templates)
// Enables marketing team to edit email content without code deployments
// ==============================================================================
model EmailTemplate {
  id            String              @id @default(uuid()) @db.Uuid
  template_type EmailTemplateType
  status        EmailTemplateStatus @default(DRAFT)

  // Content (supports handlebars-style variables like {{user_name}})
  subject      String  @db.VarChar(255)
  body_text    String  @db.Text // Plain text version
  body_html    String  @db.Text // HTML version
  preview_text String? @db.VarChar(255) // Email preview/snippet

  // Versioning (for A/B testing and rollback)
  version      Int     @default(1)
  parent_id    String? @map("parent_id") @db.Uuid // Previous version
  variant_name String? @map("variant_name") @db.VarChar(50) // "A", "B", "control"

  // Variables expected (JSON array of variable names for validation)
  required_variables String[] @default([]) @map("required_variables") // ["user_name", "verification_link"]

  // Metadata
  created_by String? @map("created_by") @db.Uuid
  updated_by String? @map("updated_by") @db.Uuid
  notes      String? @db.Text // Internal notes for marketing team

  // Timestamps
  active_from  DateTime? @map("active_from") @db.Timestamptz(6)
  active_until DateTime? @map("active_until") @db.Timestamptz(6)
  created_at   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updated_at   DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  parent   EmailTemplate?  @relation("TemplateVersions", fields: [parent_id], references: [id], onDelete: SetNull)
  children EmailTemplate[] @relation("TemplateVersions")

  @@unique([template_type, version])
  @@index([template_type, status])
  @@index([status, active_from, active_until])
  @@map("email_templates")
}

// ==============================================================================
// Model: UserRegistration
// Tracks user signup flow from waitlist to paid customer
// Central record for CRM integration and lifecycle management
// ==============================================================================
model UserRegistration {
  id        String  @id @default(uuid()) @db.Uuid
  email     String  @unique @db.VarChar(255)
  full_name String? @map("full_name") @db.VarChar(255)

  // Lifecycle tracking
  lifecycle_stage LifecycleStage @default(WAITLIST) @map("lifecycle_stage")

  // Email verification
  verification_token   String?   @unique @map("verification_token") @db.VarChar(128)
  verification_sent_at DateTime? @map("verification_sent_at") @db.Timestamptz(6)
  verified_at          DateTime? @map("verified_at") @db.Timestamptz(6)

  // Trial tracking
  trial_started_at DateTime? @map("trial_started_at") @db.Timestamptz(6)
  trial_ends_at    DateTime? @map("trial_ends_at") @db.Timestamptz(6)

  // Conversion tracking
  converted_at      DateTime?         @map("converted_at") @db.Timestamptz(6)
  subscription_tier SubscriptionTier? @map("subscription_tier")

  // CRM integration
  crm_lead_id    String? @map("crm_lead_id") @db.VarChar(100) // Twenty CRM Lead ID
  crm_contact_id String? @map("crm_contact_id") @db.VarChar(100) // Twenty CRM Contact ID
  crm_company_id String? @map("crm_company_id") @db.VarChar(100) // Twenty CRM Company ID

  // Tenant linkage (set when trial tenant created)
  tenant_id String? @map("tenant_id") @db.Uuid
  user_id   String? @map("user_id") @db.Uuid // User record created after email verification

  // Signup metadata
  registration_source String  @default("landing_page") @map("registration_source") @db.VarChar(50) // "landing_page", "invitation", "referral", "integration"
  utm_source          String? @map("utm_source") @db.VarChar(100)
  utm_medium          String? @map("utm_medium") @db.VarChar(100)
  utm_campaign        String? @map("utm_campaign") @db.VarChar(100)
  referrer            String? @db.VarChar(500)
  ip_address          String? @map("ip_address") @db.VarChar(45) // IPv6 support
  user_agent          String? @map("user_agent") @db.Text

  // Metadata
  metadata Json? @db.JsonB // Additional tracking data

  // Timestamps
  created_at DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updated_at DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  tenant Tenant? @relation(fields: [tenant_id], references: [id], onDelete: SetNull)
  user   User?   @relation(fields: [user_id], references: [id], onDelete: SetNull)

  @@index([email])
  @@index([lifecycle_stage])
  @@index([verification_token])
  @@index([tenant_id])
  @@index([crm_lead_id])
  @@index([created_at(sort: Desc)])
  @@map("user_registrations")
}

// ==============================================================================
// Model: UserInvitation
// Team invitations for adding users to existing tenants
// Secure token-based flow with expiration and role assignment
// ==============================================================================
model UserInvitation {
  id        String @id @default(uuid()) @db.Uuid
  tenant_id String @map("tenant_id") @db.Uuid
  email     String @db.VarChar(255)
  token     String @unique @db.VarChar(128) // Cryptographically secure token

  // Role assignment
  role        StakeholderRole @default(contractor)
  permissions Json?           @db.JsonB // Custom permissions if needed

  // Status tracking
  status InvitationStatus @default(PENDING)

  // Invitation metadata
  invited_by  String  @map("invited_by") @db.Uuid
  accepted_by String? @map("accepted_by") @db.Uuid // User ID when accepted
  message     String? @db.Text // Personal message from inviter

  // Email tracking
  email_sent_at    DateTime? @map("email_sent_at") @db.Timestamptz(6)
  last_reminder_at DateTime? @map("last_reminder_at") @db.Timestamptz(6)
  reminder_count   Int       @default(0) @map("reminder_count")

  // Expiration (default 7 days)
  expires_at  DateTime  @map("expires_at") @db.Timestamptz(6)
  accepted_at DateTime? @map("accepted_at") @db.Timestamptz(6)
  revoked_at  DateTime? @map("revoked_at") @db.Timestamptz(6)
  revoked_by  String?   @map("revoked_by") @db.Uuid

  // Timestamps
  created_at DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updated_at DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  tenant   Tenant @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  inviter  User   @relation("InvitationsSent", fields: [invited_by], references: [id], onDelete: Cascade)
  acceptor User?  @relation("InvitationsAccepted", fields: [accepted_by], references: [id], onDelete: SetNull)

  @@unique([tenant_id, email, status]) // Prevent duplicate pending invitations
  @@index([token])
  @@index([email])
  @@index([tenant_id, status])
  @@index([status, expires_at])
  @@index([created_at(sort: Desc)])
  @@map("user_invitations")
}

// ==============================================================================
// Model: TenantMember
// Team membership tracking (replaces implicit tenant_id on User)
// Enables users to belong to multiple tenants with different roles
// ==============================================================================
model TenantMember {
  id        String @id @default(uuid()) @db.Uuid
  tenant_id String @map("tenant_id") @db.Uuid
  user_id   String @map("user_id") @db.Uuid

  // Role within this tenant
  role        StakeholderRole @default(contractor)
  permissions Json?           @db.JsonB

  // Status
  is_active Boolean @default(true) @map("is_active")
  is_owner  Boolean @default(false) @map("is_owner") // Tenant owner (billing admin)

  // Activity tracking
  last_active_at DateTime? @map("last_active_at") @db.Timestamptz(6)

  // Timestamps
  joined_at  DateTime  @default(now()) @map("joined_at") @db.Timestamptz(6)
  removed_at DateTime? @map("removed_at") @db.Timestamptz(6)
  removed_by String?   @map("removed_by") @db.Uuid

  // Relations
  tenant Tenant @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  user   User   @relation("TenantMemberships", fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, user_id])
  @@index([user_id])
  @@index([tenant_id, is_active])
  @@index([is_active, last_active_at(sort: Desc)])
  @@map("tenant_members")
}

// ==============================================================================
// Model: SubscriptionHistory
// Tracks lifecycle transitions for analytics and compliance
// Enables conversion funnel analysis and retention metrics
// ==============================================================================
model SubscriptionHistory {
  id        String @id @default(uuid()) @db.Uuid
  tenant_id String @map("tenant_id") @db.Uuid

  // Lifecycle transition
  from_stage LifecycleStage? @map("from_stage") // null for initial creation
  to_stage   LifecycleStage  @map("to_stage")

  // Subscription details
  from_tier SubscriptionTier? @map("from_tier")
  to_tier   SubscriptionTier? @map("to_tier")

  // Financial tracking
  mrr_change Decimal? @map("mrr_change") @db.Decimal(10, 2) // Monthly Recurring Revenue change
  arr_change Decimal? @map("arr_change") @db.Decimal(10, 2) // Annual Recurring Revenue change

  // Transition metadata
  trigger         String  @db.VarChar(100) // "trial_started", "payment_success", "trial_expired", "cancellation"
  trigger_user_id String? @map("trigger_user_id") @db.Uuid // Who triggered this change
  notes           String? @db.Text

  // CRM sync
  synced_to_crm Boolean   @default(false) @map("synced_to_crm")
  crm_synced_at DateTime? @map("crm_synced_at") @db.Timestamptz(6)

  // Timestamp
  transitioned_at DateTime @default(now()) @map("transitioned_at") @db.Timestamptz(6)

  // Relations
  tenant       Tenant @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  trigger_user User?  @relation("SubscriptionTransitions", fields: [trigger_user_id], references: [id], onDelete: SetNull)

  @@index([tenant_id, transitioned_at(sort: Desc)])
  @@index([to_stage, transitioned_at(sort: Desc)])
  @@index([trigger, transitioned_at(sort: Desc)])
  @@map("subscription_history")
}

// ==============================================================================
// Roadmap Database Models
// ==============================================================================
// Database-backed storage for .roadmap/ JSON data.
// Replaces 3 independent file readers (FileDataSource, PlatformContextAdapter,
// RoadmapService) with a single Prisma-backed DataSource.
// Multi-venture ready via venture_id FK.
// ==============================================================================

enum RoadmapNodeType {
  FILE
  DIRECTORY
  SERVICE
  WORKFLOW
  DELIVERABLE
  MILESTONE
  DECISION
  EVIDENCE
  PERSON
  IP_ASSET
  DEPENDENCY
  PHASE
  TASK
  METRIC
  EXTENSION
  NODE
  WORKSTREAM
  DOCUMENT
}

enum RoadmapNodeStatus {
  ACTIVE
  ARCHIVED
  DEPRECATED
}

enum RoadmapPhaseStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  BLOCKED
}

enum RoadmapFeatureStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  DEFERRED
}

enum DocDecisionImpact {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum DocDecisionStatus {
  PROPOSED
  UNDER_REVIEW
  APPROVED
  REJECTED
  IMPLEMENTED
  DEPRECATED
}

// ==============================================================================
// Model: RoadmapVenture
// Source: venture-summary.json + roadmap.json .venture
// URN: urn:luhtech:{ventureId}:venture:{ventureId}
// ==============================================================================
model RoadmapVenture {
  id         String @id @default(uuid()) @db.Uuid
  urn        String @unique @db.VarChar(300)
  venture_id String @unique @map("venture_id") @db.VarChar(100)

  // Core identity
  name        String  @db.VarChar(255)
  tagline     String? @db.VarChar(500)
  type        String? @db.VarChar(100) // "platform", "saas", etc.
  stage       String? @db.VarChar(50) // "active", "pre-revenue", etc.
  domain      String? @db.VarChar(255)
  license     String? @db.VarChar(100)
  founded     String? @db.VarChar(20) // Year or date string

  // Architecture
  architecture Json? @db.JsonB // monorepo structure, tech stack

  // Mission & vision
  mission String? @db.Text
  vision  String? @db.Text

  // Metrics
  overall_progress            Float?   @map("overall_progress")
  production_readiness_score  Int?     @map("production_readiness_score")
  type_safety_score           Int?     @map("type_safety_score")
  metrics                     Json?    @db.JsonB // General metrics blob

  // Pitch data
  pitch Json? @db.JsonB // problem, solution, market, businessModel, differentiator, traction

  // Graph metadata
  graph_metadata Json? @map("graph_metadata") @db.JsonB

  // Timestamps
  created_at DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updated_at DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  phases         RoadmapPhase[]
  features       RoadmapFeature[]
  state_nodes    StateNode[]
  platform_state PlatformState[]
  doc_decisions  DocumentationDecision[]
  environments   InfraEnvironment[]
  infra_services InfraService[]
  votes          RoadmapVote[]
  dependencies   ExternalDependency[]

  @@index([venture_id])
  @@map("roadmap_ventures")
}

// ==============================================================================
// Model: RoadmapPhase
// Source: roadmap.json .quarters[]
// URN: urn:luhtech:{ventureId}:phase:{phaseId}
// ==============================================================================
model RoadmapPhase {
  id         String @id @default(uuid()) @db.Uuid
  urn        String @unique @db.VarChar(300)
  venture_id String @map("venture_id") @db.VarChar(100)

  phase_id   String             @map("phase_id") @db.VarChar(50)
  name       String             @db.VarChar(255)
  status     RoadmapPhaseStatus @default(PLANNED)
  progress   Float?

  // Dates
  start_date      String? @map("start_date") @db.VarChar(30)
  target_date     String? @map("target_date") @db.VarChar(30)
  completion_date String? @map("completion_date") @db.VarChar(30)

  // Graph metadata
  graph_metadata Json? @map("graph_metadata") @db.JsonB

  // Timestamps
  created_at DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updated_at DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  venture      RoadmapVenture       @relation(fields: [venture_id], references: [venture_id], onDelete: Cascade)
  deliverables RoadmapDeliverableDb[]

  @@unique([venture_id, phase_id])
  @@index([venture_id])
  @@index([status])
  @@map("roadmap_phases")
}

// ==============================================================================
// Model: RoadmapFeature
// Source: roadmap.json .features[]
// URN: urn:luhtech:{ventureId}:feature:{featureId}
// ==============================================================================
model RoadmapFeature {
  id         String @id @default(uuid()) @db.Uuid
  urn        String @unique @db.VarChar(300)
  venture_id String @map("venture_id") @db.VarChar(100)

  feature_id   String               @map("feature_id") @db.VarChar(100)
  name         String               @db.VarChar(255)
  category     String?              @db.VarChar(100)
  status       RoadmapFeatureStatus @default(PLANNED)
  priority     Int?
  phase        String?              @db.VarChar(50)
  dependencies String[]             @default([])
  description  String?              @db.Text

  // Graph metadata
  graph_metadata Json? @map("graph_metadata") @db.JsonB

  // Timestamps
  created_at DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updated_at DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  venture RoadmapVenture @relation(fields: [venture_id], references: [venture_id], onDelete: Cascade)

  @@unique([venture_id, feature_id])
  @@index([venture_id])
  @@index([status])
  @@index([category])
  @@map("roadmap_features")
}

// ==============================================================================
// Model: RoadmapDeliverableDb
// Source: roadmap.json .quarters[].deliverables[]
// URN: urn:luhtech:{ventureId}:deliverable:{deliverableId}
// ==============================================================================
model RoadmapDeliverableDb {
  id         String @id @default(uuid()) @db.Uuid
  urn        String @unique @db.VarChar(300)
  venture_id String @map("venture_id") @db.VarChar(100)

  deliverable_id String  @map("deliverable_id") @db.VarChar(100)
  title          String  @db.VarChar(500)
  description    String? @db.Text
  status         String  @default("planned") @db.VarChar(50)
  phase_id       String  @map("phase_id") @db.VarChar(50)
  assigned_to    String? @map("assigned_to") @db.VarChar(255)
  completed_date String? @map("completed_date") @db.VarChar(30)

  // Graph metadata
  graph_metadata Json? @map("graph_metadata") @db.JsonB

  // Timestamps
  created_at DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updated_at DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  phase RoadmapPhase @relation(fields: [venture_id, phase_id], references: [venture_id, phase_id], onDelete: Cascade)

  @@unique([venture_id, deliverable_id])
  @@index([venture_id])
  @@index([phase_id])
  @@index([status])
  @@map("roadmap_deliverables")
}

// ==============================================================================
// Model: StateNode
// Source: current-truth.json .nodes[]
// URN: urn:luhtech:{ventureId}:node:{nodeId}
// ==============================================================================
model StateNode {
  id         String @id @default(uuid()) @db.Uuid
  urn        String @unique @db.VarChar(300)
  venture_id String @map("venture_id") @db.VarChar(100)

  node_id     String            @map("node_id") @db.VarChar(200)
  title       String            @db.VarChar(500)
  node_type   RoadmapNodeType   @default(NODE) @map("node_type")
  status      RoadmapNodeStatus @default(ACTIVE)
  phase       String?           @db.VarChar(50)
  path        String?           @db.VarChar(1000)
  description String?           @db.Text
  owner       String?           @db.VarChar(255)

  // Content (summary, problem, solution, impact, filesModified, evidence)
  content Json? @db.JsonB

  // Relationships (dependsOn, blockedBy, relatedTo)
  relationships Json? @db.JsonB

  // Metadata (size, lines, language, etc.)
  metadata Json? @db.JsonB

  // Evidence & tags
  evidence String[] @default([])
  tags     String[] @default([])

  // Dates from source
  source_created_at  String? @map("source_created_at") @db.VarChar(30)
  source_modified_at String? @map("source_modified_at") @db.VarChar(30)
  retention_date     String? @map("retention_date") @db.VarChar(30)

  // Graph metadata
  graph_metadata Json? @map("graph_metadata") @db.JsonB

  // Timestamps
  created_at DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updated_at DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  venture RoadmapVenture @relation(fields: [venture_id], references: [venture_id], onDelete: Cascade)

  @@unique([venture_id, node_id])
  @@index([venture_id])
  @@index([node_type])
  @@index([status])
  @@index([phase])
  @@map("state_nodes")
}

