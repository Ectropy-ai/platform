# Percy Configuration for Ectropy Visual Regression Testing

# Project token (set in CI environment)
# PERCY_TOKEN=your-percy-token-here

# Browser configuration
PERCY_BROWSER_EXECUTABLE=

# Snapshot configuration
PERCY_PARALLEL_NONCE=
PERCY_PARALLEL_TOTAL=-1

# Debug and logging
PERCY_LOG_LEVEL=info
PERCY_DEBUG=

# Build configuration
PERCY_BUILD_ID=
PERCY_COMMIT=
PERCY_BRANCH=
PERCY_TARGET_BRANCH=
PERCY_TARGET_COMMIT=
PERCY_PULL_REQUEST=
PERCY_PARTIAL_BUILD=

# Advanced configuration
PERCY_TIMEOUT=30000
PERCY_ALLOWED_HOSTNAME=localhost
PERCY_DISABLE_CACHE=false