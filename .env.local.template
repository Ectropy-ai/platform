# =============================================================================
# ECTROPY PLATFORM — LOCAL SECRETS TEMPLATE
# =============================================================================
# Copy this file to .env.local (git-ignored, never commit)
# Source: Bitwarden vault (luhtechnology.com)
# Format: bare KEY=value — NO "export " prefix (Docker Compose env_file format)
#
# Retrieve via BW CLI:
#   source ~/.luhtech/secrets.env  # loads BW_SESSION
#   bw get password <ITEM_ID> | xargs -I {} echo "KEY={}" >> .env.local
#
# All item IDs below are from Bitwarden vault search results.
# =============================================================================

# --- AI Provider ---
# Bitwarden: search "ANTHROPIC_API_KEY"
ANTHROPIC_API_KEY=

# --- GitHub Packages (read:packages scope PAT) ---
# Bitwarden: search "LUHTECH_PKG_READ"
# Required for @luh-tech scoped packages from npm.pkg.github.com
LUHTECH_PKG_READ=

# --- Google OAuth (development credentials only) ---
# Bitwarden: search "ECTROPY_DEV_GOOGLE"
# WARNING: Use DEV credentials locally — NEVER prod credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- DigitalOcean ---
# Bitwarden: search "DO_API_TOKEN"
DO_API_TOKEN=

# --- Cloudflare ---
# Bitwarden: search "CF_API_TOKEN"
CF_API_TOKEN=

# --- Twenty CRM ---
# Bitwarden: search "TWENTY_API_KEY"
TWENTY_API_KEY=

# --- n8n ---
# Bitwarden: search "N8N_API_KEY"
N8N_API_KEY=

# --- Bitwarden CLI session ---
BW_SESSION=

# --- Database (fill manually for local dev — see docker-compose.development.yml) ---
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ectropy_platform
